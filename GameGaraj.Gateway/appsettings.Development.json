{
  "ReverseProxy": {
    "Routes": {
      "basket-route": {
        "ClusterId": "basket.cluster",
        "Match": {
          "Path": "{version:regex(^v[0-9]+$)}/baskets/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{version}/baskets/{**catch-all}"
          }
        ]
      },
      "catalog-route": {
        "ClusterId": "catalog.cluster",
        "Match": {
          "Path": "{version:regex(^v[0-9]+$)}/catalogs/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "photostock-route": {
        "ClusterId": "photostock.cluster",
        "Match": {
          "Path": "{version:regex(^v[0-9]+$)}/photostock/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/photos/{**catch-all}"
          }
        ]
      },
      "payment-route": {
        "ClusterId": "payment.cluster",
        "Match": {
          "Path": "{version:regex(^v[0-9]+$)}/payments/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/payments/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "basket.cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5013"
          }
        }
      },
      "catalog.cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5011"
          }
        }
      },
      "photostock.cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5012"
          }
        }
      },
      "payment.cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5014"
          }
        }
      }
    }
  },
  "IdentityOption": {
    "Address": "http://localhost:8080/realms/GameGaraj",
    "Issuer": "http://localhost:8080/realms/GameGaraj",
    "Audience": "gateway.api"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}