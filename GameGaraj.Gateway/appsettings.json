          }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://payment-api:8080"
          }
        }
      },
      "photostock-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://photostock-api:8080"
          }
        }
      },
      "campaign-cluster": {
