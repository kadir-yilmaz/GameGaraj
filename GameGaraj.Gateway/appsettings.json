            "PathPattern": "/api/v1/favorites/{**catch-all}"
          }
        ]
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/order/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "review-route": {
        "ClusterId": "review-cluster",
        "Match": {
          "Path": "/api/review/{**catch-all}"
