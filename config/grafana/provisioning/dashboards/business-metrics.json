  "panels": [
    {
      "title": "📊 Counter: Sepete Eklenen Ürünler (Rate)",
      "description": "Counter metriği: Toplam sepete eklenen ürün sayısının saniye başına artış hızı. rate() fonksiyonu counter'ı hıza dönüştürür.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(basket_items_added_total[5m])",
          "legendFormat": "Sepete Ekleme/sn"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "gradientMode": "scheme" },
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      }
    },
    {
      "title": "📊 Counter: Siparişler Oluşturuldu (Rate)",
      "description": "Counter metriği: Toplam sipariş sayısının saniye başına artış hızı.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(orders_created_total[5m])",
          "legendFormat": "Sipariş/sn"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "gradientMode": "scheme" },
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },
    {
      "title": "📊 Counter: Sepet İşlemleri (Toplam)",
      "description": "Counter metrikleri: increase() fonksiyonu ile son 1 saatte kaç adet işlem olduğunu gösterir. Counter her zaman artar, asla azalmaz.",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "increase(basket_items_added_total[1h])",
          "legendFormat": "Eklenen"
        },
        {
          "expr": "increase(basket_items_removed_total[1h])",
          "legendFormat": "Çıkarılan"
        },
        {
          "expr": "increase(basket_deleted_total[1h])",
          "legendFormat": "Silinen Sepet"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 5 },
              { "color": "yellow", "value": 50 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "value"
      }
    },
    {
      "title": "📊 Counter: Sipariş Durumları (Toplam)",
      "description": "Birden fazla counter'ı karşılaştırarak iş akışının sağlığını ölçebilirsiniz.",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "increase(orders_created_total[1h])",
          "legendFormat": "Oluşturulan"
        },
        {
          "expr": "increase(orders_cancelled_total[1h])",
          "legendFormat": "İptal Edilen"
        },
        {
          "expr": "increase(orders_completed_total[1h])",
          "legendFormat": "Tamamlanan"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 1 },
              { "color": "orange", "value": 20 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "value"
      }
    },
    {
      "title": "📊 Counter: Ödeme Başarı vs Hata",
      "description": "İki counter'ı aynı grafikte karşılaştırmak sık kullanılan bir pattern. Başarılı ve başarısız ödemeleri aynı anda görüntüler.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "rate(payments_succeeded_total[5m])",
          "legendFormat": "Başarılı"
        },
        {
          "expr": "rate(payments_failed_total[5m])",
          "legendFormat": "Başarısız"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Başarılı" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Başarısız" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      }
    },
    {
      "title": "📐 Histogram: HTTP İstek Süresi Dağılımı (P50 / P95 / P99)",
      "description": "Histogram metriği: İsteklerin süre dağılımını gösterir. histogram_quantile() ile yüzdelik dilimler hesaplanır. P50=ortanca, P95=yavaş istekler, P99=en yavaşlar.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50 (Ortanca)"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99 (En Yavaş)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "P50 (Ortanca)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P95" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P99 (En Yavaş)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      }
    },
    {
      "title": "📏 Gauge: Anlık Aktif Bağlantı Sayısı (Servis Bazlı)",
      "description": "Gauge metriği: Anlık değer gösterir, yukarı-aşağı gidebilir. Counter'dan farkı: counter sadece artar, gauge ise anlık durumu yansıtır.",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(http_server_active_requests) by (service_name)",
          "legendFormat": "{{service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "title": "📏 Gauge: .NET Heap Bellek (Anlık)",
      "description": "Gauge metriği: GC heap boyutunu anlık olarak gösterir. Büyüyen trend memory leak işareti olabilir.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "targets": [
        {
          "expr": "process_runtime_dotnet_gc_heap_size_bytes",
          "legendFormat": "{{service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "📊 Counter: Favori İşlemleri (Rate)",
      "description": "Counter: Favori ekleme ve çıkarma işlemlerinin hız karşılaştırması.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "rate(basket_favorites_added_total[5m])",
          "legendFormat": "Favori Eklendi"
        },
        {
          "expr": "rate(basket_favorites_removed_total[5m])",
          "legendFormat": "Favori Çıkarıldı"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Favori Eklendi" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Favori Çıkarıldı" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          }
        ]
      }
    },
    {
      "title": "📐 Histogram: HTTP İstek Hızı (Status Code Bazlı)",
      "description": "Counter metriği HTTP status code label'ı ile gruplandırarak kullanılan bir pattern. Label bazlı filtreleme Prometheus'un en güçlü özelliklerinden biridir.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{http_response_status_code=~\"2..\"}[5m])) by (service_name)",
          "legendFormat": "{{service_name}} 2xx"
        },
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{http_response_status_code=~\"4..\"}[5m])) by (service_name)",
          "legendFormat": "{{service_name}} 4xx"
        },
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{http_response_status_code=~\"5..\"}[5m])) by (service_name)",
          "legendFormat": "{{service_name}} 5xx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2 }
        }
      }
    }
  ],
