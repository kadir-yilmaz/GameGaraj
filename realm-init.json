{
  "realm": "GameGaraj",
  "enabled": true,
  "displayName": "GameGaraj",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 3600,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Default user role",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "instructor",
        "description": "Instructor role for content management",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "admin",
        "description": "Administrator role",
        "composite": false,
        "clientRole": false
      }
    ]
  },
  "defaultRoles": ["user"],
  "clients": [
    {
      "clientId": "web-ui",
      "name": "GameGaraj Web UI",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "attributes": {
        "access.token.lifespan": "3600"
      },
      "protocolMappers": [
        {
          "name": "audience-basket",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "basket.api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "audience-catalog",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "catalog.api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "audience-photostock",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "photostock.api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "audience-invoice",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "invoice.api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "audience-gateway",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "gateway.api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "gateway-client",
      "name": "GameGaraj API Gateway",
      "enabled": true,
      "publicClient": false,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "secret": "gateway-secret",
      "protocolMappers": [
        {
          "name": "audience-gateway",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "gateway.api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "testuser@gamegaraj.com",
      "email": "testuser@gamegaraj.com",
      "firstName": "Test",
      "lastName": "Kullanıcı",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "Password12*",
          "temporary": false
        }
      ],
      "realmRoles": ["user"]
    },
    {
      "username": "instructor@gamegaraj.com",
      "email": "instructor@gamegaraj.com",
      "firstName": "Eğitmen",
      "lastName": "Kullanıcı",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "Password12*",
          "temporary": false
        }
      ],
      "realmRoles": ["user", "instructor"]
    },
    {
      "username": "admin@gamegaraj.com",
      "email": "admin@gamegaraj.com",
      "firstName": "Admin",
      "lastName": "Kullanıcı",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "Password12*",
          "temporary": false
        }
      ],
      "realmRoles": ["user", "instructor", "admin"]
    }
  ]
}
