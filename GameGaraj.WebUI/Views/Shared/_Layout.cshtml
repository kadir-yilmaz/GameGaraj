@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    var isAuthPage = string.Equals(ViewContext.RouteData.Values["controller"]?.ToString(), "Auth", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GameGaraj</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body style="min-height: 100vh; display: flex; flex-direction: column;">
    <header>
        <!-- Navbar -->
        @await Html.PartialAsync("_Navbar")
        
        <!-- Category Bar -->
        @await Component.InvokeAsync("CategoryMenu")
    </header>
    
    <style>
        /* Navbar z-index fix */
        header > nav:first-child {
            position: relative;
            z-index: 1050;
        }
        
        .dropdown-menu {
            z-index: 1060 !important;
        }
        
        .nav-link:hover {
            color: #007bff !important;
            transform: translateY(-1px);
        }
        .dropdown-item:hover {
            background: #f8f9fa;
            padding-left: 1.25rem !important;
            transition: all 0.2s;
        }
        #searchInput::placeholder {
            color: #6c757d;
        }
        #searchInput:focus {
            background: white;
            border-color: #f39c12;
            box-shadow: 0 0 0 0.2rem rgba(243,156,18,0.25);
            color: #333;
        }
        .search-suggestion-item {
            display: grid !important;
            grid-template-columns: 52px minmax(0, 1fr) auto;
            align-items: center;
            gap: 0.75rem;
            min-height: 72px;
            padding: 0.65rem 1rem;
            cursor: pointer;
            border-bottom: 1px solid #eee;
            transition: background 0.2s ease;
        }
        .search-suggestion-item:hover {
            background: #f8f9fa;
        }
        .search-suggestion-item:last-child {
            border-bottom: none;
        }
        .search-suggestion-media {
            width: 52px;
            height: 52px;
            border-radius: 6px;
            background: #f6f7f9;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #6c757d;
            overflow: hidden;
            flex: 0 0 auto;
        }
        .search-suggestion-media img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }
        .search-suggestion-main {
            min-width: 0;
        }
        .search-suggestion-title {
            color: #222;
            font-weight: 600;
            line-height: 1.25;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .search-suggestion-meta {
            color: #6c757d;
            font-size: 0.9rem;
            margin-top: 0.2rem;
            line-height: 1.1;
        }
        .search-suggestion-type {
            color: #6c757d;
            font-size: 0.9rem;
            white-space: nowrap;
            padding-left: 1rem;
        }
        .search-suggestion-item.suggestion-brand .search-suggestion-media {
            background: #fff4e5;
            color: #f97316;
        }
        .search-suggestion-item.suggestion-brand .search-suggestion-type {
            color: #c2410c;
            background: #ffedd5;
            border-radius: 999px;
            padding: 0.3rem 0.65rem;
            font-weight: 700;
        }
        .search-suggestion-item.suggestion-category .search-suggestion-media {
            background: #eef2ff;
            color: #4f46e5;
        }
        .search-suggestion-item.suggestion-category .search-suggestion-type {
            color: #3730a3;
            background: #e0e7ff;
            border-radius: 999px;
            padding: 0.3rem 0.65rem;
            font-weight: 700;
        }
    </style>
    
    <script>
        // Search autocomplete (Multi-input support for Desktop & Mobile)
        let searchTimeout;
        const searchInputs = document.querySelectorAll('.js-search-input');
        
        searchInputs.forEach(input => {
            const suggestionsContainer = input.closest('form').querySelector('.js-search-suggestions');
            
            input.addEventListener('input', function() {
                clearTimeout(searchTimeout);
                const query = this.value.trim();
                
                if (query.length < 2) {
                    if (suggestionsContainer) suggestionsContainer.style.display = 'none';
                    return;
                }
                
                searchTimeout = setTimeout(() => {
                    fetch(`/api/products/search?q=${encodeURIComponent(query)}`)
                        .then(res => res.json())
                        .then(data => {
                            if (!suggestionsContainer) return;
                            
                            let html = '';
                            
                            // Products
                            if (data.products && data.products.length > 0) {
                                html += data.products.map(p => `
                                    <a href="${p.url}" class="search-suggestion-item text-decoration-none">
                                        <div class="search-suggestion-media">
                                            <img src="${p.imageUrl || '@GameGaraj.WebUI.Models.Products.ProductViewModel.DefaultImageUrl'}" alt="${p.name}" onerror="this.onerror=null;this.src='@GameGaraj.WebUI.Models.Products.ProductViewModel.DefaultImageUrl';">
                                        </div>
                                        <div class="search-suggestion-main">
                                            <div class="search-suggestion-title">${p.name}</div>
                                            <div class="search-suggestion-meta">${p.price || ''}</div>
                                        </div>
                                        <div class="search-suggestion-type">ÃœrÃ¼n</div>
                                    </a>
                                `).join('');
                            }

                            // Brands
                            if (data.brands && data.brands.length > 0) {
                                html += data.brands.map(b => `
                                    <a href="${b.url}" class="search-suggestion-item suggestion-brand text-decoration-none">
                                        <div class="search-suggestion-media">
                                            <i class="fas fa-tag"></i>
                                        </div>
                                        <div class="search-suggestion-main">
                                            <div class="search-suggestion-title">${b.name}</div>
                                        </div>
                                        <div class="search-suggestion-type">Marka</div>
                                    </a>
                                `).join('');
                            }
                            
                            // Categories
                            if (data.categories && data.categories.length > 0) {
                                html += data.categories.map(c => `
                                    <a href="${c.url}" class="search-suggestion-item suggestion-category text-decoration-none">
                                        <div class="search-suggestion-media">
                                            <i class="fas fa-tags"></i>
                                        </div>
                                        <div class="search-suggestion-main">
                                            <div class="search-suggestion-title">${c.name}</div>
                                        </div>
                                        <div class="search-suggestion-type">Kategori</div>
                                    </a>
                                `).join('');
                            }
                            
                            if (html !== '') {
                                suggestionsContainer.innerHTML = html;
                                suggestionsContainer.style.display = 'block';
                            } else {
                                suggestionsContainer.innerHTML = '<div class="p-3 text-muted text-center">SonuÃ§ bulunamadÄ±</div>';
                                suggestionsContainer.style.display = 'block';
                            }
                        })
                        .catch(() => {
                            if (suggestionsContainer) suggestionsContainer.style.display = 'none';
                        });
                }, 300);
            });
            
            // Close suggestions when clicking outside
            document.addEventListener('click', function(e) {
                if (!input.contains(e.target) && (!suggestionsContainer || !suggestionsContainer.contains(e.target))) {
                    if (suggestionsContainer) suggestionsContainer.style.display = 'none';
                }
            });
        });
    </script>
    <div class="container-fluid px-0" style="flex: 1; margin-top: 0; background: @(isAuthPage ? "#2f3947" : "transparent");">
        <main role="main" class="@(isAuthPage ? string.Empty : "pb-3")">
            @RenderBody()
        </main>
    </div>
    <footer class="mt-auto pt-5 pb-4" style="background-color: #0d0d0d; color: #b0b0b0; border-top: 1px solid #222;">
        <div class="container text-center">
            <!-- Tüm içeriği mobilde ve PC'de ortalamak için text-center eklendi -->
            <div class="row justify-content-center">
                <!-- Row içeriğini ortaladık -->
                <!-- Marka & Sosyal Medya -->
                <div class="col-lg-4 col-md-6 mb-4">
                    <h5 class="text-white mb-3" style="font-weight: 700; letter-spacing: 1px;">GAMEGARAJ</h5>
                    <div class="mt-3">
                        <a href="#" class="text-white mx-2 social-icon"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="text-white mx-2 social-icon"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="text-white mx-2 social-icon"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="text-white mx-2 social-icon"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>

                <!-- Kurumsal Linkler -->
                <div class="col-lg-4 col-md-6 mb-4">
                    <h5 class="text-white mb-3" style="font-weight: 600;">Kurumsal</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="#" class="text-decoration-none" style="color: #b0b0b0; transition: color 0.2s;">Biz Kimiz?</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none" style="color: #b0b0b0; transition: color 0.2s;">Kariyer</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none" style="color: #b0b0b0; transition: color 0.2s;">Gizlilik Politikası</a></li>
                    </ul>
                </div>

                <!-- İletişim Linkleri -->
                <div class="col-lg-4 col-md-6 mb-4">
                    <h5 class="text-white mb-3" style="font-weight: 600;">İletişim</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="#" class="text-decoration-none" style="color: #b0b0b0; transition: color 0.2s;">İletişim Kanalları</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none" style="color: #b0b0b0; transition: color 0.2s;">Destek / SSS</a></li>
                        <li class="mb-2" style="font-size: 0.9em;"><i class="fas fa-envelope me-2"></i> info@gamegaraj.com</li>
                    </ul>
                </div>

            </div>

            <hr style="border-color: #333; margin: 20px 0;">

            <!-- Telif Hakkı & Versiyon -->
            <div class="row">
                <div class="col-12 text-center">
                    <p class="small mb-0">
                        &copy; 2026 GameGaraj. Tüm hakları saklıdır.
                        <span class="text-muted ms-2" style="font-size: 0.85em;">Version: @(Configuration["APP_VERSION"] ?? "Local")</span>
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <!-- Toast Notification Container -->
    <div class="toast-container position-fixed end-0 bottom-0 p-4" style="z-index: 1100;">
        <div id="liveToast" class="toast app-toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex align-items-center">
                <div class="toast-body d-flex align-items-center gap-3">
                    <i class="fas fa-check-circle app-toast-icon"></i>
                    <span class="app-toast-message">&Uuml;r&uuml;n sepete eklendi!</span>
                </div>
                <button type="button" class="btn-close btn-close-white me-3 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

    <style>
        .app-toast {
            min-width: min(380px, calc(100vw - 2rem));
            border-radius: 12px;
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.22);
            overflow: hidden;
        }

        .app-toast .toast-body {
            min-height: 72px;
            padding: 1rem 1.15rem;
            font-size: 1rem;
            font-weight: 700;
            line-height: 1.35;
        }

        .app-toast-icon {
            font-size: 1.45rem;
        }

        @@media (max-width: 575px) {
            .toast-container {
                left: 0;
                right: 0;
                padding: 1rem !important;
            }

            .app-toast {
                width: 100%;
                min-width: 0;
            }
        }
    </style>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        // Check for TempData notification
        @if (TempData["BasketNotification"] != null)
        {
            <text>
            window.showAppToast && window.showAppToast('success', '&Uuml;r&uuml;n sepete eklendi!');
            </text>
        }
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
