@model int

@if (Model > 0)
{
    <span class="position-absolute badge rounded-circle d-flex align-items-center justify-content-center" 
          style="top: -8px; right: -10px; background-color: #e74c3c; color: white; width: 18px; height: 18px; font-size: 0.7rem; border: 1px solid #232f3e;">
        @Model
    </span>
}
