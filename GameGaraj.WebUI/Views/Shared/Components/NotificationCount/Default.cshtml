@model int

@if (Model > 0)
{
    <span class="position-absolute badge rounded-circle d-flex align-items-center justify-content-center notification-badge" 
          style="top: -5px; right: -8px; background-color: #f1c40f; color: #1a1d2e; width: 18px; height: 18px; font-size: 0.7rem; border: 1px solid #1a1d2e; font-weight: bold;">
        @Model
    </span>
}
