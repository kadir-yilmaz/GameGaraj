@model List<GameGaraj.WebUI.Models.Products.CategoryViewModel>
@{
    var categories = Model ?? new List<GameGaraj.WebUI.Models.Products.CategoryViewModel>();
    var rootCategories = categories.Where(x => string.IsNullOrWhiteSpace(x.ParentId)).ToList();
    if (!rootCategories.Any())
    {
        rootCategories = categories;
    }

    string CategoryUrl(GameGaraj.WebUI.Models.Products.CategoryViewModel category)
    {
        return !string.IsNullOrWhiteSpace(category.Slug)
            ? Url.Action("Index", "Product", new { category = category.Slug })!
            : Url.Action("Index", "Product", new { categoryId = category.Id })!;
    }
}

<style>
    .gg-category-bar {
        position: relative;
        z-index: 100;
        background: #22303f;
        border-top: 1px solid rgba(255,255,255,0.08);
        box-shadow: 0 10px 24px rgba(0,0,0,0.18);
    }

    .gg-category-main {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        min-height: 58px;
    }

    .gg-category-scroll-btn {
        width: 46px;
        height: 46px;
        flex: 0 0 46px;
        display: none;
        align-items: center;
        justify-content: center;
        border: 0;
        border-radius: 50%;
        background: #f39c12;
        color: #fff;
        transition: background 0.2s ease, opacity 0.2s ease, transform 0.2s ease;
    }

    .gg-category-bar.is-overflowing .gg-category-scroll-btn {
        display: inline-flex;
    }

    .gg-category-scroll-btn:hover {
        background: #f6a821;
        transform: translateY(-1px);
    }

    .gg-category-scroll-btn:disabled {
        opacity: 0.35;
        transform: none;
        cursor: default;
    }

    .gg-category-scroll {
        flex: 1 1 auto;
        display: flex;
        align-items: center;
        gap: 0.65rem;
        overflow-x: auto;
        scroll-behavior: smooth;
        scrollbar-width: none;
        padding: 0.45rem 0;
    }

    .gg-category-scroll::-webkit-scrollbar {
        display: none;
    }

    .gg-category-main-link {
        flex: 0 0 auto;
        min-height: 40px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.45rem;
        padding: 0.55rem 1.2rem;
        border: 1px solid rgba(255,255,255,0.18);
        border-radius: 8px;
        background: rgba(255,255,255,0.08);
        color: #fff;
        font-size: 0.95rem;
        font-weight: 700;
        line-height: 1;
        text-decoration: none;
        white-space: nowrap;
        transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    }

    .gg-category-main-link:hover,
    .gg-category-main-link:focus,
    .gg-category-main-link.is-active {
        background: rgba(255,255,255,0.16);
        border-color: rgba(255,255,255,0.34);
        color: #fff;
        outline: none;
    }

    .gg-category-subbar {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: #1d1f23;
        border-top: 1px solid rgba(255,255,255,0.06);
        box-shadow: 0 16px 28px rgba(0,0,0,0.22);
    }

    .gg-category-subbar.is-visible {
        display: block;
    }

    .gg-category-sub-list {
        display: none;
        align-items: center;
        justify-content: center;
        gap: 2rem;
        min-height: 62px;
        overflow-x: auto;
        scrollbar-width: none;
        padding: 0.75rem 0;
    }

    .gg-category-sub-list::-webkit-scrollbar {
        display: none;
    }

    .gg-category-sub-list.is-active {
        display: flex;
    }

    .gg-category-sub-link {
        flex: 0 0 auto;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: #d5d9df;
        font-size: 0.98rem;
        font-weight: 700;
        text-decoration: none;
        white-space: nowrap;
        transition: color 0.2s ease;
    }

    .gg-category-sub-link:hover,
    .gg-category-sub-link:focus {
        color: #fff;
        outline: none;
    }

    .gg-category-count {
        color: rgba(255,255,255,0.62);
        font-weight: 800;
    }

    @@media (max-width: 768px) {
        .gg-category-main {
            min-height: 52px;
            gap: 0.45rem;
        }

        .gg-category-scroll-btn {
            width: 38px;
            height: 38px;
            flex-basis: 38px;
        }

        .gg-category-main-link {
            min-height: 38px;
            padding: 0.5rem 0.9rem;
            font-size: 0.88rem;
        }

        .gg-category-sub-list {
            justify-content: flex-start;
            gap: 1.25rem;
            min-height: 52px;
            padding: 0.65rem 0;
        }

        .gg-category-sub-link {
            font-size: 0.9rem;
        }
    }
</style>

@if (rootCategories.Any())
{
    <nav class="gg-category-bar" data-category-menu aria-label="Kategoriler">
        <div class="container">
            <div class="gg-category-main">
                <button class="gg-category-scroll-btn" type="button" data-category-scroll-prev aria-label="Önceki kategoriler">
                    <i class="fas fa-chevron-left" aria-hidden="true"></i>
                </button>

                <div class="gg-category-scroll" data-category-scroll>
                    <a href="/Campaign" class="gg-category-main-link text-warning fw-bold" style="background: rgba(246, 139, 30, 0.15); border-color: rgba(246, 139, 30, 0.35); text-decoration: none;">
                        <i class="fas fa-gift text-warning me-1"></i> Kampanyalar
                    </a>
                    @foreach (var category in rootCategories)
                    {
                        <a href="@CategoryUrl(category)"
                           class="gg-category-main-link"
                           data-category-id="@category.Id"
                           data-has-children="@((category.Children?.Any() == true).ToString().ToLowerInvariant())">
                            @category.Name
                            <span class="gg-category-count">(@category.ProductCount)</span>
                        </a>
                    }
                </div>

                <button class="gg-category-scroll-btn" type="button" data-category-scroll-next aria-label="Sonraki kategoriler">
                    <i class="fas fa-chevron-right" aria-hidden="true"></i>
                </button>
            </div>
        </div>

        <div class="gg-category-subbar" data-category-subbar>
            <div class="container">
                @foreach (var category in rootCategories.Where(x => x.Children?.Any() == true))
                {
                    <div class="gg-category-sub-list" data-category-panel="@category.Id">
                        @foreach (var child in category.Children)
                        {
                            <a href="@CategoryUrl(child)" class="gg-category-sub-link">
                                @child.Name
                                <span class="gg-category-count">(@child.ProductCount)</span>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </nav>
}

<script>
    (function () {
        const menus = document.querySelectorAll('[data-category-menu]');

        menus.forEach(menu => {
            const scroller = menu.querySelector('[data-category-scroll]');
            const prev = menu.querySelector('[data-category-scroll-prev]');
            const next = menu.querySelector('[data-category-scroll-next]');
            const links = menu.querySelectorAll('[data-category-id]');
            const subbar = menu.querySelector('[data-category-subbar]');
            const panels = menu.querySelectorAll('[data-category-panel]');

            if (!scroller || !prev || !next) return;

            const updateScrollState = () => {
                const hasOverflow = scroller.scrollWidth > scroller.clientWidth + 4;
                menu.classList.toggle('is-overflowing', hasOverflow);
                prev.disabled = scroller.scrollLeft <= 2;
                next.disabled = scroller.scrollLeft >= scroller.scrollWidth - scroller.clientWidth - 4;
            };

            const showPanel = (categoryId) => {
                let visible = false;

                links.forEach(link => link.classList.toggle('is-active', link.dataset.categoryId === categoryId));
                panels.forEach(panel => {
                    const isActive = panel.dataset.categoryPanel === categoryId;
                    panel.classList.toggle('is-active', isActive);
                    visible = visible || isActive;
                });

                if (subbar) {
                    subbar.classList.toggle('is-visible', visible);
                }
            };

            prev.addEventListener('click', () => {
                scroller.scrollBy({ left: -Math.round(scroller.clientWidth * 0.75), behavior: 'smooth' });
            });

            next.addEventListener('click', () => {
                scroller.scrollBy({ left: Math.round(scroller.clientWidth * 0.75), behavior: 'smooth' });
            });

            links.forEach(link => {
                const activate = () => showPanel(link.dataset.categoryId);
                link.addEventListener('mouseenter', activate);
                link.addEventListener('focus', activate);
            });

            menu.addEventListener('mouseleave', () => {
                links.forEach(link => link.classList.remove('is-active'));
                panels.forEach(panel => panel.classList.remove('is-active'));
                if (subbar) subbar.classList.remove('is-visible');
            });

            scroller.addEventListener('scroll', updateScrollState, { passive: true });
            scroller.addEventListener('wheel', event => {
                if (Math.abs(event.deltaY) <= Math.abs(event.deltaX)) return;
                event.preventDefault();
                scroller.scrollLeft += event.deltaY;
            }, { passive: false });

            window.addEventListener('resize', updateScrollState);
            updateScrollState();
        });
    })();
</script>
