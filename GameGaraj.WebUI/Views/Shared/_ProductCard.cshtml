@model GameGaraj.WebUI.Models.Products.ProductViewModel

<div class="card product-card h-100 position-relative border-0 shadow-sm">
    <div class="product-img-container rounded-top overflow-hidden">
        @if (ViewBag.ShowFeaturedBadge == true)
        {
            <span class="badge-featured">Öne Çıkan</span>
        }
        <button type="button" class="btn-favorite @(Model.IsFavorite ? "active" : "")" data-product-id="@Model.Id"
            title="@(Model.IsFavorite ? "Favorilerden Çıkar" : "Favorilere Ekle")">
            <i class="@(Model.IsFavorite ? "fas" : "far") fa-heart"></i>
        </button>

        <img src="@Model.FirstImageUrl" class="product-img w-100 h-100" style="object-fit: cover;" alt="@Model.Name"
            onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1587202372634-32705e3bf49c?w=800&auto=format&fit=crop&q=80';">
    </div>
    <div class="card-body p-3 d-flex flex-column">
        <small class="text-primary fw-bold mb-1">@Model.CategoryName</small>
        <h5 class="card-title fw-bold mb-2" style="font-size: 0.95rem; line-height: 1.4;">
            <a asp-controller="Product" asp-action="Detail" asp-route-id="@Model.Id"
                class="text-decoration-none text-dark stretched-link">
                @Model.Name
            </a>
        </h5>

        @if (Model.Specs != null && Model.Specs.Any())
        {
            <ul class="list-unstyled small text-muted mb-3 flex-grow-1" style="font-size: 0.85rem;">
                @foreach (var spec in Model.Specs.Take(4))
                {
                    <li class="mb-1 text-truncate">
                        <i class="fas fa-circle me-1 text-primary" style="font-size: 4px; vertical-align: middle;"></i>
                        <strong>@spec.Key:</strong> @spec.Value
                    </li>
                }
            </ul>
        }
        else
        {
            <div class="flex-grow-1"></div>
        }

        <div class="mb-3">
            <span class="price-tag fs-5 fw-bold text-dark">@Model.Price.ToString("C2")</span>
        </div>

        @if (Model.IsInBasket)
        {
            <a asp-controller="Basket" asp-action="Index" class="btn btn-secondary w-100 mt-auto position-relative"
                style="z-index: 2; background-color: #28a745; border-color: #28a745; color: white;">
                <i class="fas fa-check me-2"></i>Sepete Git
            </a>
        }
        else
        {
            @if (Model.AvailableStock > 0 || (Model.AvailableStock == 0 && Model.Stock > 0))
            {
                <form asp-controller="Basket" asp-action="AddItem" method="post" class="w-100 mt-auto js-add-to-cart-form">
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <button type="submit" class="btn btn-outline-primary w-100 position-relative btn-hover-animate"
                        style="z-index: 2;">
                        <i class="fas fa-shopping-cart me-2"></i>Sepete Ekle
                    </button>
                </form>
            }
            else
            {
                <button type="button" class="btn btn-outline-secondary w-100 mt-auto position-relative" disabled
                    style="z-index: 2; opacity: 0.6;">
                    <i class="fas fa-ban me-2"></i>Stokta Yok
                </button>
            }
        }
    </div>
</div>
