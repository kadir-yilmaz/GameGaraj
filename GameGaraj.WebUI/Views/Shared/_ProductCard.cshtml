@model GameGaraj.WebUI.Models.Products.ProductViewModel
@{
    var cardImagesJson = System.Text.Json.JsonSerializer.Serialize(Model.DisplayImageUrls);
}

<div class="card product-card h-100 position-relative border-0 shadow-sm">
    <div class="product-img-container product-card-gallery rounded-top overflow-hidden" data-card-images='@cardImagesJson'>
        @if (ViewBag.ShowFeaturedBadge == true)
        {
            <span class="badge-featured">Öne Çıkan</span>
        }
        <button type="button" class="btn-favorite @(Model.IsFavorite ? "active" : "")" data-product-id="@Model.Id"
            title="@(Model.IsFavorite ? "Favorilerden Çıkar" : "Favorilere Ekle")">
            <i class="@(Model.IsFavorite ? "fas" : "far") fa-heart"></i>
        </button>

        <img src="@Model.FirstImageUrl" class="product-img w-100 h-100" alt="@Model.Name"
            onerror="this.onerror=null;this.src='@GameGaraj.WebUI.Models.Products.ProductViewModel.DefaultImageUrl';">

        @if (Model.DisplayImageUrls.Count > 1)
        {
            <div class="product-card-image-dots" aria-hidden="true">
                @for (int i = 0; i < Model.DisplayImageUrls.Count; i++)
                {
                    <span class="product-card-image-dot @(i == 0 ? "active" : "")"></span>
                }
            </div>
        }
    </div>
    <div class="card-body p-2 p-lg-3 d-flex flex-column">
        @if (!string.IsNullOrWhiteSpace(Model.Brand))
        {
            <small class="product-card-brand mb-1">@Model.Brand</small>
        }
        <h5 class="card-title product-card-title fw-bold mb-2">
            <a asp-controller="Product" asp-action="Detail" asp-route-slug="@Model.Slug"
                class="text-decoration-none text-dark">
                @Model.Name
            </a>
        </h5>

        @if (Model.Specs != null && Model.Specs.Any())
        {
            <ul class="list-unstyled small text-muted mb-2 flex-grow-1" style="font-size: 0.78rem;">
                @foreach (var spec in Model.Specs.Take(2))
                {
                    <li class="mb-1 text-truncate">
                        <i class="fas fa-circle me-1 text-primary" style="font-size: 4px; vertical-align: middle;"></i>
                        <strong>@spec.Key:</strong> @spec.Value
                    </li>
                }
            </ul>
        }
        else
        {
            <div class="flex-grow-1"></div>
        }

        <div class="mb-2">
            <span class="price-tag fw-bold text-dark">@Model.Price.ToString("C2")</span>
        </div>

        @if (Model.IsInBasket)
        {
            <a asp-controller="Basket" asp-action="Index" class="btn btn-secondary btn-sm w-100 mt-auto position-relative"
                style="z-index: 2; background-color: #28a745; border-color: #28a745; color: white;">
                <i class="fas fa-check me-2"></i>Sepete Git
            </a>
        }
        else
        {
            @if (Model.AvailableStock > 0 || (Model.AvailableStock == 0 && Model.Stock > 0))
            {
                <form asp-controller="Basket" asp-action="AddItem" method="post" class="w-100 mt-auto js-add-to-cart-form">
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <button type="submit" class="btn btn-outline-primary btn-sm w-100 position-relative btn-hover-animate"
                        style="z-index: 2;">
                        <i class="fas fa-shopping-cart me-2"></i>Sepete Ekle
                    </button>
                </form>
            }
            else
            {
                <button type="button" class="btn btn-outline-secondary btn-sm w-100 mt-auto position-relative" disabled
                    style="z-index: 2; opacity: 0.6;">
                    <i class="fas fa-ban me-2"></i>Stokta Yok
                </button>
            }
        }
    </div>
</div>
