@model GameGaraj.WebUI.Models.Products.ProductViewModel
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@inject GameGaraj.WebUI.Services.Abstract.ICampaignService CampaignService
@{
    var cardImagesJson = System.Text.Json.JsonSerializer.Serialize(Model.DisplayImageUrls);
    var ratingValue = 4.4m + (Math.Abs(Model.Id.GetHashCode()) % 6) / 10m;
    var reviewCount = 120 + (Math.Abs(Model.Id.GetHashCode()) % 1800);
    var stockCount = Model.AvailableStock > 0 ? Model.AvailableStock : Model.Stock;
    var isOutOfStock = stockCount <= 0;
    var isLowStock = !isOutOfStock && stockCount < 20;

    var httpContext = HttpContextAccessor.HttpContext;
    List<GameGaraj.WebUI.Models.Campaigns.CampaignRuleViewModel> activeRules = null;
    if (httpContext != null)
    {
        if (httpContext.Items.TryGetValue("ActiveCampaignRules", out var cachedRules))
        {
            activeRules = cachedRules as List<GameGaraj.WebUI.Models.Campaigns.CampaignRuleViewModel>;
        }
        else
        {
            try
            {
                var allRules = await CampaignService.GetAllRulesAsync();
                activeRules = allRules.Where(r => r.IsActive).ToList();
                httpContext.Items["ActiveCampaignRules"] = activeRules;
            }
            catch
            {
                activeRules = new List<GameGaraj.WebUI.Models.Campaigns.CampaignRuleViewModel>();
            }
        }
    }

    // Find matching campaign for this product
    GameGaraj.WebUI.Models.Campaigns.CampaignRuleViewModel matchingCampaign = null;
    if (activeRules != null)
    {
        matchingCampaign = activeRules.FirstOrDefault(r => 
            (!string.IsNullOrEmpty(r.ProductId) && r.ProductId.Equals(Model.Id, StringComparison.OrdinalIgnoreCase)) ||
            (!string.IsNullOrEmpty(r.CategoryId) && r.CategoryId.Equals(Model.CategoryId, StringComparison.OrdinalIgnoreCase)) ||
            (!string.IsNullOrEmpty(r.BrandName) && !string.IsNullOrEmpty(Model.Brand) && r.BrandName.Equals(Model.Brand, StringComparison.OrdinalIgnoreCase))
        );
    }
}

<div class="card product-card h-100 position-relative border-0 shadow-sm"
     data-product-url="@Url.Action("Detail", "Product", new { slug = Model.Slug })"
     role="link"
     tabindex="0"
     aria-label="@Model.Name">
    <div class="product-img-container product-card-gallery rounded-top overflow-hidden" data-card-images='@cardImagesJson'>
        @if (ViewBag.ShowFeaturedBadge == true)
        {
            <span class="badge-featured">&Ouml;ne &Ccedil;&#305;kan</span>
        }
        <button type="button" class="btn-favorite @(Model.IsFavorite ? "active" : "")" data-product-id="@Model.Id"
            title="@(Model.IsFavorite ? "Favorilerden \u00C7\u0131kar" : "Favorilere Ekle")">
            <i class="@(Model.IsFavorite ? "fas" : "far") fa-heart"></i>
        </button>

        <img src="@Model.FirstImageUrl" class="product-img w-100 h-100" alt="@Model.Name"
            onerror="this.onerror=null;this.src='@GameGaraj.WebUI.Models.Products.ProductViewModel.DefaultImageUrl';">

        @if (Model.DisplayImageUrls.Count > 1)
        {
            <div class="product-card-image-dots" aria-hidden="true">
                @for (int i = 0; i < Model.DisplayImageUrls.Count; i++)
                {
                    <span class="product-card-image-dot @(i == 0 ? "active" : "")"></span>
                }
            </div>
        }
    </div>
    <div class="card-body product-card-body d-flex flex-column">
        @if (matchingCampaign != null)
        {
            <div class="product-card-campaign" title="@matchingCampaign.Name">
                @matchingCampaign.Name
            </div>
        }
        else
        {
            <div class="product-card-campaign">
                Alisveris Kredisi ile 3 taksit
            </div>
        }

        <div class="product-card-name-block">
            @if (!string.IsNullOrWhiteSpace(Model.Brand))
            {
                <small class="product-card-brand-inline">
                    @Model.Brand
                    @if (Model.Brand.Equals("Samsung", StringComparison.OrdinalIgnoreCase) || Model.Brand.Equals("MSI", StringComparison.OrdinalIgnoreCase) || Model.Brand.Equals("Asus", StringComparison.OrdinalIgnoreCase))
                    {
                        <i class="fas fa-check-circle text-primary ms-1" style="font-size: 0.8rem; color: #1e90ff !important;" title="Onaylı Marka"></i>
                    }
                </small>
            }
            <a asp-controller="Product" asp-action="Detail" asp-route-slug="@Model.Slug"
               class="text-decoration-none text-dark product-card-title-link product-card-title-inline">
                @Model.Name
            </a>
        </div>

        <div class="product-card-rating">
            <i class="fas fa-star"></i>
            <span class="product-card-rating-value">@ratingValue.ToString("0.0").Replace(".", ",")</span>
            <span class="product-card-rating-count">(@reviewCount)</span>
        </div>

        <div class="product-card-stock @(isOutOfStock ? "out" : isLowStock ? "low" : "good")">
            <i class="fas @(isOutOfStock ? "fa-ban" : "fa-box")"></i>
            @(isOutOfStock ? "Stokta yok" : $"Stokta {stockCount} adet")
        </div>

        <div class="product-card-footer mt-auto">
            <div class="product-card-price-wrap d-flex align-items-baseline gap-2 flex-wrap">
                @if (matchingCampaign != null && ((matchingCampaign.DiscountRate.HasValue && matchingCampaign.DiscountRate.Value > 0) || (matchingCampaign.FixedDiscount.HasValue && matchingCampaign.FixedDiscount.Value > 0)))
                {
                    decimal discountedPrice = Model.Price;
                    if (matchingCampaign.DiscountRate.HasValue && matchingCampaign.DiscountRate.Value > 0)
                    {
                        var discountRate = matchingCampaign.DiscountRate.Value;
                        discountedPrice = Model.Price - (Model.Price * (discountRate / 100m));
                    }
                    else if (matchingCampaign.FixedDiscount.HasValue && matchingCampaign.FixedDiscount.Value > 0)
                    {
                        discountedPrice = Model.Price - matchingCampaign.FixedDiscount.Value;
                        if (discountedPrice < 0) discountedPrice = 0;
                    }
                    <span class="price-tag fw-bold" style="color: #ff4757; font-size: 1.25rem;">@discountedPrice.ToString("N0") TL</span>
                    <span class="text-muted text-decoration-line-through small" style="font-size: 0.85rem;">@Model.Price.ToString("N2") TL</span>
                }
                else
                {
                    <span class="price-tag fw-bold text-dark">@Model.Price.ToString("C2")</span>
                }
            </div>

            @if (Model.IsInBasket)
            {
                <a asp-controller="Basket" asp-action="Index" class="btn-mini-cart btn-mini-cart-success" title="Sepete Git">
                    <i class="fas fa-check"></i>
                </a>
            }
            else if (Model.AvailableStock > 0 || (Model.AvailableStock == 0 && Model.Stock > 0))
            {
                <form asp-controller="Basket" asp-action="AddItem" method="post" class="js-add-to-cart-form product-card-cart-form">
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <button type="submit" class="btn-mini-cart" title="Sepete Ekle">
                        <i class="fas fa-shopping-cart"></i>
                    </button>
                </form>
            }
            else
            {
                <button type="button" class="btn-mini-cart" disabled title="Stokta Yok">
                    <i class="fas fa-ban"></i>
                </button>
            }
        </div>
    </div>
</div>
