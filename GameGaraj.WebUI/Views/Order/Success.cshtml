@{
    ViewData["Title"] = "Ödeme Başarılı";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-body text-center py-5">
                    <div class="mb-4">
                        <i class="fas fa-check-circle text-success" style="font-size: 5rem;"></i>
                    </div>
                    <h2 class="mb-3 text-success">Ödeme Başarılı!</h2>
                    <p class="lead text-muted mb-4">
                        Siparişiniz başarıyla tamamlandı.
                    </p>
                    <p class="text-muted">
                        Sipariş numaranız: <strong class="text-primary">#@ViewBag.OrderId</strong>
                    </p>
                    
                    <div class="alert alert-success mt-4">
                        <i class="fas fa-envelope me-2"></i>
                        <strong>Fatura gönderildi!</strong> E-posta adresinize fatura gönderilmiştir.
                    </div>

                    <div class="d-grid gap-2 col-md-6 mx-auto mt-4">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
                            <i class="fas fa-home me-2"></i>Ana Sayfaya Dön
                        </a>
                        <a asp-controller="Order" asp-action="History" class="btn btn-outline-secondary">
                            <i class="fas fa-history me-2"></i>Siparişlerim
                        </a>
                    </div>
                </div>
            </div>

            <div class="card shadow mt-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">
                        <i class="fas fa-info-circle text-info me-2"></i>Bilgilendirme
                    </h5>
                    <ul class="mb-0">
                        <li class="mb-2">Siparişiniz "Tamamlandı" durumuna geçti</li>
                        <li class="mb-2">Fatura e-posta adresinize gönderildi</li>
                        <li class="mb-2">Sipariş detaylarını "Siparişlerim" sayfasından görüntüleyebilirsiniz</li>
                        <li>Herhangi bir sorun yaşarsanız müşteri hizmetlerimizle iletişime geçebilirsiniz</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
