@model List<GameGaraj.WebUI.Models.Orders.OrderViewModel>
@{
    ViewData["Title"] = "Siparişlerim";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Siparişlerim</h2>
        <a href="/" class="btn btn-outline-primary btn-sm rounded-pill"><i class="fas fa-shopping-cart me-1"></i> Alışverişe Devam Et</a>
    </div>

    @if (Model != null && Model.Any())
    {
        foreach (var order in Model)
        {
            <div class="card mb-4 shadow-sm border-0 overflow-hidden">
                <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center pt-3 px-4">
                    <div>
                        <strong class="fs-5 text-dark">Sipariş #@order.Id</strong>
                        <span class="text-muted ms-2 small">@order.CreatedDate.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>
                    <span
                        class="badge rounded-pill px-3 py-2 @(order.Status == 1 || order.Status == 5 ? "bg-success" : order.Status == 2 ? "bg-danger" : order.Status == 4 ? "bg-info pulse-badge" : order.Status == 3 ? "bg-primary pulse-badge" : "bg-warning")">
                        @(order.Status == 0 ? "Beklemede" :
                            order.Status == 1 ? "Ödeme Tamamlandı" :
                            order.Status == 2 ? "Başarısız" :
                            order.Status == 3 ? "Hazırlanıyor" :
                            order.Status == 4 ? "Kargoda" :
                            order.Status == 5 ? "Teslim Edildi" : "")
                    </span>
                </div>
                <div class="card-body px-4 pb-4">
                    <!-- Sipariş Takip Adımları -->
                    @if (order.Status != 2)
                    {
                        <div class="order-tracking mb-5">
                            <div class="steps">
                                <div class="step @(order.Status == 1 || order.Status == 3 || order.Status == 4 || order.Status == 5 ? "completed" : "")">
                                    <div class="step-icon"><i class="fas fa-check-circle"></i></div>
                                    <div class="step-label">Sipariş Alındı</div>
                                </div>
                                <div class="step @(order.Status == 4 || order.Status == 5 ? "completed" : order.Status == 3 ? "active" : "")">
                                    <div class="step-icon"><i class="fas fa-cog"></i></div>
                                    <div class="step-label">Hazırlanıyor</div>
                                </div>
                                <div class="step @(order.Status == 5 ? "completed" : order.Status == 4 ? "active" : "")">
                                    <div class="step-icon"><i class="fas fa-truck"></i></div>
                                    <div class="step-label">Kargoda</div>
                                </div>
                                <div class="step @(order.Status == 5 ? "completed" : "")">
                                    <div class="step-icon"><i class="fas fa-box-open"></i></div>
                                    <div class="step-label">Teslim Edildi</div>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="row g-4">
                        <div class="col-md-7">
                            <h6 class="text-secondary text-uppercase small fw-bold mb-3 d-flex align-items-center">
                                <i class="fas fa-laptop me-2"></i> Satın Alınan Ürünler
                            </h6>
                            <div class="order-items border rounded-3 p-3 bg-light">
                                @foreach (var item in order.OrderItems)
                                {
                                    var myReviews = ViewBag.MyReviews as Dictionary<string, GameGaraj.WebUI.Models.Reviews.ReviewViewModel> ?? new();
                                    myReviews.TryGetValue(item.ProductId, out var existingReview);
                                    var isDelivered = order.Status == 5;

                                    <div class="order-item-row mb-3 pb-3 border-bottom last-border-0">
                                        <div class="d-flex justify-content-between align-items-start gap-3 order-item-content">
                                            <div class="d-flex align-items-start flex-grow-1 min-width-0">
                                                <img src="@(string.IsNullOrWhiteSpace(item.PictureUrl) ? GameGaraj.WebUI.Models.Products.ProductViewModel.DefaultImageUrl : item.PictureUrl)"
                                                     class="rounded border me-3"
                                                     style="width: 50px; height: 50px; object-fit: cover;"
                                                     alt="@item.ProductName"
                                                     onerror="this.onerror=null;this.src='@GameGaraj.WebUI.Models.Products.ProductViewModel.DefaultImageUrl';" />
                                                <div class="flex-grow-1 min-width-0">
                                                    <div class="fw-bold text-dark">@item.ProductName</div>
                                                    <div class="text-secondary small">
                                                        @((item.Quantity > 0 ? item.Quantity : 1)) Adet x @item.Price.ToString("C2")
                                                        @if (isDelivered && item.ProductId == "__legacy_disabled__")
                                                        {
                                                            var legacyReviews = ViewBag.MyReviews as Dictionary<string, GameGaraj.WebUI.Models.Reviews.ReviewViewModel> ?? new();
                                                            legacyReviews.TryGetValue(item.ProductId, out var legacyReview);
                                                            if (legacyReview != null)
                                                            {
                                                                <button type="button"
                                                                        class="btn btn-outline-success btn-sm mt-2 btn-make-comment"
                                                                        data-bs-toggle="modal"
                                                                        data-bs-target="#commentModal"
                                                                        data-product-id="@item.ProductId"
                                                                        data-product-name="@item.ProductName"
                                                                        data-product-image="@(string.IsNullOrWhiteSpace(item.PictureUrl) ? GameGaraj.WebUI.Models.Products.ProductViewModel.DefaultImageUrl : item.PictureUrl)"
                                                                        data-is-edit="true"
                                                                        data-review-id="@legacyReview.Id"
                                                                        data-rating="@legacyReview.Rating"
                                                                        data-comment="@legacyReview.Comment">
                                                                    <i class="far fa-edit me-1"></i>Yorumu Düzenle
                                                                </button>
                                                            }
                                                            else
                                                            {
                                                                <button type="button"
                                                                        class="btn btn-outline-primary btn-sm mt-2 btn-make-comment"
                                                                        data-bs-toggle="modal"
                                                                        data-bs-target="#commentModal"
                                                                        data-product-id="@item.ProductId"
                                                                        data-product-name="@item.ProductName"
                                                                        data-product-image="@(string.IsNullOrWhiteSpace(item.PictureUrl) ? GameGaraj.WebUI.Models.Products.ProductViewModel.DefaultImageUrl : item.PictureUrl)"
                                                                        data-is-edit="false">
                                                                    <i class="far fa-comment-dots me-1"></i>Yorum Yap
                                                                </button>
                                                            }
                                                        }
                                                    </div>
                                                    @if (existingReview != null)
                                                    {
                                                        <div class="review-preview mt-2">
                                                            <div class="text-warning small mb-1">
                                                                @for (var i = 1; i <= 5; i++)
                                                                {
                                                                    <i class="@(i <= existingReview.Rating ? "fas" : "far") fa-star"></i>
                                                                }
                                                                <span class="text-muted ms-1">@existingReview.Rating / 5</span>
                                                            </div>
                                                            <div class="small text-dark review-comment-text">@existingReview.Comment</div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                            <div class="text-end order-item-actions">
                                                <div class="fw-bold fs-6 mb-2">@((item.Price * (item.Quantity > 0 ? item.Quantity : 1)).ToString("C2"))</div>
                                                @if (isDelivered)
                                                {
                                                    if (existingReview != null)
                                                    {
                                                        <button type="button"
                                                                class="btn btn-outline-success btn-sm btn-make-comment"
                                                                data-bs-toggle="modal"
                                                                data-bs-target="#commentModal"
                                                                data-product-id="@item.ProductId"
                                                                data-product-name="@item.ProductName"
                                                                data-product-image="@(string.IsNullOrWhiteSpace(item.PictureUrl) ? GameGaraj.WebUI.Models.Products.ProductViewModel.DefaultImageUrl : item.PictureUrl)"
                                                                data-is-edit="true"
                                                                data-review-id="@existingReview.Id"
                                                                data-rating="@existingReview.Rating"
                                                                data-comment="@existingReview.Comment">
                                                            <i class="far fa-edit me-1"></i>Yorumu D&#252;zenle
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button type="button"
                                                                class="btn btn-outline-primary btn-sm btn-make-comment"
                                                                data-bs-toggle="modal"
                                                                data-bs-target="#commentModal"
                                                                data-product-id="@item.ProductId"
                                                                data-product-name="@item.ProductName"
                                                                data-product-image="@(string.IsNullOrWhiteSpace(item.PictureUrl) ? GameGaraj.WebUI.Models.Products.ProductViewModel.DefaultImageUrl : item.PictureUrl)"
                                                                data-is-edit="false">
                                                            <i class="far fa-comment-dots me-1"></i>Yorum Yap
                                                        </button>
                                                    }
                                                }
                                            </div>
                                        </div>
                                        @if (item.DiscountAmount > 0)
                                        {
                                            <div class="d-flex justify-content-between text-success small mt-1 ps-5">
                                                <span><i class="fas fa-tag me-1"></i> Ürün İndirimi</span>
                                                <span class="fw-bold">-@item.DiscountAmount.ToString("C2")</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="col-md-5">
                            <div class="summary-card border rounded-3 p-4 h-100 shadow-sm bg-white">
                                <h6 class="text-secondary text-uppercase small fw-bold mb-3 d-flex align-items-center">
                                    <i class="fas fa-file-invoice-dollar me-2"></i> Hesap Özeti
                                </h6>
                                
                                <div class="price-summary">
                                    @if (order.OrderPricingLedgers != null && order.OrderPricingLedgers.Any())
                                    {
                                        foreach (var ledger in order.OrderPricingLedgers.OrderBy(x => x.SortOrder))
                                        {
                                            if (ledger.Type == 3) // Net Toplam
                                            {
                                                <hr class="my-3">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <span class="h5 mb-0 fw-bold">@ledger.Title</span>
                                                    <span class="h4 mb-0 text-primary fw-bold">@ledger.Amount.ToString("C2")</span>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="d-flex justify-content-between mb-2 @(ledger.Type == 1 ? "text-success fw-medium" : "text-dark")">
                                                    <span class="small">
                                                        @if(ledger.Type == 1) { <i class="fas fa-gift me-1"></i> }
                                                        @ledger.Title
                                                    </span>
                                                    <span class="small fw-bold">@(ledger.Type == 1 ? "-" : "")@ledger.Amount.ToString("C2")</span>
                                                </div>
                                            }
                                        }
                                    }
                                    else
                                    {
                                        @* Fallback for old orders *@
                                        <div class="d-flex justify-content-between mb-2 small text-dark">
                                            <span>Ara Toplam</span>
                                            <span class="fw-bold">@order.OriginalTotalAmount.ToString("C2")</span>
                                        </div>
                                        @if (order.CampaignDiscountAmount > 0)
                                        {
                                            <div class="d-flex justify-content-between mb-2 small text-success fw-medium">
                                                <span><i class="fas fa-gift me-1"></i> İndirim</span>
                                                <span class="fw-bold">-@order.CampaignDiscountAmount.ToString("C2")</span>
                                            </div>
                                        }
                                        <div class="d-flex justify-content-between mb-2 small text-dark">
                                            <span>Kargo</span>
                                            <span class="fw-bold">@order.ShippingFee.ToString("C2")</span>
                                        </div>
                                        <hr class="my-3">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="h5 mb-0 fw-bold">Toplam</span>
                                            <span class="h4 mb-0 text-primary fw-bold">@order.TotalPaidAmount.ToString("C2")</span>
                                        </div>
                                    }
                                </div>

                                @if (order.Address != null && !string.IsNullOrEmpty(order.Address.FirstName))
                                {
                                    <div class="mt-4 pt-4 border-top">
                                        <h6 class="text-secondary text-uppercase small fw-bold mb-3 d-flex align-items-center">
                                            <i class="fas fa-map-marker-alt me-2"></i> Teslimat
                                        </h6>
                                        <div class="small text-dark">
                                            <div class="fw-bold mb-1">@order.Address.FirstName @order.Address.LastName</div>
                                            <div class="text-muted mb-2"><i class="fas fa-phone me-1"></i> @order.Address.PhoneNumber</div>
                                            <div class="bg-light p-2 rounded border-0 text-secondary" style="font-size: 13px;">
                                                @order.Address.AddressDetail, @order.Address.Neighborhood<br />
                                                <strong>@order.Address.District / @order.Address.Province</strong> @order.Address.PostalCode
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center py-5 bg-white rounded shadow-sm border">
            <div class="mb-4"><i class="fas fa-box-open fa-5x text-light opacity-50"></i></div>
            <h4 class="text-muted fw-light">Henüz siparişiniz bulunmamaktadır.</h4>
            <p class="text-secondary mb-4">Harika PC ürünlerimize göz atarak hemen alışverişe başlayabilirsin.</p>
            <a href="/" class="btn btn-primary px-5 py-2 rounded-pill shadow-sm fw-bold">ALIŞVERİŞE BAŞLA</a>
        </div>
    }
</div>

<!-- Comment Modal -->
<div class="modal fade" id="commentModal" tabindex="-1" aria-labelledby="commentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold" id="commentModalLabel">Ürünü Değerlendir</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>
            <form asp-controller="Product" asp-action="CreateReview" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ProductId" id="modalProductId" />
                <input type="hidden" name="ProductName" id="modalProductName" />
                <input type="hidden" name="ProductImageUrl" id="modalProductImageUrl" />
                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                <input type="hidden" name="ReviewId" id="modalReviewId" />
                
                <div class="modal-body pt-3">
                    <!-- Product Info Header -->
                    <div class="d-flex align-items-center mb-4 bg-light p-3 rounded-3 border">
                        <img src="" id="modalProductImageDisplay" alt="" class="rounded border me-3 bg-white" style="width: 60px; height: 60px; object-fit: contain;" />
                        <div>
                            <div class="fw-bold text-dark text-truncate" id="modalProductNameDisplay" style="max-width: 320px;"></div>
                            <small class="text-muted">Bu ürünü değerlendiriyorsunuz</small>
                        </div>
                    </div>

                    <!-- Star Rating Selector -->
                    <div class="text-center mb-4">
                        <label class="form-label d-block text-secondary small fw-bold text-uppercase mb-2">Puanınız</label>
                        <div class="star-rating-input fs-2 text-muted">
                            <i class="far fa-star cursor-pointer px-1" data-value="1" style="cursor: pointer; transition: transform 0.15s ease;"></i>
                            <i class="far fa-star cursor-pointer px-1" data-value="2" style="cursor: pointer; transition: transform 0.15s ease;"></i>
                            <i class="far fa-star cursor-pointer px-1" data-value="3" style="cursor: pointer; transition: transform 0.15s ease;"></i>
                            <i class="far fa-star cursor-pointer px-1" data-value="4" style="cursor: pointer; transition: transform 0.15s ease;"></i>
                            <i class="far fa-star cursor-pointer px-1" data-value="5" style="cursor: pointer; transition: transform 0.15s ease;"></i>
                        </div>
                        <input type="hidden" name="Rating" id="selectedRating" required />
                        <div class="invalid-feedback d-block text-danger small mt-1" id="ratingValidationMsg" style="display:none;">Lütfen bir puan seçin.</div>
                    </div>

                    <!-- Comment Text -->
                    <div class="mb-3">
                        <label for="modalComment" class="form-label text-secondary small fw-bold text-uppercase mb-2">Değerlendirmeniz (Yorumunuz)</label>
                        <textarea class="form-control border-2" id="modalComment" name="Comment" rows="4" minlength="10" maxlength="1000" placeholder="Deneyiminizi buraya yazın (En az 10, en fazla 1000 karakter)..." required></textarea>
                        <div class="form-text d-flex justify-content-between mt-1">
                            <span class="text-muted small">Minimum 10 karakter</span>
                            <span id="charCount" class="text-muted small">0 / 1000</span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0 pb-4 px-4">
                    <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm" id="btnSubmitComment">Yorumu Gönder</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const commentModal = document.getElementById('commentModal');
        if (commentModal) {
            const ratingInput = document.getElementById('selectedRating');
            const ratingStars = commentModal.querySelectorAll('.star-rating-input i');
            const commentTextarea = document.getElementById('modalComment');
            const charCount = document.getElementById('charCount');
            const form = commentModal.querySelector('form');

            commentModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                const productId = button.getAttribute('data-product-id');
                const productName = button.getAttribute('data-product-name');
                const productImage = button.getAttribute('data-product-image');
                const isEdit = button.getAttribute('data-is-edit') === 'true';

                // Reset before assigning modal values; reset clears hidden inputs too.
                form.reset();
                document.getElementById('ratingValidationMsg').style.display = 'none';

                commentModal.querySelector('#modalProductId').value = productId;
                commentModal.querySelector('#modalProductName').value = productName;
                commentModal.querySelector('#modalProductImageUrl').value = productImage;

                commentModal.querySelector('#modalProductNameDisplay').textContent = productName;
                commentModal.querySelector('#modalProductImageDisplay').src = productImage;

                if (isEdit) {
                    form.action = '/Product/UpdateReview';
                    commentModal.querySelector('#modalReviewId').value = button.getAttribute('data-review-id');
                    commentModal.querySelector('#commentModalLabel').textContent = 'Yorumu Düzenle';

                    const rating = button.getAttribute('data-rating');
                    const comment = button.getAttribute('data-comment');

                    ratingInput.value = rating;
                    highlightStars(parseInt(rating));
                    commentTextarea.value = comment;
                    charCount.textContent = `${comment.length} / 1000`;
                } else {
                    form.action = '/Product/CreateReview';
                    commentModal.querySelector('#modalReviewId').value = '';
                    commentModal.querySelector('#commentModalLabel').textContent = 'Ürünü Değerlendir';

                    ratingInput.value = '';
                    highlightStars(0);
                    commentTextarea.value = '';
                    charCount.textContent = '0 / 1000';
                }
            });

            // Star Rating logic
            ratingStars.forEach(star => {
                star.addEventListener('mouseover', function () {
                    const val = parseInt(this.getAttribute('data-value'));
                    highlightStars(val);
                });

                star.addEventListener('mouseout', function () {
                    const currentVal = parseInt(ratingInput.value) || 0;
                    highlightStars(currentVal);
                });

                star.addEventListener('click', function () {
                    const val = parseInt(this.getAttribute('data-value'));
                    ratingInput.value = val;
                    highlightStars(val);
                    document.getElementById('ratingValidationMsg').style.display = 'none';
                });
            });

            function highlightStars(val) {
                ratingStars.forEach(star => {
                    const starVal = parseInt(star.getAttribute('data-value'));
                    if (starVal <= val) {
                        star.classList.remove('far');
                        star.classList.add('fas', 'text-warning');
                    } else {
                        star.classList.remove('fas', 'text-warning');
                        star.classList.add('far');
                    }
                });
            }

            // Character Count logic
            commentTextarea.addEventListener('input', function () {
                charCount.textContent = `${this.value.length} / 1000`;
            });

            // Validation before submit
            form.addEventListener('submit', function (e) {
                if (!ratingInput.value) {
                    e.preventDefault();
                    document.getElementById('ratingValidationMsg').style.display = 'block';
                }
            });
        }
    });
</script>

<style>
    body { background-color: #f8f9fa; }
    .card { transition: all 0.25s ease-in-out; border-radius: 16px; border: 1px solid rgba(0,0,0,.05); }
    .last-border-0:last-child { border-bottom: 0 !important; margin-bottom: 0 !important; padding-bottom: 0 !important; }
    
    .order-tracking { padding: 10px 0; }
    .order-item-actions { min-width: 150px; }
    .review-preview {
        max-width: 100%;
        border-left: 3px solid #ffc107;
        padding-left: 10px;
    }
    .review-comment-text {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.35;
    }
    .steps { display: flex; justify-content: space-between; position: relative; margin: 0 auto; max-width: 650px; }
    .steps::before { content: ''; position: absolute; top: 20px; left: 0; right: 0; height: 3px; background: #f0f0f0; z-index: 0; }
    .step { flex: 1; text-align: center; position: relative; z-index: 1; }
    .step-icon { width: 42px; height: 42px; border-radius: 50%; background: #fff; border: 3px solid #f0f0f0; color: #bbb; display: flex; align-items: center; justify-content: center; margin: 0 auto 10px; font-size: 16px; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    
    .step.completed .step-icon { background: #28a745; border-color: #28a745; color: white; transform: scale(1.1); }
    .step.active .step-icon { background: #fff; border-color: #007bff; color: #007bff; box-shadow: 0 0 15px rgba(0,123,255,0.35); transform: scale(1.15); }
    
    .step-label { font-size: 12px; color: #999; font-weight: 500; margin-top: 5px; }
    .step.completed .step-label { color: #28a745; font-weight: 600; }
    .step.active .step-label { color: #007bff; font-weight: 700; }
    
    /* Pulse Animation */
    .pulse-badge {
        box-shadow: 0 0 0 0 rgba(13, 110, 253, 0.4);
        animation: pulse-red 2s infinite;
    }
    
    .bg-info.pulse-badge {
        box-shadow: 0 0 0 0 rgba(13, 202, 240, 0.4);
        animation: pulse-info 2s infinite;
    }

    .step.active .step-icon {
        animation: pulse-blue 2s infinite;
    }

    @@keyframes pulse-blue {
        0% { box-shadow: 0 0 0 0 rgba(0, 123, 255, 0.7); }
        70% { box-shadow: 0 0 0 15px rgba(0, 123, 255, 0); }
        100% { box-shadow: 0 0 0 0 rgba(0, 123, 255, 0); }
    }

    @@keyframes pulse-info {
        0% { box-shadow: 0 0 0 0 rgba(13, 202, 240, 0.7); }
        70% { box-shadow: 0 0 0 10px rgba(13, 202, 240, 0); }
        100% { box-shadow: 0 0 0 0 rgba(13, 202, 240, 0); }
    }

    /* Icon Specific Animations */
    .step.active .fa-cog {
        animation: fa-spin 2s linear infinite;
    }

    .step.active .fa-truck {
        animation: truck-move 1s ease-in-out infinite;
    }

    @@keyframes truck-move {
        0% { transform: translateX(0); }
        25% { transform: translateX(3px) translateY(-1px); }
        50% { transform: translateX(0); }
        75% { transform: translateX(-2px) translateY(1px); }
        100% { transform: translateX(0); }
    }

    .btn-outline-primary { border-width: 2px; font-weight: 600; }
    .btn-outline-primary:hover { transform: translateY(-2px); box-shadow: 0 4px 8px rgba(0,123,255,0.2); }

    @@media (max-width: 768px) {
        .order-item-content { flex-direction: column; }
        .order-item-actions { width: 100%; text-align: left !important; padding-left: 66px; }
        .steps { flex-direction: column; text-align: left; max-width: 100%; border-left: 3px solid #f0f0f0; padding-left: 30px; margin-left: 20px; }
        .steps::before { display: none; }
        .step { display: flex; align-items: center; text-align: left; margin-bottom: 25px; }
