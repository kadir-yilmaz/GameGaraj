@model List<GameGaraj.WebUI.Models.Orders.OrderViewModel>
@{
    ViewData["Title"] = "Siparişlerim";
}

<div class="container py-4">
    <h2 class="mb-4">Siparişlerim</h2>

    @if (Model != null && Model.Any())
    {
        foreach (var order in Model)
        {
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div>
                        <strong>Sipariş #@order.Id</strong>
                        <span class="text-muted ms-2">@order.CreatedDate.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>
                    <span
                        class="badge @(order.Status == 1 || order.Status == 5 ? "bg-success" : order.Status == 2 ? "bg-danger" : order.Status == 4 ? "bg-info" : order.Status == 3 ? "bg-primary" : "bg-warning")">
                        @(order.Status == 0 ? "Beklemede" :
                            order.Status == 1 ? "Ödeme Tamamlandı" :
                            order.Status == 2 ? "Başarısız" :
                            order.Status == 3 ? "Hazırlanıyor" :
                            order.Status == 4 ? "Kargoda" :
                            order.Status == 5 ? "Teslim Edildi" : "")
                    </span>
                </div>
                <div class="card-body">
                    <!-- Sipariş Takip Adımları -->
                    @if (order.Status != 2) // Başarısız değilse
                    {
                        <div class="order-tracking mb-4">
                            <div class="steps">
                                <!-- Adım 1: Sipariş Alındı -->
                                <div class="step @(order.Status == 1 || order.Status == 3 || order.Status == 4 || order.Status == 5 ? "completed" : "")">
                                    <div class="step-icon">
                                        <i class="fas fa-check-circle"></i>
                                    </div>
                                    <div class="step-label">Sipariş Alındı</div>
                                </div>

                                <!-- Adım 2: Hazırlanıyor -->
                                <div class="step @(order.Status == 4 || order.Status == 5 ? "completed" : order.Status == 3 ? "active" : "")">
                                    <div class="step-icon">
                                        <i class="fas fa-cog"></i>
                                    </div>
                                    <div class="step-label">Hazırlanıyor</div>
                                </div>

                                <!-- Adım 3: Kargoya Verildi -->
                                <div class="step @(order.Status == 5 ? "completed" : order.Status == 4 ? "active" : "")">
                                    <div class="step-icon">
                                        <i class="fas fa-truck"></i>
                                    </div>
                                    <div class="step-label">Kargoya Verildi</div>
                                </div>

                                <!-- Adım 4: Teslim Edildi -->
                                <div class="step @(order.Status == 5 ? "completed" : "")">
                                    <div class="step-icon">
                                        <i class="fas fa-box-open"></i>
                                    </div>
                                    <div class="step-label">Teslim Edildi</div>
                                </div>
                            </div>
                        </div>
                    }

                    @if (order.Address != null && !string.IsNullOrEmpty(order.Address.FirstName))
                    {
                        <div class="mb-3">
                            <h6 class="text-muted mb-2">Teslimat Adresi</h6>
                            <p class="mb-1">
                                <i class="fas fa-user me-2"></i>
                                <strong>@order.Address.FirstName @order.Address.LastName</strong>
                            </p>
                            <p class="mb-1">
                                <i class="fas fa-phone me-2"></i>
                                @order.Address.PhoneNumber
                            </p>
                            <p class="mb-0">
                                <i class="fas fa-map-marker-alt me-2"></i>
                                @order.Address.AddressDetail, @order.Address.Neighborhood<br />
                                <span class="ms-4">@order.Address.District / @order.Address.Province
                                    @order.Address.PostalCode</span>
                            </p>
                        </div>
                        <hr>
                    }

                    <h6 class="text-muted mb-2">Ürünler</h6>
                    @foreach (var item in order.OrderItems)
                    {
                        <div class="d-flex justify-content-between mb-2">
                            <span>@item.ProductName</span>
                            <span>@item.Price.ToString("C2")</span>
                        </div>
                    }
                    <hr>
                    <div class="d-flex justify-content-between">
                        <strong>Toplam</strong>
                        <strong>@order.OrderItems.Sum(x => x.Price).ToString("C2")</strong>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i>
            Henüz siparişiniz bulunmamaktadır.
        </div>
    }
</div>

<style>
    .order-tracking {
        padding: 20px 0;
    }

    .steps {
        display: flex;
        justify-content: space-between;
        position: relative;
        margin: 0 auto;
        max-width: 800px;
    }

    .steps::before {
        content: '';
        position: absolute;
        top: 30px;
        left: 0;
        right: 0;
        height: 3px;
        background: #e0e0e0;
        z-index: 0;
    }

    .step {
        flex: 1;
        text-align: center;
        position: relative;
        z-index: 1;
    }

    .step-icon {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: #e0e0e0;
        color: #999;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 10px;
        font-size: 24px;
        transition: all 0.3s;
    }

    .step.completed .step-icon {
        background: #28a745;
        color: white;
    }

    .step.active .step-icon {
        background: #007bff;
        color: white;
        animation: pulse 2s infinite;
    }

    .step-label {
        font-size: 14px;
        color: #666;
        font-weight: 500;
    }

    .step.completed .step-label {
        color: #28a745;
        font-weight: 600;
    }

    .step.active .step-label {
        color: #007bff;
        font-weight: 600;
    }

    @@keyframes pulse {

        0%,
        100% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.1);
        }
    }

    @@media (max-width: 768px) {
        .steps {
            flex-direction: column;
        }

        .steps::before {
            display: none;
        }

        .step {
            margin-bottom: 20px;
        }
    }
</style>
