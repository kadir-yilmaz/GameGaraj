@model GameGaraj.WebUI.Models.Orders.CheckoutInfoInput
@{
    ViewData["Title"] = "Ödeme";
    var deliveryAddresses = ViewBag.DeliveryAddresses as List<GameGaraj.WebUI.Models.Addresses.UserAddressViewModel> ?? new
    List<GameGaraj.WebUI.Models.Addresses.UserAddressViewModel>();
    var invoiceAddresses = ViewBag.InvoiceAddresses as List<GameGaraj.WebUI.Models.Addresses.UserAddressViewModel> ?? new
    List<GameGaraj.WebUI.Models.Addresses.UserAddressViewModel>();
}

<style>
    .address-card {
        border: 2px solid #e0e0e0;
        border-radius: 12px;
        padding: 15px; /* Reduced padding */
        cursor: pointer;
        transition: all 0.2s ease;
        position: relative;
        background: white;
        height: 100%; /* Ensure uniform height in grid */
    }

    .address-card:hover {
        border-color: #0d6efd;
        box-shadow: 0 4px 12px rgba(13, 110, 253, 0.15);
        transform: translateY(-2px);
    }

    .address-card.selected {
        border-color: #0d6efd;
        background: #f8f9ff;
        box-shadow: 0 4px 12px rgba(13, 110, 253, 0.2);
    }

    .address-card .check-icon {
        position: absolute;
        top: 15px;
        right: 15px;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: #0d6efd;
        color: white;
        display: none;
        align-items: center;
        justify-content: center;
        font-size: 14px;
    }

    .address-card.selected .check-icon {
        display: flex;
    }

    .address-card .default-badge {
        position: absolute;
        top: 15px;
        left: 15px;
        background: #198754;
        color: white;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .new-address-card {
        border: 2px dashed #0d6efd;
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s ease;
        background: #f8f9ff;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 120px;
    }

    .new-address-card i {
        font-size: 2rem !important; /* Smaller icon */
        margin-bottom: 0.5rem !important;
    }

    .new-address-card h6 {
        font-size: 0.9rem;
        margin-bottom: 0;
    }

    .new-address-card:hover {
        background: #e7f1ff;
        border-style: solid; /* Change to solid on hover for premium feel */
    }

    .section-title {
        font-size: 1.25rem;
        font-weight: 600;
        margin-bottom: 20px;
        color: #212529;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .section-title i {
        color: #0d6efd;
    }

    /* Premium Credit Card Styles */
    .credit-card-container {
        perspective: 1000px;
        margin-bottom: 2rem;
        width: 100%;
        min-width: 320px;
    }

    .credit-card-visual {
        width: 100%;
        max-width: 400px;
        aspect-ratio: 1.586 / 1;
        height: auto;
        position: relative;
        transition: transform 0.8s;
        transform-style: preserve-3d;
        cursor: pointer;
        margin: 0 auto;
    }

    .credit-card-visual.flipped {
        transform: rotateY(180deg);
    }

    .card-front, .card-back {
        position: absolute;
        width: 100%;
        height: 100%;
        backface-visibility: hidden;
        border-radius: 15px;
        padding: 20px;
        color: white;
        box-shadow: 0 15px 35px rgba(0,0,0,0.2);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .card-front {
        background: linear-gradient(135deg, #1d1d1d 0%, #434343 100%);
    }

    .card-back {
        background: linear-gradient(135deg, #434343 0%, #1d1d1d 100%);
        transform: rotateY(180deg);
        padding: 0;
        justify-content: flex-start;
    }

    .card-chip {
        width: 50px;
        height: 40px;
        background: linear-gradient(135deg, #ffd700 0%, #b8860b 100%);
        border-radius: 5px;
        position: relative;
    }

    .card-type-icon {
        font-size: 2rem;
        opacity: 0.8;
    }

    .visual-card-number {
        font-size: 1.4rem;
        letter-spacing: 2px;
        font-family: 'Courier New', Courier, monospace;
        margin: 20px 0;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
        white-space: nowrap;
        overflow: hidden;
    }

    .card-holder-info {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
    }

    .info-label {
        font-size: 10px;
        text-transform: uppercase;
        opacity: 0.7;
        margin-bottom: 5px;
    }

    .info-value {
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 1px;
    }

    .card-magnetic-strip {
        width: 100%;
        height: 50px;
        background: #000;
        margin-top: 30px;
    }

    .card-signature-area {
        margin: 20px;
        height: 40px;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: flex-end;
        padding: 0 10px;
        color: #333;
        font-weight: bold;
        font-style: italic;
    }

    .card-cvv-box {
        background: #fff;
        padding: 5px 10px;
        border-radius: 4px;
        color: #333;
        font-family: 'Courier New', Courier, monospace;
    }

    .checkout-section-card {
        border: 1px solid rgba(0, 0, 0, 0.08) !important;
        border-radius: 16px !important;
        box-shadow: 0 10px 30px rgba(0,0,0,0.04) !important;
        background: #fff;
    }
    
    .checkout-section-header {
        background: #fafbfe;
        border-bottom: 1px solid rgba(0,0,0,0.05);
        padding: 1.25rem 1.5rem;
        margin: -1.5rem -1.5rem 1.5rem -1.5rem;
        border-top-left-radius: 15px;
        border-top-right-radius: 15px;
    }
</style>

<div class="row">
    <div class="col-lg-8">
        <form asp-controller="Order" asp-action="Checkout" method="post" id="checkoutForm" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- Adres Bilgileri -->
            <div class="card checkout-section-card mb-4">
                <div class="card-body p-4">
                    <div class="checkout-section-header">
                        <h5 class="section-title mb-0">
                            <i class="fas fa-map-marked-alt"></i> Teslimat ve Fatura Adresi
                        </h5>
                    </div>

                    @if (deliveryAddresses.Any())
                    {
                        <div class="row g-3 mb-4">
                            @foreach (var addr in deliveryAddresses)
                            {
                                <div class="col-md-6">
                                    <div class="address-card @(addr.IsDefault ? "selected" : "")" data-address-id="@addr.Id"
                                        data-type="delivery" data-firstname="@addr.FirstName" data-lastname="@addr.LastName"
                                        data-phone="@addr.PhoneNumber" data-email="@addr.Email" data-province="@addr.Province"
                                        data-district="@addr.District" data-street="@addr.Neighborhood"
                                        data-line="@addr.AddressDetail" data-zipcode="@addr.PostalCode">

                                        @if (addr.IsDefault)
                                        {
                                            <span class="default-badge">Varsayılan</span>
                                        }
                                        <div class="check-icon">
                                            <i class="fas fa-check"></i>
                                        </div>

                                        <h6 class="fw-bold mb-2" style="margin-top: @(addr.IsDefault ? "30px" : "0")">
                                            @addr.Title</h6>
                                        <p class="mb-1 text-muted small">
                                            <i class="fas fa-user me-1"></i> @addr.FirstName @addr.LastName
                                        </p>
                                        <p class="mb-1 text-muted small">
                                            <i class="fas fa-phone me-1"></i> @addr.PhoneNumber
                                        </p>
                                        <p class="mb-1 text-muted small">
                                            <i class="fas fa-envelope me-1"></i> @addr.Email
                                        </p>
                                        <p class="mb-0 text-muted small">
                                            <i class="fas fa-map-marker-alt me-1"></i>
                                            @addr.AddressDetail, @addr.Neighborhood<br />
                                            @addr.District / @addr.Province @addr.PostalCode
                                        </p>
                                    </div>
                                </div>
                            }

                            <div class="col-md-6">
                                <div class="new-address-card" id="newDeliveryAddressBtn">
                                    <i class="fas fa-plus-circle fa-3x text-primary mb-3"></i>
                                    <h6 class="text-primary fw-bold">Yeni Adres Ekle</h6>
                                    <p class="text-muted small mb-0">Farklı bir adrese teslimat</p>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle me-2"></i>
                            Kayıtlı teslimat adresiniz yok. Lütfen adres bilgilerinizi girin.
                        </div>
                    }

                    <!-- Manuel Adres Formu -->
                    <div id="deliveryAddressForm" style="display: @(deliveryAddresses.Any() ? "none" : "block")">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="mb-0">Adres Bilgileri</h6>
                            @if (deliveryAddresses.Any())
                            {
                                <button type="button" class="btn btn-sm btn-outline-secondary" id="cancelNewDeliveryBtn">
                                    <i class="fas fa-times me-1"></i> İptal
                                </button>
                            }
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="CustomerName" class="form-label small">Adınız</label>
                                <input asp-for="CustomerName" class="form-control" id="customerNameInput" required>
                                <span asp-validation-for="CustomerName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="CustomerSurname" class="form-label small">Soyadınız</label>
                                <input asp-for="CustomerSurname" class="form-control" id="customerSurnameInput" required>
                                <span asp-validation-for="CustomerSurname" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="CustomerPhone" class="form-label small">Telefon</label>
                                <input asp-for="CustomerPhone" class="form-control" id="customerPhoneInput" placeholder="05XX XXX XX XX" required>
                                <span asp-validation-for="CustomerPhone" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="CustomerEmail" class="form-label small">E-Posta</label>
                                <input asp-for="CustomerEmail" class="form-control" id="customerEmailInput" required>
                                <span asp-validation-for="CustomerEmail" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Province" class="form-label small">İl</label>
                                <select asp-for="Province" class="form-select" id="provinceSelect" required>
                                    <option value="">Seçiniz</option>
                                </select>
                                <span asp-validation-for="Province" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="District" class="form-label small">İlçe</label>
                                <select asp-for="District" class="form-select" id="districtSelect" required>
                                    <option value="">Seçiniz</option>
                                </select>
                                <span asp-validation-for="District" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Street" class="form-label small">Mahalle/Sokak</label>
                                <select asp-for="Street" class="form-select" id="streetSelect" required>
                                    <option value="">Seçiniz</option>
                                </select>
                                <span asp-validation-for="Street" class="text-danger small"></span>
                            </div>
                            <div class="col-md-12">
                                <label asp-for="Line" class="form-label small">Adres Detayı</label>
                                <textarea asp-for="Line" class="form-control" id="lineInput" rows="2" placeholder="Sokak, bina no, kat, daire..." required></textarea>
                                <span asp-validation-for="Line" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ZipCode" class="form-label small fw-bold">Posta Kodu</label>
                                <input asp-for="ZipCode" class="form-control" id="zipCodeInput" placeholder="34000" maxlength="5" oninput="this.value = this.value.replace(/[^0-9]/g, '')" required>
                                <span asp-validation-for="ZipCode" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6" id="deliveryTitleGroup" style="display: none;">
                                <label asp-for="AddressTitle" class="form-label small fw-bold">Adres Başlığı <span class="text-danger">*</span></label>
                                <input asp-for="AddressTitle" type="text" class="form-control" id="deliveryTitle"
                                    value="Adresim" placeholder="Örn: Ev Adresim">
                                <span asp-validation-for="AddressTitle" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <div class="form-check">
                                    <input asp-for="SaveAddress" class="form-check-input" type="checkbox"
                                        id="deliverySaveAddress">
                                    <label class="form-check-label" for="deliverySaveAddress">
                                        Bu adresi kaydet (gelecekte kullanmak için)
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <hr class="my-4">

                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="sameAsDelivery" checked>
                        <label class="form-check-label fw-bold" for="sameAsDelivery">
                            Fatura adresi teslimat adresi ile aynı
                        </label>
                    </div>

                    <div id="invoiceAddressSection" style="display: none;">
                        <h6 class="mb-3 text-primary"><i class="fas fa-file-invoice me-1"></i> Fatura Adresi Seçiniz</h6>
                        @if (invoiceAddresses.Any())
                        {
                            <div class="row g-3 mb-3">
                                @foreach (var addr in invoiceAddresses)
                                {
                                    <div class="col-md-6">
                                        <div class="address-card @(addr.IsDefault ? "selected" : "")" data-address-id="@addr.Id"
                                            data-type="invoice" data-province="@addr.Province" data-district="@addr.District"
                                            data-street="@addr.Neighborhood" data-line="@addr.AddressDetail"
                                            data-zipcode="@addr.PostalCode">

                                            @if (addr.IsDefault)
                                            {
                                                <span class="default-badge">Varsayılan</span>
                                            }
                                            <div class="check-icon">
                                                <i class="fas fa-check"></i>
                                            </div>

                                            <h6 class="fw-bold mb-2" style="margin-top: @(addr.IsDefault ? "30px" : "0")">
                                                @addr.Title</h6>
                                            <p class="mb-1 text-muted small">
                                                <i class="fas fa-user me-1"></i> @addr.FirstName @addr.LastName
                                            </p>
                                            <p class="mb-0 text-muted small">
                                                <i class="fas fa-map-marker-alt me-1"></i>
                                                @addr.AddressDetail, @addr.Neighborhood<br />
                                                @addr.District / @addr.Province @addr.PostalCode
                                            </p>
                                        </div>
                                    </div>
                                }

                                <div class="col-md-6">
                                    <div class="new-address-card" data-bs-toggle="modal"
                                        data-bs-target="#invoiceAddressModal">
                                        <i class="fas fa-plus-circle text-primary mb-2"></i>
                                        <h6 class="text-primary fw-bold">Yeni Fatura Adresi</h6>
                                        <p class="text-muted small mb-0">Farklı bir fatura adresi ekle</p>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info mb-3">
                                <i class="fas fa-info-circle me-2"></i>
                                Kayıtlı fatura adresiniz yok.
                            </div>
                            <button type="button" class="btn btn-primary" data-bs-toggle="modal"
                                data-bs-target="#invoiceAddressModal">
                                <i class="fas fa-plus me-1"></i> Fatura Adresi Ekle
                            </button>
                        }
                    </div>
                </div>
            </div>

            <!-- Ödeme Bilgileri -->
            <div class="card checkout-section-card mb-4">
                <div class="card-body p-4">
                    <div class="checkout-section-header">
                        <h5 class="section-title mb-0">
                            <i class="fas fa-credit-card"></i> Ödeme Bilgileri
                        </h5>
                    </div>

                    <div class="row g-3">
                        <div class="col-lg-6">
                            <div class="row g-3">
                                <div class="col-12">
                                    <label asp-for="CardName" class="form-label small">Kart Üzerindeki İsim</label>
                                    <input asp-for="CardName" class="form-control" id="cardHolderInput" autocomplete="off" required placeholder="AD SOYAD">
                                    <span asp-validation-for="CardName" class="text-danger small"></span>
                                </div>
                                <div class="col-12">
                                    <label asp-for="CardNumber" class="form-label small">Kart Numarası</label>
                                    <input asp-for="CardNumber" class="form-control" id="cardNumberInput" maxlength="19" autocomplete="off" required placeholder="0000 0000 0000 0000">
                                    <span asp-validation-for="CardNumber" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Expiration" class="form-label small">Son Kullanma Tarihi</label>
                                    <input asp-for="Expiration" class="form-control" id="cardExpiryInput" placeholder="AA/YY" maxlength="5"
                                        autocomplete="off" required>
                                    <span asp-validation-for="Expiration" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="CVV" class="form-label small">CVV</label>
                                    <input asp-for="CVV" class="form-control" id="cardCvvInput" maxlength="3" autocomplete="off" required placeholder="000">
                                    <span asp-validation-for="CVV" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6 d-flex align-items-center">
                            <div class="credit-card-container">
                                <div class="credit-card-visual" id="visualCard">
                                    <!-- Front -->
                                    <div class="card-front">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="card-chip"></div>
                                            <i class="fab fa-cc-visa card-type-icon"></i>
                                        </div>
                                        <div class="visual-card-number" id="vCardNumber">#### #### #### ####</div>
                                        <div class="card-holder-info">
                                            <div>
                                                <div class="info-label">KART SAHİBİ</div>
                                                <div class="info-value" id="vCardName">AD SOYAD</div>
                                            </div>
                                            <div class="text-end">
                                                <div class="info-label">SON KUL.</div>
                                                <div class="info-value" id="vCardExpiry">AA/YY</div>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- Back -->
                                    <div class="card-back">
                                        <div class="card-magnetic-strip"></div>
                                        <div class="card-signature-area">
                                            <div class="card-cvv-box" id="vCardCvv">***</div>
                                        </div>
                                        <div class="p-3">
                                            <small style="font-size: 8px; opacity: 0.5;">Bu kart görseli sadece önizleme amaçlıdır. Güvenliğiniz için gerçek kart bilgilerinizi kimseyle paylaşmayın.</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm sticky-top" style="top: 2rem;">
            <div class="card-body">
                <h5 class="card-title mb-3">Sipariş Özeti</h5>

                @if (ViewBag.Basket is GameGaraj.WebUI.Models.Baskets.BasketViewModel basket)
                {
                    <div class="mb-3">
                        @foreach (var item in basket.Items)
                        {
                            <div class="d-flex align-items-center justify-content-between mb-3 pb-3 border-bottom">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="rounded-3 border overflow-hidden bg-light d-flex align-items-center justify-content-center" style="width: 54px; height: 54px; flex-shrink: 0;">
                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <img src="@item.ImageUrl" alt="@item.ProductName" style="max-width: 100%; max-height: 100%; object-fit: contain;" />
                                        }
                                        else
                                        {
                                            <i class="fas fa-image text-muted"></i>
                                        }
                                    </div>
                                    <div>
                                        @if (!string.IsNullOrEmpty(item.Brand))
                                        {
                                            <div class="text-muted text-uppercase fw-bold" style="font-size: 0.65rem; letter-spacing: 0.5px; margin-bottom: 2px;">@item.Brand</div>
                                        }
                                        <h6 class="mb-0 text-dark fw-semibold" style="font-size: 0.85rem; line-height: 1.3; max-width: 160px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@item.ProductName">@item.ProductName</h6>
                                        <small class="text-secondary">Adet: <span class="fw-semibold">@item.Quantity</span></small>
                                    </div>
                                </div>
                                <span class="fw-bold text-dark" style="font-size: 0.9rem;">@((item.Price * item.Quantity).ToString("C2"))</span>
                            </div>
                        }
                    </div>

                    <hr>

                    var discountResult = ViewBag.DiscountResult as GameGaraj.WebUI.Models.Campaigns.CalculateDiscountResponse;
                    var shippingSetting = ViewBag.ShippingSetting as GameGaraj.WebUI.Models.Campaigns.ShippingSettingViewModel;
                    
                    var isShippingFree = basket.TotalPrice >= (shippingSetting?.FreeShippingThreshold ?? 0) || !(shippingSetting?.IsActive ?? true);
                    var finalShippingFee = isShippingFree ? 0 : (shippingSetting?.DefaultShippingFee ?? 0);
                    
                    var finalItemsTotal = discountResult != null ? discountResult.FinalTotal : basket.TotalPrice;
                    var finalGrossTotal = finalItemsTotal + finalShippingFee;

                    @if (discountResult != null && discountResult.AppliedRules != null && discountResult.AppliedRules.Any())
                    {
                        <div class="d-flex justify-content-between mb-2">
                            <span>Ara Toplam</span>
                            <span>@discountResult.OriginalTotal.ToString("C2")</span>
                        </div>

                        foreach (var appliedRule in discountResult.AppliedRules)
                        {
                            <div class="d-flex justify-content-between mb-2 text-success">
                                <span>
                                    <i class="fas fa-tag me-1"></i>@appliedRule.RuleName
                                </span>
                                <span class="fw-bold">-@appliedRule.DiscountAmount.ToString("C2")</span>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="d-flex justify-content-between mb-2">
                            <span>Ara Toplam</span>
                            <span>@basket.TotalPrice.ToString("C2")</span>
                        </div>
                    }
                    
                    @if (shippingSetting != null && shippingSetting.IsActive)
                    {
                        <div class="d-flex justify-content-between mb-2">
                            <span>Kargo Tutarı</span>
                            <span>@shippingSetting.DefaultShippingFee.ToString("C2")</span>
                        </div>
                        @if (isShippingFree)
                        {
                            <div class="d-flex justify-content-between mb-2 text-success">
                                <span><i class="fas fa-truck text-success me-1"></i>Kargo İndirimi</span>
                                <span class="fw-bold">-@shippingSetting.DefaultShippingFee.ToString("C2")</span>
                            </div>
                        }
                    }

                    <div class="mt-4 mb-4">
                        <h6 class="fw-bold mb-2 small"><i class="fas fa-ticket-alt me-1 text-primary"></i>Kupon Kodu</h6>
                        
                        @if (ViewBag.AppliedCoupon is GameGaraj.WebUI.Models.Campaigns.CouponViewModel coupon)
                        {
                            decimal couponDiscAmount = 0;
                            string couponDisplay = coupon.Code;

                            if (coupon.DiscountType == "Percentage" && coupon.DiscountRate > 0)
                            {
                                couponDiscAmount = finalGrossTotal * (coupon.DiscountRate.Value / 100m);
                                if (coupon.MaxDiscountAmount > 0 && couponDiscAmount > coupon.MaxDiscountAmount)
                                {
                                    couponDiscAmount = coupon.MaxDiscountAmount.Value;
                                }
                                couponDisplay += $" (%{coupon.DiscountRate})";
                            }
                            else if (coupon.DiscountType == "FixedAmount" && coupon.Amount > 0)
                            {
                                couponDiscAmount = coupon.Amount.Value;
                                couponDisplay += $" (-{coupon.Amount} TL)";
                            }
                            else if (coupon.DiscountType == "FreeShipping")
                            {
                                couponDiscAmount = finalShippingFee;
                                couponDisplay += " (Kargo Bedava)";
                            }

                            finalGrossTotal -= couponDiscAmount;
                            if (finalGrossTotal < 0) finalGrossTotal = 0;

                            <div class="p-2 border rounded bg-light d-flex justify-content-between align-items-center">
                                <span class="text-success fw-bold small">
                                    <i class="fas fa-check-circle me-1"></i>@couponDisplay
                                </span>
                                <form asp-action="RemoveCoupon" method="post" class="m-0 ajax-cart-form">
                                    <button type="submit" class="btn btn-sm text-danger p-0"><i class="fas fa-times"></i></button>
                                </form>
                            </div>
                            
                            <div class="d-flex justify-content-between mt-2 text-success">
                                <span class="small">Kupon İndirimi</span>
                                <span class="fw-bold">-@couponDiscAmount.ToString("N2") TL</span>
                            </div>
                        }
                        else
                        {
                            <form asp-action="ApplyCoupon" method="post" class="input-group input-group-sm ajax-cart-form">
                                <input type="text" name="couponCode" class="form-control" style="text-transform: uppercase;" oninput="this.value = this.value.toUpperCase()" placeholder="Kupon kodunuz">
                                <button class="btn btn-primary" type="submit">Uygula</button>
                            </form>
                            
                            @if (TempData["CouponError"] != null)
                            {
                                <div class="text-danger x-small mt-1" style="font-size: 0.75rem;">
                                    <i class="fas fa-exclamation-circle me-1"></i>@TempData["CouponError"]
                                </div>
                            }
                            @if (TempData["CouponSuccess"] != null)
                            {
                                <div class="text-success x-small mt-1" style="font-size: 0.75rem;">
                                    <i class="fas fa-check-circle me-1"></i>@TempData["CouponSuccess"]
                                </div>
                            }
                        }
                    </div>

                    <hr>

                    <div class="d-flex justify-content-between mb-3">
                        <span class="fw-bold">Genel Toplam</span>
                        <span class="fw-bold text-primary h4">@finalGrossTotal.ToString("C2")</span>
                    </div>
                }

                @if (ViewBag.Error != null || !ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger shadow-sm py-2">
                        <div class="d-flex align-items-center mb-1">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            <strong class="small">Lütfen aşağıdaki alanları kontrol ediniz:</strong>
                        </div>
                        <div asp-validation-summary="All" class="text-danger small mb-0" style="list-style: none; padding-left: 0;"></div>
                        @if (ViewBag.Error != null)
                        {
                            <div class="small text-danger mt-1">@ViewBag.Error</div>
                        }
                    </div>
                }

                <button type="submit" form="checkoutForm" class="btn btn-success w-100 py-3 fw-bold">
                    <i class="fas fa-lock me-2"></i> Güvenli Ödeme Yap
                </button>

                <div class="text-center mt-3">
                    <small class="text-muted">
                        <i class="fas fa-shield-alt"></i> 256-bit SSL ile korunmaktadır
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Fatura Adresi Modal -->
<div class="modal fade" id="invoiceAddressModal" tabindex="-1" aria-labelledby="invoiceAddressModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="invoiceAddressModalLabel">
                    <i class="fas fa-file-invoice me-2"></i>Yeni Fatura Adresi Ekle
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="invoiceAddressForm">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small">Ad <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="invoiceFirstName" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Soyad <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="invoiceLastName" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Telefon <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="invoicePhone" placeholder="+90 555 123 4567"
                                required>
                        </div>
                        <div class="col-md-12">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label small fw-bold">Adres Başlığı <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="invoiceTitle" value="Adresim" placeholder="Örn: Ev Adresim" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small fw-bold">Posta Kodu</label>
                                    <input type="text" class="form-control" id="invoicePostalCode" maxlength="5" placeholder="34000" oninput="this.value = this.value.replace(/[^0-9]/g, '')">
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">İl <span class="text-danger">*</span></label>
                            <select class="form-select" id="invoiceProvinceInput" required>
                                <option value="">İl Seçiniz</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">İlçe <span class="text-danger">*</span></label>
                            <select class="form-select" id="invoiceDistrictInput" required disabled>
                                <option value="">İlçe Seçiniz</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">Mahalle <span class="text-danger">*</span></label>
                            <select class="form-select" id="invoiceNeighborhood" required disabled>
                                <option value="">Mahalle Seçiniz</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label small">Adres Detayı <span class="text-danger">*</span></label>
                            <textarea class="form-control" id="invoiceAddressDetail" rows="2" required></textarea>
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="invoiceSaveAddress">
                                <label class="form-check-label" for="invoiceSaveAddress">
                                    Bu adresi kaydet (gelecekte kullanmak için)
                                </label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-primary" id="saveInvoiceAddressBtn">
                    <i class="fas fa-check me-1"></i> Kullan
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // --- ADDRESS DATA LOGIC ---
            let addressData = {};
            const provinceSelect = document.getElementById('provinceSelect');
            const districtSelect = document.getElementById('districtSelect');
            const streetSelect = document.getElementById('streetSelect');

            const invProvinceSelect = document.getElementById('invoiceProvinceInput');
            const invDistrictSelect = document.getElementById('invoiceDistrictInput');
            const invStreetSelect = document.getElementById('invoiceNeighborhood');

            function setupCascadingDropdowns(pSelect, dSelect, sSelect) {
                pSelect.addEventListener('change', function () {
                    const province = this.value;
                    dSelect.innerHTML = '<option value="">İlçe Seçiniz</option>';
                    sSelect.innerHTML = '<option value="">Mahalle Seçiniz</option>';
                    sSelect.disabled = true;

                    if (province && addressData[province]) {
                        dSelect.disabled = false;
                        Object.keys(addressData[province]).sort().forEach(d => {
                            dSelect.add(new Option(d, d));
                        });
                    } else {
                        dSelect.disabled = true;
                    }
                });

                dSelect.addEventListener('change', function () {
                    const province = pSelect.value;
                    const district = this.value;
                    sSelect.innerHTML = '<option value="">Mahalle Seçiniz</option>';

                    if (province && district && addressData[province][district]) {
                        sSelect.disabled = false;
                        addressData[province][district].sort().forEach(m => {
                            sSelect.add(new Option(m, m));
                        });
                    } else {
                        sSelect.disabled = true;
                    }
                });
            }

            // Load Address JSON
            fetch('/data/il_ilce_mahalle.json')
                .then(res => res.json())
                .then(data => {
                    addressData = data;
                    const provinces = Object.keys(data).sort();
                    provinces.forEach(p => {
                        provinceSelect.add(new Option(p, p));
                        invProvinceSelect.add(new Option(p, p));
                    });

                    setupCascadingDropdowns(provinceSelect, districtSelect, streetSelect);
                    setupCascadingDropdowns(invProvinceSelect, invDistrictSelect, invStreetSelect);

                    // --- AUTO-SELECT DEFAULT ADDRESS (Wait until data is loaded) ---
                    const defaultCard = document.querySelector('.address-card.selected[data-type="delivery"]');
                    if (defaultCard) {
                        setTimeout(() => {
                            defaultCard.click();
                        }, 50);
                    }
                })
                .catch(err => console.error('Adres verisi yüklenemedi:', err));

            // --- VISUAL CARD LOGIC ---
            const visualCard = document.getElementById('visualCard');
            const cardHolderInput = document.getElementById('cardHolderInput');
            const cardNumberInput = document.getElementById('cardNumberInput');
            const cardExpiryInput = document.getElementById('cardExpiryInput');
            const cardCvvInput = document.getElementById('cardCvvInput');

            const vName = document.getElementById('vCardName');
            const vNumber = document.getElementById('vCardNumber');
            const vExpiry = document.getElementById('vCardExpiry');
            const vCvv = document.getElementById('vCardCvv');

            // Card Holder Name Sync
            cardHolderInput.addEventListener('input', (e) => {
                vName.textContent = e.target.value.toUpperCase() || "AD SOYAD";
            });

            // Card Number Formatting & Sync
            cardNumberInput.addEventListener('input', (e) => {
                let value = e.target.value.replace(/\D/g, '');
                value = value.match(/.{1,4}/g)?.join(' ') || '';
                e.target.value = value;
                vNumber.textContent = value || "#### #### #### ####";
                
                // Card Type Detect (Basic)
                const firstDigit = value[0];
                const icon = visualCard.querySelector('.card-type-icon');
                if (firstDigit === '4') icon.className = 'fab fa-cc-visa card-type-icon';
                else if (firstDigit === '5') icon.className = 'fab fa-cc-mastercard card-type-icon';
                else icon.className = 'fas fa-credit-card card-type-icon';
            });

            // Expiry Formatting & Sync
            cardExpiryInput.addEventListener('input', (e) => {
                let val = e.target.value.replace(/\D/g, '');
                if (val.length > 2) val = val.substring(0, 2) + '/' + val.substring(2, 4);
                e.target.value = val;
                vExpiry.textContent = val || "AA/YY";
            });

            // CVV Sync & Flip
            cardCvvInput.addEventListener('input', (e) => {
                vCvv.textContent = e.target.value || "***";
            });

            cardCvvInput.addEventListener('focus', () => visualCard.classList.add('flipped'));
            cardCvvInput.addEventListener('blur', () => visualCard.classList.remove('flipped'));

            // --- EXISTING ADDRESS SELECTION LOGIC ---
            document.querySelectorAll('.address-card[data-type="delivery"]').forEach(card => {
                card.addEventListener('click', function () {
                    document.querySelectorAll('.address-card[data-type="delivery"]').forEach(c => c.classList.remove('selected'));
                    this.classList.add('selected');

                    document.getElementById('customerNameInput').value = this.dataset.firstname || '';
                    document.getElementById('customerSurnameInput').value = this.dataset.lastname || '';
                    document.getElementById('customerPhoneInput').value = this.dataset.phone || '';
                    document.getElementById('customerEmailInput').value = this.dataset.email || '';
                    
                    // Dropdown setting needs careful async handling
                    const p = this.dataset.province;
                    const d = this.dataset.district;
                    const m = this.dataset.street;

                    if (provinceSelect.querySelector(`option[value="${p}"]`)) {
                        provinceSelect.value = p;
                        provinceSelect.dispatchEvent(new Event('change'));
                        
                        setTimeout(() => {
                            districtSelect.value = d;
                            districtSelect.dispatchEvent(new Event('change'));
                            setTimeout(() => {
                                streetSelect.value = m;
                            }, 100);
                        }, 100);
                    }

                    document.getElementById('lineInput').value = this.dataset.line || '';
                    document.getElementById('zipCodeInput').value = this.dataset.zipcode || '';
                    document.getElementById('deliveryAddressForm').style.display = 'none';
                });
            });

            document.getElementById('newDeliveryAddressBtn')?.addEventListener('click', function () {
                document.querySelectorAll('.address-card[data-type="delivery"]').forEach(c => c.classList.remove('selected'));
                document.getElementById('deliveryAddressForm').style.display = 'block';
                document.getElementById('checkoutForm').reset();
                provinceSelect.dispatchEvent(new Event('change'));
            });

            document.getElementById('cancelNewDeliveryBtn')?.addEventListener('click', function () {
                document.getElementById('deliveryAddressForm').style.display = 'none';
                const firstCard = document.querySelector('.address-card[data-type="delivery"]');
                if (firstCard) firstCard.click();
            });

            document.getElementById('sameAsDelivery')?.addEventListener('change', function () {
                document.getElementById('invoiceAddressSection').style.display = this.checked ? 'none' : 'block';
            });

            // Toggle Address Title group on save address change
            const saveCheck = document.getElementById('deliverySaveAddress');
            const titleGroup = document.getElementById('deliveryTitleGroup');
            if (saveCheck && titleGroup) {
                saveCheck.addEventListener('change', function () {
                    titleGroup.style.display = this.checked ? 'block' : 'none';
                });
                titleGroup.style.display = saveCheck.checked ? 'block' : 'none';
            }

            // Form Submit Cleanup (Remove spaces from card number)
            document.getElementById('checkoutForm')?.addEventListener('submit', function (e) {
                const num = document.getElementById('cardNumberInput');
                if (num) num.value = num.value.replace(/\s/g, '');
            });

            // --- AUTO-SYNC CARD ON LOAD ---
            function syncCard() {
                if (cardHolderInput.value) vName.textContent = cardHolderInput.value.toUpperCase();
                if (cardNumberInput.value) vNumber.textContent = cardNumberInput.value;
                if (cardExpiryInput.value) vExpiry.textContent = cardExpiryInput.value;
                if (cardCvvInput.value) vCvv.textContent = cardCvvInput.value;
            }
            syncCard();

            // Sepet formlarını global (event delegation) yakala ve sayfa yenilemeden gönder
            document.body.addEventListener('submit', async function(e) {
                if (e.target.classList.contains('ajax-cart-form')) {
                    e.preventDefault();
                    
                    const currForm = e.target;
                    const formData = new FormData(currForm);
                    
                    // Butona tıklanma animasyonu
                    const btn = currForm.querySelector('button');
                    if(btn) {
                        btn.disabled = true;
                        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
                    }

                    try {
                        const response = await fetch(currForm.getAttribute('action'), { 
                            method: 'POST', 
                            body: formData 
                        });
                        
                        if (response.ok) {
                            const html = await response.text();
                            const doc = new DOMParser().parseFromString(html, "text/html");
                            
                            // Replace the entire right column (summary)
                            const newSummary = doc.querySelector('.col-lg-4');
                            if (newSummary) {
                                document.querySelector('.col-lg-4').innerHTML = newSummary.innerHTML;
                            } else {
                                window.location.reload(); // Fallback
                            }
                        } else {
                            window.location.reload();
                        }
                    } catch (err) {
                        window.location.reload();
                    }
                }
            });
        });
    </script>
}
