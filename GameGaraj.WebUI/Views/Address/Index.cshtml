@model GameGaraj.WebUI.Models.Addresses.AddressListViewModel
@{
    ViewData["Title"] = "Adreslerim";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-map-marker-alt me-2"></i>Adreslerim</h5>
                </div>
                <div class="card-body">

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle me-1"></i> @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle me-1"></i> @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <!-- Tab Navigation -->
                    <ul class="nav nav-tabs mb-4" id="addressTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(Model.ActiveTab == GameGaraj.WebUI.Models.Addresses.AddressType.Delivery ? "active" : "")" 
                                    id="delivery-tab" data-bs-toggle="tab" data-bs-target="#delivery" 
                                    type="button" role="tab">
                                <i class="fas fa-truck me-1"></i> Teslimat Adreslerim
                                <span class="badge bg-secondary ms-1">@Model.DeliveryAddresses.Count</span>
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(Model.ActiveTab == GameGaraj.WebUI.Models.Addresses.AddressType.Invoice ? "active" : "")" 
                                    id="invoice-tab" data-bs-toggle="tab" data-bs-target="#invoice" 
                                    type="button" role="tab">
                                <i class="fas fa-file-invoice me-1"></i> Fatura Adreslerim
                                <span class="badge bg-secondary ms-1">@Model.InvoiceAddresses.Count</span>
                            </button>
                        </li>
                    </ul>

                    <!-- Tab Content -->
                    <div class="tab-content" id="addressTabsContent">
                        
                        <!-- Teslimat Adresleri -->
                        <div class="tab-pane fade @(Model.ActiveTab == GameGaraj.WebUI.Models.Addresses.AddressType.Delivery ? "show active" : "")" 
                             id="delivery" role="tabpanel">
                            
                            <div class="alert alert-info mb-4">
                                <i class="fas fa-info-circle me-1"></i>
                                Maksimum 3 teslimat adresi ekleyebilirsiniz. Adres değişiklikleri geçmiş siparişleri etkilemez.
                            </div>

                            @if (Model.DeliveryAddresses.Count < 3)
                            {
                                <a asp-action="Create" asp-route-type="@GameGaraj.WebUI.Models.Addresses.AddressType.Delivery" 
                                   class="btn btn-primary mb-4">
                                    <i class="fas fa-plus me-1"></i> Yeni Teslimat Adresi Ekle
                                </a>
                            }

                            @if (Model.DeliveryAddresses.Any())
                            {
                                <div class="row">
                                    @foreach (var address in Model.DeliveryAddresses)
                                    {
                                        <div class="col-md-6 mb-3">
                                            <div class="card @(address.IsDefault ? "border-primary" : "")">
                                                <div class="card-body">
                                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                                        <h6 class="card-title mb-0">
                                                            @address.Title
                                                            @if (address.IsDefault)
                                                            {
                                                                <span class="badge bg-primary ms-2">Varsayılan</span>
                                                            }
                                                        </h6>
                                                    </div>
                                                    <p class="card-text mb-2">
                                                        <strong>@address.FirstName @address.LastName</strong><br />
                                                        @address.PhoneNumber<br />
                                                        @address.AddressDetail<br />
                                                        @address.Neighborhood, @address.District / @address.Province<br />
                                                        @if (!string.IsNullOrEmpty(address.PostalCode))
                                                        {
                                                            <text>Posta Kodu: @address.PostalCode</text>
                                                        }
                                                    </p>
                                                    <div class="btn-group btn-group-sm" role="group">
                                                        <a asp-action="Edit" asp-route-id="@address.Id" class="btn btn-outline-primary">
                                                            <i class="fas fa-edit"></i> Düzenle
                                                        </a>
                                                        @if (!address.IsDefault)
                                                        {
                                                            <form asp-action="SetDefault" method="post" class="d-inline">
                                                                <input type="hidden" name="id" value="@address.Id" />
                                                                <input type="hidden" name="type" value="@address.Type" />
                                                                <button type="submit" class="btn btn-outline-success">
                                                                    <i class="fas fa-star"></i> Varsayılan Yap
                                                                </button>
                                                            </form>
                                                        }
                                                        <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Bu adresi silmek istediğinizden emin misiniz?');">
                                                            <input type="hidden" name="id" value="@address.Id" />
                                                            <input type="hidden" name="tab" value="@address.Type" />
                                                            <button type="submit" class="btn btn-outline-danger">
                                                                <i class="fas fa-trash"></i> Sil
                                                            </button>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="text-center text-muted py-5">
                                    <i class="fas fa-map-marker-alt fa-3x mb-3"></i>
                                    <p>Henüz teslimat adresi eklememişsiniz.</p>
                                </div>
                            }
                        </div>

                        <!-- Fatura Adresleri -->
                        <div class="tab-pane fade @(Model.ActiveTab == GameGaraj.WebUI.Models.Addresses.AddressType.Invoice ? "show active" : "")" 
                             id="invoice" role="tabpanel">
                            
                            <div class="alert alert-info mb-4">
                                <i class="fas fa-info-circle me-1"></i>
                                Maksimum 3 fatura adresi ekleyebilirsiniz. Fatura adresi sadece bilgi amaçlıdır.
                            </div>

                            @if (Model.InvoiceAddresses.Count < 3)
                            {
                                <a asp-action="Create" asp-route-type="@GameGaraj.WebUI.Models.Addresses.AddressType.Invoice" 
                                   class="btn btn-primary mb-4">
                                    <i class="fas fa-plus me-1"></i> Yeni Fatura Adresi Ekle
                                </a>
                            }

                            @if (Model.InvoiceAddresses.Any())
                            {
                                <div class="row">
                                    @foreach (var address in Model.InvoiceAddresses)
                                    {
                                        <div class="col-md-6 mb-3">
                                            <div class="card @(address.IsDefault ? "border-primary" : "")">
                                                <div class="card-body">
                                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                                        <h6 class="card-title mb-0">
                                                            @address.Title
                                                            @if (address.IsDefault)
                                                            {
                                                                <span class="badge bg-primary ms-2">Varsayılan</span>
                                                            }
                                                        </h6>
                                                    </div>
                                                    <p class="card-text mb-2">
                                                        <strong>@address.FirstName @address.LastName</strong><br />
                                                        @address.PhoneNumber<br />
                                                        @address.AddressDetail<br />
                                                        @address.Neighborhood, @address.District / @address.Province<br />
                                                        @if (!string.IsNullOrEmpty(address.PostalCode))
                                                        {
                                                            <text>Posta Kodu: @address.PostalCode</text>
                                                        }
                                                    </p>
                                                    <div class="btn-group btn-group-sm" role="group">
                                                        <a asp-action="Edit" asp-route-id="@address.Id" class="btn btn-outline-primary">
                                                            <i class="fas fa-edit"></i> Düzenle
                                                        </a>
                                                        @if (!address.IsDefault)
                                                        {
                                                            <form asp-action="SetDefault" method="post" class="d-inline">
                                                                <input type="hidden" name="id" value="@address.Id" />
                                                                <input type="hidden" name="type" value="@address.Type" />
                                                                <button type="submit" class="btn btn-outline-success">
                                                                    <i class="fas fa-star"></i> Varsayılan Yap
                                                                </button>
                                                            </form>
                                                        }
                                                        <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Bu adresi silmek istediğinizden emin misiniz?');">
                                                            <input type="hidden" name="id" value="@address.Id" />
                                                            <input type="hidden" name="tab" value="@address.Type" />
                                                            <button type="submit" class="btn btn-outline-danger">
                                                                <i class="fas fa-trash"></i> Sil
                                                            </button>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="text-center text-muted py-5">
                                    <i class="fas fa-file-invoice fa-3x mb-3"></i>
                                    <p>Henüz fatura adresi eklememişsiniz.</p>
                                </div>
                            }
                        </div>

                    </div>
                </div>
            </div>
            
        </div>
    </div>
</div>
