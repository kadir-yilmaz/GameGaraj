@model GameGaraj.WebUI.Models.Addresses.UpdateUserAddressInput
@{
    ViewData["Title"] = "Adres Düzenle";
    var isDelivery = Model.Type == GameGaraj.WebUI.Models.Addresses.AddressType.Delivery;
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-edit me-2"></i>
                        @(isDelivery ? "Teslimat Adresi Düzenle" : "Fatura Adresi Düzenle")
                    </h5>
                </div>
                <div class="card-body">

                    <form method="post" asp-action="Edit">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="Type" />

                        <!-- Kişisel Bilgiler -->
                        <h6 class="text-muted mb-3">Kişisel Bilgiler</h6>
                        
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label">Ad <span class="text-danger">*</span></label>
                                <input class="form-control" asp-for="FirstName" required />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Soyad <span class="text-danger">*</span></label>
                                <input class="form-control" asp-for="LastName" required />
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Telefon <span class="text-danger">*</span></label>
                                <input class="form-control" asp-for="PhoneNumber" placeholder="+90 555 123 4567" required />
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">E-posta <span class="text-danger">*</span></label>
                                <input type="email" class="form-control" asp-for="Email" placeholder="ornek@email.com" required />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <!-- Adres Bilgileri -->
                        <h6 class="text-muted mb-3">Adres Bilgileri</h6>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">Adres Başlığı <span class="text-danger">*</span></label>
                                <input class="form-control" asp-for="Title" placeholder="Adresim" required />
                                <span asp-validation-for="Title" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small fw-bold">Posta Kodu</label>
                                <input class="form-control" asp-for="PostalCode" maxlength="5" placeholder="34000" oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                                <span asp-validation-for="PostalCode" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-4">
                                <label class="form-label small">İl <span class="text-danger">*</span></label>
                                <select class="form-select" asp-for="Province" id="provinceInput" required>
                                    <option value="">İl Seçiniz</option>
                                </select>
                                <span asp-validation-for="Province" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label small">İlçe <span class="text-danger">*</span></label>
                                <select class="form-select" asp-for="District" id="districtInput" required disabled>
                                    <option value="">İlçe Seçiniz</option>
                                </select>
                                <span asp-validation-for="District" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label small">Mahalle <span class="text-danger">*</span></label>
                                <select class="form-select" asp-for="Neighborhood" id="streetInput" required disabled>
                                    <option value="">Mahalle Seçiniz</option>
                                </select>
                                <span asp-validation-for="Neighborhood" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12">
                                <label class="form-label small">Adres Detayı <span class="text-danger">*</span></label>
                                <textarea class="form-control" asp-for="AddressDetail" rows="3" 
                                          placeholder="Sokak, bina no, daire no..." required></textarea>
                                <span asp-validation-for="AddressDetail" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <div class="form-check mt-3">
                                    <input class="form-check-input" type="checkbox" asp-for="IsDefault" />
                                    <label class="form-check-label fw-bold" asp-for="IsDefault">
                                        Varsayılan adres olarak ayarla
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <a asp-action="Index" asp-route-tab="@Model.Type" class="btn btn-outline-secondary">
                                <i class="fas fa-times me-1"></i> Vazgeç
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-check me-1"></i> Güncelle
                            </button>
                        </div>

                    </form>
                </div>
            </div>
            
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            let addressData = {};
            const provinceSelect = document.getElementById('provinceInput');
            const districtSelect = document.getElementById('districtInput');
            const streetSelect = document.getElementById('streetInput');

            // Initial values from model
            const initialProvince = '@Html.Raw(Model.Province)';
            const initialDistrict = '@Html.Raw(Model.District)';
            const initialStreet = '@Html.Raw(Model.Neighborhood)';

            fetch('/data/il_ilce_mahalle.json')
                .then(res => res.json())
                .then(data => {
                    addressData = data;
                    const provinces = Object.keys(data).sort();
                    provinces.forEach(p => {
                        provinceSelect.add(new Option(p, p));
                    });

                    // Set initial province
                    if (initialProvince && addressData[initialProvince]) {
                        provinceSelect.value = initialProvince;
                        provinceSelect.dispatchEvent(new Event('change'));

                        // Set initial district
                        if (initialDistrict && addressData[initialProvince][initialDistrict]) {
                            districtSelect.value = initialDistrict;
                            districtSelect.dispatchEvent(new Event('change'));

                            // Set initial street
                            if (initialStreet && addressData[initialProvince][initialDistrict].includes(initialStreet)) {
                                streetSelect.value = initialStreet;
                            }
                        }
                    }
                });

            provinceSelect.addEventListener('change', function () {
                const province = this.value;
                districtSelect.innerHTML = '<option value="">İlçe Seçiniz</option>';
                streetSelect.innerHTML = '<option value="">Mahalle Seçiniz</option>';
                streetSelect.disabled = true;

                if (province && addressData[province]) {
                    districtSelect.disabled = false;
                    Object.keys(addressData[province]).sort().forEach(d => {
                        districtSelect.add(new Option(d, d));
                    });
                } else {
                    districtSelect.disabled = true;
                }
            });

            districtSelect.addEventListener('change', function () {
                const province = provinceSelect.value;
                const district = this.value;
                streetSelect.innerHTML = '<option value="">Mahalle Seçiniz</option>';

                if (province && district && addressData[province][district]) {
                    streetSelect.disabled = false;
                    addressData[province][district].sort().forEach(m => {
                        streetSelect.add(new Option(m, m));
                    });
                } else {
                    streetSelect.disabled = true;
                }
            });
        });
    </script>
}
