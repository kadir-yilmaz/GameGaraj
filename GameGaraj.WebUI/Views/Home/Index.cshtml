<!-- Home Categories Section -->
@if (homeCategories.Any())
{
    foreach (var category in homeCategories)
    {
        <div class="container my-5 py-4 border-top home-category-section"
             data-home-category-section
             data-load-url="@Url.Action("CategoryShowcase", "Home", new { categoryId = category.Id })">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="fs-3 fw-bold mb-0">@category.Name</h2>
                    </div>
                    <a asp-controller="Product" asp-action="Index" asp-route-categoryId="@category.Id" class="btn btn-outline-dark rounded-pill px-4">
                        Tümünü Gör <i class="fas fa-arrow-right ms-2"></i>
                    </a>
                </div>

                <div class="row row-cols-2 row-cols-md-3 row-cols-xl-5 g-3 home-category-loader" data-home-category-content>
                    <div class="col-12">
                        <div class="p-5 bg-light rounded-3 text-center text-muted">
                            <div class="spinner-border text-primary mb-3" role="status"></div>
                            <div>Urunler yukleniyor...</div>
                        </div>
                    </div>
                </div>
            </div>
    }
}

@section Scripts {
    <script>
        function copyCouponCode(code, btn) {
            navigator.clipboard.writeText(code).then(function() {
                // Change icon to check
                const icon = btn.querySelector('i');
                icon.className = 'fa-solid fa-check text-success';
                
                // Show toast using our global notification helper
                if (window.showAppToast) {
                    window.showAppToast('success', 'Kupon kodu (' + code + ') kopyalandı!');
                }
                
                // Reset icon after 2 seconds
                setTimeout(function() {
                    icon.className = 'fa-regular fa-copy';
                }, 2000);
            }).catch(function(err) {
                console.error('Kopyalama başarısız: ', err);
            });
        }

        document.addEventListener('DOMContentLoaded', function () {
            const sections = Array.from(document.querySelectorAll('[data-home-category-section]'));
            const pendingSections = [];
            let activeLoaders = 0;
            const maxConcurrentLoaders = 5;

            function loadNextSection() {
                if (pendingSections.length === 0) {
                    return;
                }

                while (activeLoaders < maxConcurrentLoaders && pendingSections.length > 0) {
                    const section = pendingSections.shift();
                    if (!section || section.dataset.loaded === 'true') {
                        continue;
                    }

                    const content = section.querySelector('[data-home-category-content]');
                    const url = section.dataset.loadUrl;

                    if (!content || !url) {
                        continue;
                    }

                    activeLoaders++;
                    section.dataset.loaded = 'true';

                    fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                        .then(response => {
                            if (!response.ok) {
                                throw new Error('Category products could not be loaded.');
                            }
                            return response.text();
                        })
                        .then(html => {
                            if (!html.includes('product-card')) {
                                section.style.display = 'none';
                            } else {
                                content.innerHTML = html;
                            }
                        })
                        .catch(() => {
                            content.innerHTML = '<div class="col-12"><div class="p-4 bg-light rounded-3 text-center text-muted">Urunler yuklenemedi.</div></div>';
                        })
                        .finally(() => {
                            activeLoaders--;
                            loadNextSection();
                        });
                }
            }

            if ('IntersectionObserver' in window) {
                const observer = new IntersectionObserver(function (entries) {
                    entries.forEach(entry => {
                        if (!entry.isIntersecting) {
                            return;
                        }

                        observer.unobserve(entry.target);
                        pendingSections.push(entry.target);
                        loadNextSection();
                    });
                }, { rootMargin: '250px 0px' });

                sections.forEach(section => observer.observe(section));
            } else {
                pendingSections.push(...sections);
                loadNextSection();
            }
        });
    </script>
}
