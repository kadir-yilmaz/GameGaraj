@model List<GameGaraj.WebUI.Models.Products.ProductViewModel>
@{
    ViewData["Title"] = ViewBag.CurrentCategoryName ?? "Ürünler";
    var categories = ViewBag.Categories as List<GameGaraj.WebUI.Models.Products.CategoryViewModel>;
    var currentCategoryId = ViewBag.CategoryId as string;
    var currentCategoryAttributes = ViewBag.CurrentCategoryAttributes as
    List<GameGaraj.WebUI.Models.Products.CategoryAttributeViewModel>;
    var selectedSpecs = ViewBag.SelectedSpecs as Dictionary<string, string[]> ?? new Dictionary<string, string[]>();
    var brands = ViewBag.Brands as List<string> ?? new List<string>();
    var selectedBrand = ViewBag.Brand as string;
    var rootCategories = categories?.Where(x => string.IsNullOrWhiteSpace(x.ParentId)).ToList() ?? new List<GameGaraj.WebUI.Models.Products.CategoryViewModel>();
    if (!rootCategories.Any() && categories != null)
    {
        rootCategories = categories;
    }
    var totalProductCount = rootCategories.Sum(x => x.ProductCount);

    string CategoryUrl(GameGaraj.WebUI.Models.Products.CategoryViewModel category)
    {
        return !string.IsNullOrWhiteSpace(category.Slug)
            ? Url.Action("Index", "Product", new { category = category.Slug })!
            : Url.Action("Index", "Product", new { categoryId = category.Id })!;
    }

    bool HasActiveDescendant(GameGaraj.WebUI.Models.Products.CategoryViewModel category)
    {
        return category.Children.Any(child => child.Id == currentCategoryId || HasActiveDescendant(child));
    }
}

@await Html.PartialAsync("_ProductCardStyles")

<style>
    /* Sidebar */
    .sidebar {
        background: #fff;
        border: 1px solid #e0e7ef;
        border-radius: 0;
        padding: 1.25rem;
        box-shadow: none;
        position: sticky;
        top: 20px;
        max-height: calc(100vh - 40px);
        overflow-y: auto;
    }

    .sidebar::-webkit-scrollbar {
        width: 6px;
    }

    .sidebar::-webkit-scrollbar-thumb {
        background: #ddd;
        border-radius: 3px;
    }

    .filter-section {
        margin-bottom: 1.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #eee;
    }

    .filter-section:last-child {
        border-bottom: none;
    }

    .filter-title {
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 1rem;
        color: #333;
    }

    .price-filter-apply {
        background: #f07400;
        border-color: #f07400;
        color: #fff;
        font-weight: 700;
    }

    .price-filter-apply:hover,
    .price-filter-apply:focus {
        background: #d96500;
        border-color: #d96500;
        color: #fff;
    }

    .category-panel-title {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-size: 1.15rem;
        font-weight: 800;
        color: #111827;
        padding-bottom: 0.9rem;
        margin-bottom: 1.1rem;
        border-bottom: 1px solid #e5eaf0;
    }

    .category-panel-title i {
        color: #ffb000;
    }

    .category-tree {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .category-tree-link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        min-height: 42px;
        padding: 0.65rem 0.85rem;
        border-radius: 8px;
        text-decoration: none;
        color: #526176;
        font-weight: 700;
        transition: background 0.2s ease, color 0.2s ease;
    }

    .category-tree-link:hover {
        background: #f1f5f9;
        color: #f07400;
    }

    .category-tree-link.active {
        background: #eef2f7;
        color: #f07400;
    }

    .category-tree-link.child {
        min-height: 36px;
        padding: 0.48rem 0.85rem 0.48rem 1.7rem;
        font-size: 0.92rem;
    }

    .category-children {
        margin-left: 0.95rem;
        padding-left: 0.95rem;
        border-left: 1px solid #e3e9f2;
    }

    .category-count-badge {
        min-width: 30px;
        height: 24px;
        padding: 0 0.45rem;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #dce5ef;
        border-radius: 999px;
        color: #526176;
        background: #fff;
        font-size: 0.78rem;
        font-weight: 800;
        line-height: 1;
    }

    /* Mobile Sidebar */
    @@media (max-width: 991px) {
        .sidebar-col {
            display: none !important;
        }

        #mobileFilterSidebar {
            position: fixed;
            bottom: -100%;
            left: 0;
            right: 0;
            top: auto;
            height: 85vh;
            max-height: 85vh;
            width: 100%;
            z-index: 1050;
            transition: bottom 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            border-radius: 24px 24px 0 0;
            box-shadow: 0 -8px 32px rgba(0, 0, 0, 0.2);
            padding: 0;
            background: white;
        }

        #mobileFilterSidebar.show {
            bottom: 0;
        }

        .sidebar-header {
            position: sticky;
            top: 0;
            background: #fff;
            padding: 1.5rem;
            border-bottom: 1px solid #eee;
            border-radius: 24px 24px 0 0;
            z-index: 10;
        }

        .sidebar-handle {
            width: 40px;
            height: 4px;
            background: #ddd;
            border-radius: 2px;
            margin: 0 auto 1rem;
        }

        .mobile-sidebar-content {
            padding: 1.5rem;
            overflow-y: auto;
            height: calc(85vh - 80px);
        }

        .sidebar-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(4px);
            z-index: 1040;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s;
        }

        .sidebar-overlay.show {
            opacity: 1;
            visibility: visible;
        }
    }

    @@media (min-width: 992px) {
        #mobileFilterSidebar {
            display: none !important;
        }
        
        .sidebar-header {
            display: none !important;
        }

        .sidebar-content {
            padding: 0;
        }

        .sidebar-overlay {
            display: none !important;
        }
    }
</style>

<div class="container-fluid py-4">
    <div class="row g-4">
        <!-- Sidebar -->
        <div class="col-lg-2 sidebar-col">
            <div class="sidebar" id="filterSidebar">
                <div class="sidebar-content">
                    <!-- Categories Section -->
                    <div class="filter-section">
                        <div class="category-panel-title">
                            <i class="fas fa-grip"></i>
                            <span>Tüm Kategoriler</span>
                        </div>

                        <div class="category-tree">
                            <a href="/product"
                               class="category-tree-link @(string.IsNullOrWhiteSpace(currentCategoryId) ? "active" : "")">
                                <span><i class="fas fa-list me-2"></i>Tüm Ürünler</span>
                                <span class="category-count-badge">@totalProductCount</span>
                            </a>

                            @if (rootCategories.Any())
                            {
                                @foreach (var category in rootCategories)
                                {
                                    var isCategoryActive = currentCategoryId == category.Id;
                                    var hasActiveChild = HasActiveDescendant(category);
                                    var isOpen = isCategoryActive || hasActiveChild;

                                    <a href="@CategoryUrl(category)"
                                       class="category-tree-link @(isCategoryActive || hasActiveChild ? "active" : "")">
                                        <span>@category.Name</span>
                                        <span class="category-count-badge">@category.ProductCount</span>
                                    </a>

                                    @if (category.Children != null && category.Children.Any() && isOpen)
                                    {
                                        <div class="category-children">
                                            @foreach (var child in category.Children)
                                            {
                                                var isChildActive = currentCategoryId == child.Id;
                                                var childHasActiveDescendant = HasActiveDescendant(child);

                                                <a href="@CategoryUrl(child)"
                                                   class="category-tree-link child @(isChildActive || childHasActiveDescendant ? "active" : "")">
                                                    <span>@child.Name</span>
                                                    <span class="category-count-badge">@child.ProductCount</span>
                                                </a>

                                                @if (child.Children != null && child.Children.Any() && (isChildActive || childHasActiveDescendant))
                                                {
                                                    <div class="category-children">
                                                        @foreach (var grandChild in child.Children)
                                                        {
                                                            <a href="@CategoryUrl(grandChild)"
                                                               class="category-tree-link child @(currentCategoryId == grandChild.Id ? "active" : "")">
                                                                <span>@grandChild.Name</span>
                                                                <span class="category-count-badge">@grandChild.ProductCount</span>
                                                            </a>
                                                        }
                                                    </div>
                                                }
                                            }
                                        </div>
                                    }
                                }
                            }
                        </div>
                    </div>

                    <!-- Filters Form -->
                    @if (Model != null)
                    {
                        <form method="get" asp-controller="Product" asp-action="Index" id="filterForm">
                            <input type="hidden" name="categoryId" value="@currentCategoryId" />

                            @if (brands.Any())
                            {
                                <div class="filter-section">
                                    <h6 class="filter-title">Marka</h6>
                                    @foreach (var brandName in brands)
                                    {
                                        <div class="form-check mb-2">
                                            <input class="form-check-input" type="radio" name="brand" value="@brandName"
                                                id="brand_@brandName" @(string.Equals(selectedBrand, brandName, StringComparison.OrdinalIgnoreCase) ? "checked" : "")>
                                            <label class="form-check-label" for="brand_@brandName">@brandName</label>
                                        </div>
                                    }
                                </div>
                            }

                            <!-- Price Filter -->
                            <div class="filter-section">
                                <h6 class="filter-title">Fiyat Aralığı</h6>
                                <div class="row g-2 mb-3">
                                    <div class="col-6">
                                        <input type="number" name="minPrice" class="form-control form-control-sm"
                                            placeholder="Min ₺" value="@ViewBag.MinPrice">
                                    </div>
                                    <div class="col-6">
                                        <input type="number" name="maxPrice" class="form-control form-control-sm"
                                            placeholder="Max ₺" value="@ViewBag.MaxPrice">
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-sm price-filter-apply w-100">
                                    <i class="fas fa-check me-2"></i>Fiyat&#305; Uygula
                                </button>
                            </div>


                            <!-- Dynamic Filters -->
                            @if (currentCategoryAttributes != null && currentCategoryAttributes.Any())
                            {
                                @foreach (var attr in currentCategoryAttributes)
                                {
                                    <div class="filter-section">
                                        <h6 class="filter-title">@attr.DisplayName</h6>
                                        @if (attr.Options != null && attr.Options.Any())
                                        {
                                            @foreach (var option in attr.Options)
                                            {
                                                <div class="form-check mb-2">
                                                    <input class="form-check-input" type="checkbox" name="specs[@attr.Name]" value="@option"
                                                        id="@(attr.Name)_@option" @(selectedSpecs.ContainsKey(attr.Name) &&
                                selectedSpecs[attr.Name].Contains(option) ? "checked" : "")>
                                                    <label class="form-check-label" for="@(attr.Name)_@option">
                                                        @option
                                                    </label>
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                            }

                            <div class="d-grid gap-2">
                                @if (selectedSpecs.Any() || ViewBag.MinPrice != null || ViewBag.MaxPrice != null || !string.IsNullOrWhiteSpace(selectedBrand))
                                {
                                    @if (!string.IsNullOrWhiteSpace(currentCategoryId))
                                    {
                                        <a asp-controller="Product" asp-action="Index" asp-route-categoryId="@currentCategoryId"
                                            class="btn btn-outline-secondary">
                                            <i class="fas fa-times me-2"></i>Temizle
                                        </a>
                                    }
                                    else
                                    {
                                        <a href="/product" class="btn btn-outline-secondary">
                                            <i class="fas fa-times me-2"></i>Temizle
                                        </a>
                                    }
                                }
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>

        <!-- Products -->
        <div class="col-lg-10">
            <!-- Header -->
            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                <div>
                    <h1 class="h3 fw-bold mb-1">@ViewBag.CurrentCategoryName</h1>
                    <p class="text-muted mb-0">@(Model?.Count ?? 0) ürün bulundu</p>
                </div>

                <div class="d-flex gap-2 align-items-center">
                    <!-- Mobile Filter Button -->
                    <button class="btn btn-outline-dark d-lg-none" onclick="toggleFilterSidebar()" type="button">
                        <i class="fas fa-filter me-2"></i>Filtreleme
                    </button>
                    
                    <!-- Sort Dropdown -->
                    <div class="dropdown">
                        <button class="btn btn-outline-dark dropdown-toggle" type="button" id="sortDropdown" data-bs-toggle="dropdown">
                            <i class="fas fa-sort me-2"></i>Sıralama
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" href="@Url.Action("Index", "Product", new { 
                                    categoryId = currentCategoryId, 
                                    sortBy = "price_asc",
                                    minPrice = ViewBag.MinPrice,
                                    maxPrice = ViewBag.MaxPrice
                                })">
                                    <i class="fas fa-arrow-up me-2"></i>Fiyat: Düşük-Yüksek
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="@Url.Action("Index", "Product", new { 
                                    categoryId = currentCategoryId, 
                                    sortBy = "price_desc",
                                    minPrice = ViewBag.MinPrice,
                                    maxPrice = ViewBag.MaxPrice
                                })">
                                    <i class="fas fa-arrow-down me-2"></i>Fiyat: Yüksek-Düşük
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item" href="@Url.Action("Index", "Product", new { 
                                    categoryId = currentCategoryId, 
                                    sortBy = "name_asc",
                                    minPrice = ViewBag.MinPrice,
                                    maxPrice = ViewBag.MaxPrice
                                })">
                                    <i class="fas fa-sort-alpha-down me-2"></i>İsim: A-Z
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Product Grid -->
            <div class="row row-cols-2 row-cols-md-3 row-cols-xl-5 g-3">
                @if (Model != null && Model.Any())
                {
                    @foreach (var product in Model)
                    {
                        <div class="col">
                            @{
                                ViewBag.ShowFeaturedBadge = false;
                            }
                            @await Html.PartialAsync("_ProductCard", product)
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5">
                        <div class="p-5 bg-light rounded-3">
                            <i class="fas fa-search fa-3x text-muted mb-3"></i>
                            <h5 class="fw-bold mb-2">Ürün Bulunamadı</h5>
                            <p class="text-muted">Aradığınız kriterlere uygun ürün bulunmamaktadır.</p>
                            <a href="/product" class="btn btn-primary mt-3">
                                Tüm Ürünleri Gör
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>


<!-- Mobile Filter Bottom Sheet -->
<div id="mobileFilterSidebar">
    <div class="sidebar-header">
        <div class="sidebar-handle"></div>
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold">
                <i class="fas fa-filter me-2 text-primary"></i>Filtreler
            </h5>
            <button class="btn btn-sm btn-light rounded-circle" onclick="toggleFilterSidebar()" type="button" style="width: 36px; height: 36px;">
                <i class="fas fa-times"></i>
            </button>
        </div>
    </div>
    <div class="mobile-sidebar-content">
        <!-- Filters Form -->
        @if (Model != null)
        {
            <form method="get" asp-controller="Product" asp-action="Index" id="mobileFilterForm">
                <input type="hidden" name="categoryId" value="@currentCategoryId" />

                @if (brands.Any())
                {
                    <div class="filter-section">
                        <h6 class="filter-title">Marka</h6>
                        @foreach (var brandName in brands)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="brand" value="@brandName"
                                    id="mobile_brand_@brandName" @(string.Equals(selectedBrand, brandName, StringComparison.OrdinalIgnoreCase) ? "checked" : "")>
                                <label class="form-check-label" for="mobile_brand_@brandName">@brandName</label>
                            </div>
                        }
                    </div>
                }

                <!-- Price Filter -->
                <div class="filter-section">
                    <h6 class="filter-title">Fiyat Aralığı</h6>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <input type="number" name="minPrice" class="form-control"
                                placeholder="Min ₺" value="@ViewBag.MinPrice">
                        </div>
                        <div class="col-6">
                            <input type="number" name="maxPrice" class="form-control"
                                placeholder="Max ₺" value="@ViewBag.MaxPrice">
                        </div>
                    </div>
                    <button type="submit" class="btn price-filter-apply w-100">
                        <i class="fas fa-check me-2"></i>Fiyat&#305; Uygula
                    </button>
                </div>


                <!-- Dynamic Filters -->
                @if (currentCategoryAttributes != null && currentCategoryAttributes.Any())
                {
                    @foreach (var attr in currentCategoryAttributes)
                    {
                        <div class="filter-section">
                            <h6 class="filter-title">@attr.DisplayName</h6>
                            @if (attr.Options != null && attr.Options.Any())
                            {
                                @foreach (var option in attr.Options)
                                {
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" name="specs[@attr.Name]" value="@option"
                                            id="mobile_@(attr.Name)_@option" @(selectedSpecs.ContainsKey(attr.Name) &&
                                selectedSpecs[attr.Name].Contains(option) ? "checked" : "")>
                                        <label class="form-check-label" for="mobile_@(attr.Name)_@option">
                                            @option
                                        </label>
                                    </div>
                                }
                            }
                        </div>
                    }
                }

                <div class="d-grid gap-2 sticky-bottom bg-white pt-3 pb-2" style="margin: 0 -1.5rem; padding-left: 1.5rem !important; padding-right: 1.5rem !important; border-top: 1px solid #eee;">
                    @if (selectedSpecs.Any() || ViewBag.MinPrice != null || ViewBag.MaxPrice != null || !string.IsNullOrWhiteSpace(selectedBrand))
                    {
                        @if (!string.IsNullOrWhiteSpace(currentCategoryId))
                        {
                            <a asp-controller="Product" asp-action="Index" asp-route-categoryId="@currentCategoryId"
                                class="btn btn-outline-secondary">
                                <i class="fas fa-times me-2"></i>Temizle
                            </a>
                        }
                        else
                        {
                            <a href="/product" class="btn btn-outline-secondary">
                                <i class="fas fa-times me-2"></i>Temizle
                            </a>
                        }
                    }
                </div>
            </form>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-filter fa-3x text-muted mb-3"></i>
                <p class="text-muted mb-0">Bir kategori seçtiğinizde filtreler burada görünecek</p>
            </div>
        }
    </div>
</div>

<!-- Sidebar Overlay -->
<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebars()"></div>

<script>
    function bindAutoFilterForm(formId) {
        const form = document.getElementById(formId);
        if (!form) return;

        let filterTimer;
        const submitFilters = (delay = 0) => {
            clearTimeout(filterTimer);
            filterTimer = setTimeout(() => {
                form.querySelectorAll('input[type="hidden"]').forEach(input => {
                    input.disabled = input.value.trim() === '';
                });
                form.requestSubmit();
            }, delay);
        };

        form.querySelectorAll('input[type="radio"], input[type="checkbox"], select').forEach(input => {
            input.addEventListener('change', () => submitFilters());
        });

        form.querySelectorAll('input[type="number"]').forEach(input => {
            input.addEventListener('keydown', event => {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    submitFilters();
                }
            });
        });
    }

    document.addEventListener('DOMContentLoaded', function() {
        bindAutoFilterForm('filterForm');
        bindAutoFilterForm('mobileFilterForm');
    });

    function toggleFilterSidebar() {
        const sidebar = document.getElementById('mobileFilterSidebar');
        const overlay = document.getElementById('sidebarOverlay');
        
        sidebar.classList.toggle('show');
        overlay.classList.toggle('show');
        
        if (sidebar.classList.contains('show')) {
            document.body.style.overflow = 'hidden';
        } else {
            document.body.style.overflow = '';
        }
    }

    function closeSidebars() {
        document.getElementById('mobileFilterSidebar').classList.remove('show');
        document.getElementById('sidebarOverlay').classList.remove('show');
        document.body.style.overflow = '';
    }

    // Close sidebar on swipe down (touch devices)
    let touchStartY = 0;
    let touchEndY = 0;

    const filterSidebar = document.getElementById('mobileFilterSidebar');
    if (filterSidebar) {
        filterSidebar.addEventListener('touchstart', function(e) {
            touchStartY = e.changedTouches[0].screenY;
        }, false);

        filterSidebar.addEventListener('touchend', function(e) {
            touchEndY = e.changedTouches[0].screenY;
            if (touchEndY - touchStartY > 100) {
                closeSidebars();
            }
        }, false);
    }

    // Close sidebar on escape key
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            closeSidebars();
        }
    });

    // Auto-expand active category accordion
    document.addEventListener('DOMContentLoaded', function() {
        const activeLinks = document.querySelectorAll('.category-child-link.active');
        activeLinks.forEach(link => {
            const accordionCollapse = link.closest('.accordion-collapse');
            if (accordionCollapse) {
                accordionCollapse.classList.add('show');
                const accordionButton = document.querySelector(`[data-bs-target="#${accordionCollapse.id}"]`);
                if (accordionButton) {
                    accordionButton.classList.remove('collapsed');
                }
            }
        });
    });
</script>
