@model GameGaraj.WebUI.Models.Products.ProductViewModel
@{
    ViewData["Title"] = Model.Name;
}

<style>
    :root {
        --primary: #ff6000;
        --primary-hover: #e55500;
        --primary-light: #fff5f0;
        --dark-blue: #232f3e;
        --success: #00a365;
        --text-main: #333333;
        --text-muted: #666666;
        --border-color: #e2e8f0;
        --bg-light: #f8fafc;
        --card-shadow: 0 4px 20px rgba(0, 0, 0, 0.05), 0 1px 3px rgba(0, 0, 0, 0.02);
        --transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Overall Page Styling */
    .product-page {
        background: var(--bg-light);
        min-height: 100vh;
        padding-bottom: 3rem;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        color: var(--text-main);
        overflow-x: hidden;
    }

    /* Breadcrumb */
    .breadcrumb-section {
        background: white;
        padding: 0.85rem 0;
        border-bottom: 1px solid var(--border-color);
        font-size: 0.85rem;
    }

    .breadcrumb-section .container {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        row-gap: 0.25rem;
    }

    .breadcrumb-section a {
        color: var(--text-muted);
        text-decoration: none;
        transition: var(--transition);
    }

    .breadcrumb-section a:hover {
        color: var(--primary);
    }

    .breadcrumb-section .separator {
        color: #cbd5e1;
        margin: 0 0.5rem;
    }

    /* Main Box */
    .product-main {
        background: white;
        border-radius: 12px;
        margin-top: 1.5rem;
        padding: 2rem;
        border: 1px solid var(--border-color);
        box-shadow: var(--card-shadow);
    }

    /* Image Gallery */
    .image-gallery {
        position: sticky;
        top: 20px;
    }

    .main-image-wrapper {
        position: relative;
        border: 1px solid var(--border-color);
        border-radius: 12px;
        overflow: hidden;
        background: white;
        margin-bottom: 1rem;
        cursor: zoom-in;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: var(--transition);
    }

    .main-image-wrapper img {
        width: 100%;
        height: 380px;
        object-fit: contain;
        transition: transform 0.4s ease;
        padding: 1rem;
    }

    .main-image-wrapper:hover img {
        transform: scale(1.03);
    }

    .image-nav-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 40px;
        height: 40px;
        border-radius: 50%;
        border: 1px solid var(--border-color);
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(4px);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10;
        color: var(--text-main);
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        transition: var(--transition);
    }

    .image-nav-btn:hover {
        background: white;
        border-color: var(--primary);
        color: var(--primary);
        box-shadow: 0 4px 12px rgba(255, 96, 0, 0.15);
        transform: translateY(-50%) scale(1.05);
    }

    .image-nav-btn.prev {
        left: 12px;
    }

    .image-nav-btn.next {
        right: 12px;
    }

    .thumbnail-row {
        display: flex;
        gap: 0.75rem;
        overflow-x: auto;
        padding-bottom: 0.5rem;
        scrollbar-width: thin;
    }

    .thumbnail-row::-webkit-scrollbar {
        height: 4px;
    }

    .thumbnail-row::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 2px;
    }

    .thumbnail-item {
        flex-shrink: 0;
        width: 70px;
        height: 70px;
        border: 2px solid var(--border-color);
        border-radius: 8px;
        overflow: hidden;
        cursor: pointer;
        padding: 4px;
        background: white;
        transition: var(--transition);
    }

    .thumbnail-item img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .thumbnail-item:hover,
    .thumbnail-item.active {
        border-color: var(--primary);
        box-shadow: 0 2px 8px rgba(255, 96, 0, 0.1);
    }

    /* Product Info Section */
    .product-info-section {
        padding-left: 1.5rem;
    }

    .product-brand {
        color: var(--primary);
        font-weight: 700;
        font-size: 0.95rem;
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: inline-block;
        margin-bottom: 0.25rem;
    }

    .product-brand:hover {
        color: var(--primary-hover);
        text-decoration: underline;
    }

    .product-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--dark-blue);
        line-height: 1.4;
        margin-bottom: 0.75rem;
    }

    .product-rating {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1.25rem;
        font-size: 0.9rem;
    }

    .stars {
        color: #ffc107;
    }

    .rating-count {
        color: #0066cc;
        text-decoration: none;
        font-weight: 500;
    }

    .rating-count:hover {
        text-decoration: underline;
    }

    .seller-info {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.9rem;
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border-color);
    }

    .seller-badge {
        background: var(--success);
        color: white;
        padding: 0.2rem 0.5rem;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 700;
    }

    /* Price Box */
    .price-section {
        background: var(--bg-light);
        padding: 1.25rem;
        border-radius: 12px;
        border: 1px solid var(--border-color);
        margin-bottom: 1.5rem;
    }

    .main-price {
        font-size: 2.2rem;
        font-weight: 800;
        color: var(--dark-blue);
        display: flex;
        align-items: baseline;
        gap: 0.25rem;
    }

    .main-price .currency {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text-muted);
    }

    .installment-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-top: 0.75rem;
        padding-top: 0.75rem;
        border-top: 1px dashed var(--border-color);
        font-size: 0.88rem;
        flex-wrap: wrap;
    }

    .installment-info i {
        color: var(--primary);
    }

    .installment-badge {
        background: var(--primary);
        color: white;
        padding: 0.25rem 0.6rem;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 700;
    }

    /* Attribute Variants */
    .variant-section {
        margin: 1.5rem 0;
        padding: 1.25rem 0;
        border-top: 1px solid var(--border-color);
        border-bottom: 1px solid var(--border-color);
    }

    .variant-label {
        font-size: 0.9rem;
        color: var(--text-muted);
        margin-bottom: 0.5rem;
    }

    .variant-label strong {
        color: var(--dark-blue);
        font-weight: 600;
    }

    .variant-options {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-top: 0.5rem;
    }

    .variant-btn {
        padding: 0.55rem 1.25rem;
        border: 2px solid var(--border-color);
        border-radius: 8px;
        background: white;
        font-size: 0.88rem;
        font-weight: 500;
        cursor: pointer;
        transition: var(--transition);
        color: var(--text-main);
    }

    .variant-btn:hover {
        border-color: var(--primary);
        color: var(--primary);
    }

    .variant-btn.active {
        border-color: var(--primary);
        background: var(--primary-light);
        color: var(--primary);
        font-weight: 700;
        box-shadow: 0 2px 8px rgba(255, 96, 0, 0.08);
    }

    /* Add To Cart & Actions */
    .cart-section {
        margin-top: 1.5rem;
    }

    .add-to-cart-btn {
        width: 100%;
        padding: 1.1rem;
        background: var(--primary);
        border: none;
        border-radius: 8px;
        color: white;
        font-size: 1.1rem;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        box-shadow: 0 4px 14px rgba(255, 96, 0, 0.2);
        transition: var(--transition);
    }

    .add-to-cart-btn:hover {
        background: var(--primary-hover);
        box-shadow: 0 6px 20px rgba(255, 96, 0, 0.3);
        transform: translateY(-1px);
    }

    .add-to-cart-btn:active {
        transform: translateY(1px);
    }

    .add-to-cart-btn:disabled {
        background: #cbd5e1;
        box-shadow: none;
        cursor: not-allowed;
    }

    .add-to-cart-btn.in-cart {
        background: var(--success);
        box-shadow: 0 4px 14px rgba(0, 163, 101, 0.2);
    }

    .add-to-cart-btn.in-cart:hover {
        background: #008f58;
        box-shadow: 0 6px 20px rgba(0, 163, 101, 0.3);
    }

    .action-buttons {
        display: flex;
        gap: 0.75rem;
        margin-top: 1rem;
        flex-wrap: wrap;
    }

    .action-btn {
        flex: 1;
        min-width: 140px;
        padding: 0.85rem;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        background: white;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--text-muted);
        transition: var(--transition);
    }

    .action-btn:hover {
        border-color: var(--primary);
        color: var(--primary);
        background: var(--bg-light);
    }

    .action-btn.active {
        color: #e74c3c;
        border-color: #fca5a5;
        background: #fef2f2;
    }

    .action-btn.active i {
        color: #e74c3c;
    }

    /* Delivery Details */
    .delivery-section {
        margin-top: 1.5rem;
        padding-top: 1.25rem;
        border-top: 1px solid var(--border-color);
    }

    .delivery-title {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--dark-blue);
        margin-bottom: 0.75rem;
    }

    .delivery-option {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        padding: 0.85rem;
        background: var(--bg-light);
        border-radius: 8px;
        margin-bottom: 0.5rem;
        border: 1px solid var(--border-color);
    }

    .delivery-icon {
        color: var(--success);
        font-size: 1.35rem;
    }

    .delivery-text {
        font-size: 0.88rem;
        line-height: 1.4;
    }

    .delivery-text strong {
        color: var(--success);
        font-weight: 600;
    }

    /* Right Sidebar */
    .sidebar-section {
        padding-left: 1rem;
    }

    .sidebar-card {
        background: white;
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.25rem;
        margin-bottom: 1.25rem;
        box-shadow: var(--card-shadow);
    }

    .sidebar-title {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--dark-blue);
        margin-bottom: 0.85rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .campaign-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 0;
        font-size: 0.88rem;
        border-bottom: 1px solid var(--bg-light);
    }

    .campaign-item:last-child {
        border-bottom: none;
    }

    .campaign-icon {
        color: var(--primary);
    }

    /* Premium Box Design */
    .premium-box {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        color: white;
        border-radius: 12px;
        padding: 1.25rem;
        margin-bottom: 1.25rem;
        box-shadow: 0 4px 14px rgba(15, 23, 42, 0.15);
        border: 1px solid #334155;
    }

    .premium-title {
        color: var(--primary);
        font-weight: 800;
        font-size: 0.95rem;
        margin-bottom: 0.5rem;
        letter-spacing: 1px;
    }

    .premium-text {
        font-size: 0.85rem;
        color: #cbd5e1;
        line-height: 1.5;
    }

    /* Other Sellers */
    .seller-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.85rem;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        margin-bottom: 0.5rem;
        transition: var(--transition);
    }

    .seller-card:hover {
        border-color: var(--primary);
        background: var(--bg-light);
    }

    .seller-name {
        font-size: 0.88rem;
        color: #0066cc;
        font-weight: 600;
        text-decoration: none;
    }

    .seller-price {
        font-weight: 700;
        color: var(--dark-blue);
    }

    .seller-go-btn {
        padding: 0.45rem 0.85rem;
        border: 1px solid var(--border-color);
        border-radius: 6px;
        background: white;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition);
    }

    .seller-go-btn:hover {
        border-color: var(--primary);
        color: var(--primary);
        background: var(--primary-light);
    }

    /* Tabs Component Styles */
    .tabs-section {
        background: white;
        border-radius: 12px;
        margin-top: 1.5rem;
        overflow: hidden;
        border: 1px solid var(--border-color);
        box-shadow: var(--card-shadow);
    }

    .tab-nav {
        display: flex;
        border-bottom: 1px solid var(--border-color);
        background: var(--bg-light);
        overflow-x: auto;
        scrollbar-width: none;
    }

    .tab-nav::-webkit-scrollbar {
        display: none;
    }

    .tab-btn {
        padding: 1.1rem 1.75rem;
        background: none;
        border: none;
        border-bottom: 3px solid transparent;
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--text-muted);
        cursor: pointer;
        white-space: nowrap;
        transition: var(--transition);
    }

    .tab-btn:hover {
        color: var(--primary);
        background: rgba(255, 96, 0, 0.02);
    }

    .tab-btn.active {
        color: var(--primary);
        border-bottom-color: var(--primary);
        background: white;
    }

    .tab-content {
        padding: 2rem;
    }

    .tab-pane {
        display: none;
        animation: fadeIn 0.3s ease-in-out;
    }

    .tab-pane.active {
        display: block;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(4px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Specs Tab Design */
    .specs-header {
        font-size: 1.2rem;
        font-weight: 700;
        margin-bottom: 1.25rem;
        padding-bottom: 0.75rem;
        border-bottom: 2px solid var(--primary);
        display: inline-block;
        color: var(--dark-blue);
    }

    .specs-table {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0 1.5rem;
    }

    .spec-row {
        display: flex;
        justify-content: space-between;
        padding: 0.85rem 1rem;
        border-bottom: 1px solid var(--border-color);
    }

    .spec-row:nth-child(even) {
        background: var(--bg-light);
    }

    .spec-label {
        color: var(--text-muted);
        font-size: 0.88rem;
    }

    .spec-value {
        color: var(--text-main);
        font-size: 0.88rem;
        font-weight: 600;
        text-align: right;
    }

    /* Info Icons Grid */
    .info-icons {
        display: flex;
        gap: 1.5rem;
        padding: 1.25rem;
        background: var(--bg-light);
        border-radius: 12px;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        border: 1px solid var(--border-color);
    }

    .info-icon-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 0.5rem;
        flex: 1;
        min-width: 100px;
    }

    .info-icon-item i {
        font-size: 1.6rem;
        color: var(--primary);
    }

    .info-icon-item span {
        font-size: 0.78rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .info-icon-item strong {
        font-size: 0.9rem;
        color: var(--dark-blue);
        font-weight: 700;
    }

    /* Responsive Breakpoints */
    @@media (max-width: 1199px) {
        .product-main {
            padding: 1.5rem;
        }
    }

    @@media (max-width: 991px) {
        .product-info-section {
            padding-left: 0;
            margin-top: 2rem;
        }

        .sidebar-section {
            padding-left: 0;
            margin-top: 2rem;
        }

        .specs-table {
            grid-template-columns: 1fr;
            gap: 0;
        }
    }

    @@media (max-width: 575px) {
        .product-main {
            padding: 1rem;
            margin-top: 1rem;
            border-radius: 8px;
        }

        .main-image-wrapper img {
            height: 280px;
        }

        .main-price {
            font-size: 1.75rem;
        }

        .tab-btn {
            padding: 0.85rem 1rem;
            font-size: 0.85rem;
        }

        .info-icons {
            gap: 1rem;
            padding: 1rem;
        }

        .action-buttons {
            flex-direction: column;
        }

        .action-btn {
            width: 100%;
        }
    }

    /* Fullscreen Modal Styling */
    .gallery-modal .modal-content {
        background: rgba(15, 23, 42, 0.95);
        backdrop-filter: blur(8px);
        border: none;
    }

    .gallery-modal .modal-body {
        padding: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        position: relative;
    }

    .modal-image-container {
        width: 100%;
        height: 85vh;
        background: white;
        border-radius: 16px;
        padding: 2rem;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: space-between;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
    }

    .modal-main-image {
        flex-grow: 1;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        position: relative;
    }

    .modal-main-image img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
    }

    .modal-thumbnails {
        width: 120px;
        height: 100%;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding-left: 1.5rem;
        border-left: 1px solid var(--border-color);
    }

    .modal-thumbnails::-webkit-scrollbar {
        width: 4px;
    }

    .modal-thumbnails::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 2px;
    }

    .modal-thumb-item {
        width: 100%;
        padding-top: 100%;
        position: relative;
        border: 2px solid var(--border-color);
        border-radius: 8px;
        cursor: pointer;
        overflow: hidden;
        transition: var(--transition);
        background: white;
    }

    .modal-thumb-item img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: contain;
        padding: 4px;
    }

    .modal-thumb-item:hover,
    .modal-thumb-item.active {
        border-color: var(--primary);
        box-shadow: 0 4px 12px rgba(255, 96, 0, 0.15);
    }

    .modal-close-btn {
        background: none;
        border: none;
        color: white;
        font-size: 2.2rem;
        cursor: pointer;
        opacity: 0.8;
        transition: var(--transition);
    }

    .modal-close-btn:hover {
        opacity: 1;
        color: var(--primary);
        transform: rotate(90deg);
    }

    .modal-title-bar {
        color: white;
        font-size: 1.35rem;
        font-weight: 700;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>

<!-- Breadcrumb -->
<div class="breadcrumb-section">
    <div class="container">
        <a asp-controller="Home" asp-action="Index">Ana Sayfa</a>
        <span class="separator">&gt;</span>
        @if (!string.IsNullOrEmpty(Model.CategoryName))
        {
            <a asp-controller="Product" asp-action="Index" asp-route-categoryId="@Model.CategoryId">@Model.CategoryName</a>
            <span class="separator">&gt;</span>
        }
        <span class="text-muted">@Model.Name</span>
    </div>
</div>

<div class="product-page">
    <div class="container">
        <div class="product-main">
            <div class="row">
                <!-- Image Gallery -->
                <div class="col-lg-4">
                    <div class="image-gallery">
                        <div class="main-image-wrapper">
                            @if (Model.ImageUrls.Count > 1)
                            {
                                <button class="image-nav-btn prev" onclick="prevImage()">
                                    <i class="fas fa-chevron-left"></i>
                                </button>
                                <button class="image-nav-btn next" onclick="nextImage()">
                                    <i class="fas fa-chevron-right"></i>
                                </button>
                            }
                            <img src="@Model.FirstImageUrl" alt="@Model.Name" id="mainImage"
                                onclick="openGalleryModal()" title="Büyütmek için tıklayın">
                        </div>

                        @if (Model.ImageUrls.Count > 1)
                        {
                            <div class="thumbnail-row">
                                @for (int i = 0; i < Model.ImageUrls.Count; i++)
                                {
                                    <div class="thumbnail-item @(i == 0 ? "active" : "")"
                                        onclick="selectImage(@i, '@Model.ImageUrls[i]')">
                                        <img src="@Model.ImageUrls[i]" alt="@Model.Name - @(i + 1)">
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Product Info -->
                <div class="col-lg-5">
                    <div class="product-info-section">
                        <!-- Brand -->
                        @if (!string.IsNullOrEmpty(Model.CategoryName))
                        {
                            <a href="#" class="product-brand">@Model.CategoryName</a>
                        }

                        <!-- Title -->
                        <h1 class="product-title">@Model.Name</h1>

                        <!-- Rating -->
                        <div class="product-rating">
                            <span class="stars">
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star-half-alt"></i>
                            </span>
                            <span>4.5</span>
                            <a href="#reviews" class="rating-count">38 Değerlendirme</a>
                        </div>

                        <!-- Seller Info -->
                        <div class="seller-info">
                            <span>Satıcı:</span>
                            <a href="#" class="product-brand">GameGaraj</a>
                            <span class="seller-badge">9.8</span>
                        </div>

                        <!-- Price -->
                        <div class="price-section">
                            <div class="main-price">
                                @Model.Price.ToString("N2") <span class="currency">TL</span>
                            </div>
                            <div class="installment-info">
                                <i class="far fa-credit-card"></i>
                                <span>Peşin Fiyatına</span>
                                <span class="installment-badge">9 x @((Model.Price / 9).ToString("N2")) TL</span>
                            </div>
                        </div>

                        <!-- Variants (if specs exist) -->
                        @if (Model.Specs.Any())
                        {
                            <div class="variant-section">
                                @{
                                    var displayedSpecs = Model.Specs.Take(2).ToList();
                                }
                                @foreach (var spec in displayedSpecs)
                                {
                                    <div class="variant-label">
                                        <span>@spec.Key:</span> <strong>@spec.Value</strong>
                                    </div>
                                    <div class="variant-options">
                                        <button class="variant-btn active">@spec.Value</button>
                                    </div>
                                }
                            </div>
                        }

                        <!-- Add to Cart -->
                        <div class="cart-section">
                            @if (Model.AvailableStock > 0 || (Model.AvailableStock == 0 && Model.Stock > 0))
                            {
                                <form asp-controller="Basket" asp-action="AddItem" method="post" id="addToCartForm"
                                    class="js-add-to-cart-form">
                                    <input type="hidden" name="productId" value="@Model.Id" />
                                    <input type="hidden" name="quantity" value="1" id="quantityInput" />
                                    <button type="submit" class="add-to-cart-btn @(Model.IsInBasket ? "in-cart" : "")">
                                        <i class="fas @(Model.IsInBasket ? "fa-check" : "fa-shopping-cart")"></i>
                                        <span>@(Model.IsInBasket ? "Sepete Eklendi" : "Sepete Ekle")</span>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <button class="add-to-cart-btn" disabled>
                                    <i class="fas fa-ban"></i>
                                    Stokta Yok
                                </button>
                            }

                            <div class="action-buttons">
                                <button class="action-btn btn-favorite @(Model.IsFavorite ? "active" : "")"
                                    data-product-id="@Model.Id">
                                    <i class="@(Model.IsFavorite ? "fas" : "far") fa-heart"></i>
                                    Favorilere Ekle
                                </button>
                                <button class="action-btn" onclick="shareProduct()">
                                    <i class="fas fa-share-alt"></i>
                                    Paylaş
                                </button>
                            </div>
                        </div>

                        <!-- Delivery -->
                        <div class="delivery-section">
                            <div class="delivery-title">Teslimat Seçenekleri</div>
                            <div class="delivery-option">
                                <i class="fas fa-truck delivery-icon"></i>
                                <div class="delivery-text">
                                    <strong>Ücretsiz Kargo</strong> ile yarın kapınızda!
                                </div>
                            </div>
                            <div class="delivery-option">
                                <i class="fas fa-store delivery-icon"></i>
                                <div class="delivery-text">
                                    <strong>Mağazadan Teslim</strong> - Bugün teslim al
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Sidebar -->
                <div class="col-lg-3">
                    <div class="sidebar-section">
                        <!-- Campaigns -->
                        <div class="sidebar-card">
                            <div class="sidebar-title">
                                <i class="fas fa-tags campaign-icon"></i>
                                Kampanyalar
                            </div>
                            <div class="campaign-item">
                                <i class="fas fa-check-circle campaign-icon"></i>
                                <span>150 TL üzeri kargo bedava</span>
                            </div>
                            <div class="campaign-item">
                                <i class="fas fa-check-circle campaign-icon"></i>
                                <span>Kredi kartına 9 taksit</span>
                            </div>
                        </div>

                        <!-- Premium Box -->
                        <div class="premium-box">
                            <div class="premium-title">PREMIUM</div>
                            <div class="premium-text">
                                Premium üye ol, tüm avantajlardan faydalan!
                                <a href="#" style="color: #ff6000;">Hepsipara kazan &gt;</a>
                            </div>
                        </div>

                        <!-- Stock Info -->
                        <div class="sidebar-card">
                            <div class="sidebar-title">
                                <i class="fas fa-box campaign-icon"></i>
                                Stok Durumu
                            </div>
                            @if (Model.AvailableStock > 0 || (Model.AvailableStock == 0 && Model.Stock > 0))
                            {
                                <div style="color: #00a365; font-weight: 600;">
                                    <i class="fas fa-check-circle"></i> Stokta (@(Model.AvailableStock > 0 ?
                                Model.AvailableStock : Model.Stock) adet)
                                </div>
                                <div class="mt-2" style="font-size: 0.8rem; color: #666;">
                                    <i class="fas fa-clock"></i> 15 saat 34 dk içinde sipariş ver, bugün kargoda
                                </div>
                            }
                            else
                            {
                                <div style="color: #e74c3c; font-weight: 600;">
                                    <i class="fas fa-times-circle"></i> Stokta yok
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabs Section -->
        <div class="tabs-section">
            <!-- Tab Navigation -->
            <div class="tab-nav">
                <button class="tab-btn active" onclick="openTab(event, 'description')">Ürün Açıklaması</button>
                <button class="tab-btn" onclick="openTab(event, 'specs')">Teknik Özellikler</button>
                <button class="tab-btn" onclick="openTab(event, 'reviews')">Değerlendirmeler <span
                        style="background: #ff6000; color: white; padding: 0.1rem 0.4rem; border-radius: 10px; font-size: 0.7rem; margin-left: 0.25rem;">38</span></button>
                <button class="tab-btn" onclick="openTab(event, 'qa')">Soru & Cevap</button>
            </div>

            <!-- Tab Content -->
            <div class="tab-content">
                <!-- Description Tab -->
                <div id="description" class="tab-pane active">
                    <h2 class="specs-header">Ürün Açıklaması</h2>
                    <p style="font-size: 0.95rem; line-height: 1.8; color: #333;">
                        <strong>@Model.Name</strong>
                    </p>
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <p style="font-size: 0.95rem; line-height: 1.8; color: #666;">
                            @Model.Description
                        </p>
                    }
                </div>

                <!-- Specs Tab -->
                <div id="specs" class="tab-pane">
                    <h2 class="specs-header">Ürün Özellikleri</h2>

                    <!-- Info Icons -->
                    @if (Model.Specs.Any())
                    {
                        <div class="info-icons">
                            @foreach (var spec in Model.Specs.Take(5))
                            {
                                <div class="info-icon-item">
                                    <i class="fas fa-microchip"></i>
                                    <span>@spec.Key</span>
                                    <strong>@spec.Value</strong>
                                </div>
                            }
                        </div>

                        <div class="specs-table">
                            @foreach (var spec in Model.Specs)
                            {
                                <div class="spec-row">
                                    <span class="spec-label">@spec.Key</span>
                                    <span class="spec-value">@spec.Value</span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">Bu ürün için teknik özellik bilgisi bulunmamaktadır.</p>
                    }
                </div>

                <!-- Reviews Tab -->
                <div id="reviews" class="tab-pane">
                    <h2 class="specs-header">Değerlendirmeler</h2>
                    <div class="text-center py-5">
                        <i class="far fa-comment-dots fa-3x text-muted mb-3"></i>
                        <p class="text-muted">Henüz değerlendirme yapılmamış.</p>
                        <button class="btn btn-outline-primary">İlk Değerlendirmeyi Yaz</button>
                    </div>
                </div>

                <!-- Q&A Tab -->
                <div id="qa" class="tab-pane">
                    <h2 class="specs-header">Soru & Cevap</h2>
                    <div class="text-center py-5">
                        <i class="far fa-question-circle fa-3x text-muted mb-3"></i>
                        <p class="text-muted">Henüz soru sorulmamış.</p>
                        <button class="btn btn-outline-primary">Soru Sor</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Fullscreen Image Gallery Modal -->
<div class="modal fade gallery-modal" id="imageGalleryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen">
        <div class="modal-content">
            <!-- Click Event on modal-body to close if clicking outside container -->
            <div class="modal-body"
                onclick="if(event.target === this) { const m = bootstrap.Modal.getInstance(document.getElementById('imageGalleryModal')); if(m) m.hide(); }">
                <!-- Wrapper to position header and container together -->
                <div style="width: 80%; max-width: 1000px; display: flex; flex-direction: column; gap: 15px;">

                    <!-- Header Actions -->
                    <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                        <div class="modal-title-bar" title="@Model.Name">
                            @Model.Name
                        </div>
                        <button type="button" class="modal-close-btn" data-bs-dismiss="modal" aria-label="Close">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>

                    <!-- Inner White Box -->
                    <div class="modal-image-container" onclick="event.stopPropagation();">
                        <!-- Main Modal Image -->
                        <div class="modal-main-image">
                            @if (Model.ImageUrls.Count > 1)
                            {
                                <button class="image-nav-btn prev" onclick="prevModalImage()">
                                    <i class="fas fa-chevron-left"></i>
                                </button>
                                <button class="image-nav-btn next" onclick="nextModalImage()">
                                    <i class="fas fa-chevron-right"></i>
                                </button>
                            }
                            <img src="@Model.FirstImageUrl" id="modalMainImage" alt="@Model.Name">
                        </div>

                        <!-- Modal Thumbnails -->
                        @if (Model.ImageUrls.Count > 1)
                        {
                            <div class="modal-thumbnails">
                                @for (int i = 0; i < Model.ImageUrls.Count; i++)
                                {
                                    <div class="modal-thumb-item @(i == 0 ? "active" : "")"
                                        onclick="selectModalImage(@i, '@Model.ImageUrls[i]')">
                                        <img src="@Model.ImageUrls[i]" alt="Thumbnail @(i + 1)">
                                    </div>
                                }
                            </div>
                        }
                    </div> <!-- modal-image-container -->
                </div> <!-- wrapper -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentImageIndex = 0;
        const images = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ImageUrls));

        function selectImage(index, src) {
            currentImageIndex = index;
            document.getElementById('mainImage').src = src;

            document.querySelectorAll('.thumbnail-item').forEach((item, i) => {
                item.classList.toggle('active', i === index);
            });
        }

        function prevImage() {
            if (images.length === 0) return;
            currentImageIndex = (currentImageIndex - 1 + images.length) % images.length;
            selectImage(currentImageIndex, images[currentImageIndex]);
        }

        function nextImage() {
            if (images.length === 0) return;
            currentImageIndex = (currentImageIndex + 1) % images.length;
            selectImage(currentImageIndex, images[currentImageIndex]);
        }

        // Tab functionality
        function openTab(evt, tabName) {
            document.querySelectorAll('.tab-pane').forEach(pane => {
                pane.classList.remove('active');
            });
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('active');
            });

            document.getElementById(tabName).classList.add('active');
            evt.currentTarget.classList.add('active');
        }

        // Share functionality
        function shareProduct() {
            if (navigator.share) {
                navigator.share({
                    title: '@Model.Name',
                    url: window.location.href
                });
            } else {
                navigator.clipboard.writeText(window.location.href);
                alert('Link kopyalandı!');
            }
        }
        // Modal Gallery functionality
        let modal;
        document.addEventListener("DOMContentLoaded", function () {
            // Initialize Bootstrap modal instance
            let modalEl = document.getElementById('imageGalleryModal');
            if (modalEl) {
                modal = new bootstrap.Modal(modalEl);

                // When modal is hidden, sync the main page image to the last viewed modal image
                modalEl.addEventListener('hidden.bs.modal', function () {
                    selectImage(currentImageIndex, images[currentImageIndex]);
                });
            }
        });

        function openGalleryModal() {
            if (modal) {
                // Sync modal with current index before opening
                selectModalImage(currentImageIndex, images[currentImageIndex]);
                modal.show();
            }
        }

        function selectModalImage(index, src) {
            currentImageIndex = index;
            document.getElementById('modalMainImage').src = src;

            document.querySelectorAll('.modal-thumb-item').forEach((item, i) => {
                item.classList.toggle('active', i === index);
            });
        }

        function prevModalImage() {
            if (images.length === 0) return;
            currentImageIndex = (currentImageIndex - 1 + images.length) % images.length;
            selectModalImage(currentImageIndex, images[currentImageIndex]);
        }

        function nextModalImage() {
            if (images.length === 0) return;
            currentImageIndex = (currentImageIndex + 1) % images.length;
            selectModalImage(currentImageIndex, images[currentImageIndex]);
        }

        // Keyboard arrow navigation
        document.addEventListener('keydown', function (e) {
            if (images && images.length > 1) {
                if (e.key === 'ArrowLeft') {
                    const modalEl = document.getElementById('imageGalleryModal');
                    if (modalEl && modalEl.classList.contains('show')) {
                        prevModalImage();
                    } else {
                        prevImage();
                    }
                } else if (e.key === 'ArrowRight') {
                    const modalEl = document.getElementById('imageGalleryModal');
                    if (modalEl && modalEl.classList.contains('show')) {
                        nextModalImage();
                    } else {
                        nextImage();
                    }
                }
            }
        });
    </script>
}
