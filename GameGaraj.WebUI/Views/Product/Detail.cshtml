@model GameGaraj.WebUI.Models.Products.ProductViewModel
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@inject GameGaraj.WebUI.Services.Abstract.ICampaignService CampaignService
@{
    ViewData["Title"] = Model.Name;
    var displayImageUrls = Model.DisplayImageUrls;
    var reviewSummary = ViewBag.Reviews as GameGaraj.WebUI.Models.Reviews.ReviewListViewModel ?? new GameGaraj.WebUI.Models.Reviews.ReviewListViewModel();
    var canReview = ViewBag.CanReview as GameGaraj.WebUI.Models.Reviews.CanReviewViewModel;
    var userReviewResponse = ViewBag.UserReview as GameGaraj.WebUI.Models.Reviews.UserReviewResponseViewModel;
    var userReview = userReviewResponse?.Review;

    static string ReviewStatusText(int status) => status switch
    {
        0 => "Incelemede",
        1 => "Onaylandi",
        2 => "Reddedildi",
        _ => "Bilinmiyor"
    };

    static string ReviewStatusClass(int status) => status switch
    {
        0 => "bg-warning text-dark",
        1 => "bg-success",
        2 => "bg-danger",
        _ => "bg-secondary"
    };

    var httpContext = HttpContextAccessor.HttpContext;
    List<GameGaraj.WebUI.Models.Campaigns.CampaignRuleViewModel> activeRules = null;
    if (httpContext != null)
    {
        if (httpContext.Items.TryGetValue("ActiveCampaignRules", out var cachedRules))
        {
            activeRules = cachedRules as List<GameGaraj.WebUI.Models.Campaigns.CampaignRuleViewModel>;
        }
        else
        {
            try
            {
                var allRules = await CampaignService.GetAllRulesAsync();
                activeRules = allRules.Where(r => r.IsActive).ToList();
                httpContext.Items["ActiveCampaignRules"] = activeRules;
            }
            catch
            {
                activeRules = new List<GameGaraj.WebUI.Models.Campaigns.CampaignRuleViewModel>();
            }
        }
    }

    bool CampaignAppliesToProduct(GameGaraj.WebUI.Models.Campaigns.CampaignRuleViewModel rule)
    {
        if (!string.IsNullOrWhiteSpace(rule.ProductId))
        {
            return rule.ProductId.Equals(Model.Id, StringComparison.OrdinalIgnoreCase);
        }

        var hasCategory = !string.IsNullOrWhiteSpace(rule.CategoryId);
        var hasBrand = !string.IsNullOrWhiteSpace(rule.BrandName);

        if (!hasCategory && !hasBrand)
        {
            return false;
        }

        var categoryMatches = !hasCategory || rule.CategoryId!.Equals(Model.CategoryId, StringComparison.OrdinalIgnoreCase);
        var brandMatches = !hasBrand || (!string.IsNullOrWhiteSpace(Model.Brand) && rule.BrandName!.Equals(Model.Brand, StringComparison.OrdinalIgnoreCase));

        return categoryMatches && brandMatches;
    }

    // Find matching campaign for this product
    GameGaraj.WebUI.Models.Campaigns.CampaignRuleViewModel matchingCampaign = null;
    if (activeRules != null)
    {
        matchingCampaign = activeRules.FirstOrDefault(CampaignAppliesToProduct);
    }
}

<style>
    :root {
        --primary: #ff6000;
        --primary-hover: #e55500;
        --primary-light: #fff5f0;
        --dark-blue: #232f3e;
        --success: #00a365;
        --text-main: #333333;
        --text-muted: #666666;
        --border-color: #e2e8f0;
        --bg-light: #f8fafc;
        --card-shadow: 0 4px 20px rgba(0, 0, 0, 0.05), 0 1px 3px rgba(0, 0, 0, 0.02);
        --transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Overall Page Styling */
    .product-page {
        background: var(--bg-light);
        min-height: 100vh;
        padding-bottom: 3rem;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        color: var(--text-main);
        overflow-x: hidden;
    }

    /* Breadcrumb */
    .breadcrumb-section {
        background: white;
        padding: 0.85rem 0;
        border-bottom: 1px solid var(--border-color);
        font-size: 0.85rem;
    }

    .breadcrumb-section .container {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        row-gap: 0.25rem;
    }

    .breadcrumb-section a {
        color: var(--text-muted);
        text-decoration: none;
        transition: var(--transition);
    }

    .breadcrumb-section a:hover {
        color: var(--primary);
    }

    .breadcrumb-section .separator {
        color: #cbd5e1;
        margin: 0 0.5rem;
    }

    /* Main Box */
    .product-main {
        background: white;
        border-radius: 12px;
        margin-top: 1.5rem;
        padding: 2rem;
        border: 1px solid var(--border-color);
        box-shadow: var(--card-shadow);
    }

    /* Image Gallery */
    .image-gallery {
        position: sticky;
        top: 20px;
    }

    .main-image-wrapper {
        position: relative;
        border: 1px solid var(--border-color);
        border-radius: 12px;
        overflow: hidden;
        background: white;
        margin-bottom: 1rem;
        cursor: zoom-in;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: var(--transition);
    }

    .main-image-wrapper img {
        width: 100%;
        height: 380px;
        object-fit: contain;
        transition: transform 0.4s ease;
        padding: 1rem;
    }

    .main-image-wrapper:hover img {
        transform: scale(1.03);
    }

    .image-nav-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 40px;
        height: 40px;
        border-radius: 50%;
        border: 1px solid var(--border-color);
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(4px);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10;
        color: var(--text-main);
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        transition: var(--transition);
    }

    .image-nav-btn:hover {
        background: white;
        border-color: var(--primary);
        color: var(--primary);
        box-shadow: 0 4px 12px rgba(255, 96, 0, 0.15);
        transform: translateY(-50%) scale(1.05);
    }

    .image-nav-btn.prev {
        left: 12px;
    }

    .image-nav-btn.next {
        right: 12px;
    }

    .thumbnail-row {
        display: flex;
        gap: 0.75rem;
        overflow-x: auto;
        padding-bottom: 0.5rem;
        scrollbar-width: thin;
    }

    .thumbnail-row::-webkit-scrollbar {
        height: 4px;
    }

    .thumbnail-row::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 2px;
    }

    .thumbnail-item {
        flex-shrink: 0;
        width: 70px;
        height: 70px;
        border: 2px solid var(--border-color);
        border-radius: 8px;
        overflow: hidden;
        cursor: pointer;
        padding: 4px;
        background: white;
        transition: var(--transition);
    }

    .thumbnail-item img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .thumbnail-item:hover,
    .thumbnail-item.active {
        border-color: var(--primary);
        box-shadow: 0 2px 8px rgba(255, 96, 0, 0.1);
    }

    /* Product Info Section */
    .product-info-section {
        padding-left: 1.5rem;
    }

    .product-brand {
        color: #f07400;
        font-weight: 800;
        font-size: 0.95rem;
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: inline-block;
        margin-bottom: 0.25rem;
    }

    .product-brand:hover {
        color: #d86400;
        text-decoration: underline;
    }

    .product-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--dark-blue);
        line-height: 1.4;
        margin-bottom: 0.75rem;
    }

    .product-rating {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1.25rem;
        font-size: 0.9rem;
    }

    .stars {
        color: #ffc107;
    }

    .rating-count {
        color: #0066cc;
        text-decoration: none;
        font-weight: 500;
    }

    .rating-count:hover {
        text-decoration: underline;
    }

    .seller-info {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.9rem;
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border-color);
    }

    .seller-badge {
        background: var(--success);
        color: white;
        padding: 0.2rem 0.5rem;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 700;
    }

    /* Price Box */
    .price-section {
        background: var(--bg-light);
        padding: 1.25rem;
        border-radius: 12px;
        border: 1px solid var(--border-color);
        margin-bottom: 1.5rem;
    }

    .main-price {
        font-size: 2.2rem;
        font-weight: 800;
        color: var(--dark-blue);
        display: flex;
        align-items: baseline;
        gap: 0.25rem;
    }

    .main-price .currency {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text-muted);
    }

    .installment-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-top: 0.75rem;
        padding-top: 0.75rem;
        border-top: 1px dashed var(--border-color);
        font-size: 0.88rem;
        flex-wrap: wrap;
    }

    .installment-info i {
        color: var(--primary);
    }

    .installment-badge {
        background: var(--primary);
        color: white;
        padding: 0.25rem 0.6rem;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 700;
    }

    /* Attribute Variants */
    .variant-section {
        margin: 1rem 0 1.5rem;
        padding: 1.1rem 0;
        border-top: 1px solid var(--border-color);
        border-bottom: 1px solid var(--border-color);
    }

    .variant-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.85rem 2rem;
    }

    .variant-group {
        min-width: 0;
        display: flex;
        align-items: baseline;
        gap: 0.35rem;
        font-size: 0.95rem;
        line-height: 1.45;
    }

    .variant-label {
        color: var(--text-muted);
    }

    .variant-value {
        color: var(--dark-blue);
        font-weight: 700;
    }

    .stock-strip {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin: 0.35rem 0 0;
        padding: 0.85rem 1rem;
        border: 1px solid #bbf7d0;
        border-radius: 8px;
        background: #f0fdf4;
        color: #008f58;
        font-size: 0.95rem;
        font-weight: 700;
    }

    .stock-strip.out-of-stock {
        border-color: #fecaca;
        background: #fef2f2;
        color: #dc2626;
    }

    .stock-strip-note {
        color: var(--text-muted);
        font-size: 0.82rem;
        font-weight: 500;
        text-align: right;
    }

    /* Add To Cart & Actions */
    .cart-section {
        margin-top: 1.5rem;
    }

    .cart-actions-row {
        display: flex;
        align-items: stretch;
        gap: 0.75rem;
    }

    .cart-actions-row form {
        flex: 1 1 auto;
        min-width: 0;
    }

    .cart-actions-row > .add-to-cart-btn {
        flex: 1 1 auto;
        min-width: 0;
    }

    .add-to-cart-btn {
        width: 100%;
        height: 60px;
        padding: 1.1rem;
        background: var(--primary);
        border: none;
        border-radius: 8px;
        color: white;
        font-size: 1.1rem;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        box-shadow: 0 4px 14px rgba(255, 96, 0, 0.2);
        transition: var(--transition);
    }

    .add-to-cart-btn:hover {
        background: var(--primary-hover);
        box-shadow: 0 6px 20px rgba(255, 96, 0, 0.3);
        transform: translateY(-1px);
    }

    .add-to-cart-btn:active {
        transform: translateY(1px);
    }

    .add-to-cart-btn:disabled {
        background: #cbd5e1;
        box-shadow: none;
        cursor: not-allowed;
    }

    .add-to-cart-btn.in-cart {
        background: var(--success);
        box-shadow: 0 4px 14px rgba(0, 163, 101, 0.2);
    }

    .add-to-cart-btn.in-cart:hover {
        background: #008f58;
        box-shadow: 0 6px 20px rgba(0, 163, 101, 0.3);
    }

    .action-buttons {
        display: flex;
        gap: 0.75rem;
        flex: 0 0 auto;
    }

    .cart-actions-row .btn-favorite {
        position: static !important;
        inset: auto !important;
        width: 60px;
        height: 60px;
        border-radius: 8px;
    }

    .action-btn {
        width: 60px;
        height: 60px;
        padding: 0;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        background: white;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.35rem;
        font-weight: 600;
        color: var(--text-muted);
        transition: var(--transition);
    }

    .action-btn:hover {
        border-color: var(--primary);
        color: var(--primary);
        background: var(--bg-light);
    }

    .action-btn.active {
        color: #e74c3c;
        border-color: #fca5a5;
        background: #fef2f2;
    }

    .action-btn.active i {
        color: #e74c3c;
    }

    /* Delivery Details */
    .delivery-section {
        margin-top: 1.5rem;
        padding-top: 1.25rem;
        border-top: 1px solid var(--border-color);
    }

    .sidebar-card .delivery-section {
        margin-top: 0;
        padding-top: 0;
        border-top: 0;
    }

    .delivery-title {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--dark-blue);
        margin-bottom: 0.75rem;
    }

    .delivery-option {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        padding: 0.85rem;
        background: var(--bg-light);
        border-radius: 8px;
        margin-bottom: 0.5rem;
        border: 1px solid var(--border-color);
    }

    .delivery-icon {
        color: var(--success);
        font-size: 1.35rem;
    }

    .delivery-text {
        font-size: 0.88rem;
        line-height: 1.4;
    }

    .delivery-text strong {
        color: var(--success);
        font-weight: 600;
    }

    /* Right Sidebar */
    .sidebar-section {
        padding-left: 1rem;
    }

    .sidebar-card {
        background: white;
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.25rem;
        margin-bottom: 1.25rem;
        box-shadow: var(--card-shadow);
    }

    .sidebar-title {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--dark-blue);
        margin-bottom: 0.85rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .campaign-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 0;
        font-size: 0.88rem;
        border-bottom: 1px solid var(--bg-light);
    }

    .campaign-item:last-child {
        border-bottom: none;
    }

    .campaign-icon {
        color: var(--primary);
    }

    /* Premium Box Design */
    .premium-box {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        color: white;
        border-radius: 12px;
        padding: 1.25rem;
        margin-bottom: 1.25rem;
        box-shadow: 0 4px 14px rgba(15, 23, 42, 0.15);
        border: 1px solid #334155;
    }

    .premium-title {
        color: var(--primary);
        font-weight: 800;
        font-size: 0.95rem;
        margin-bottom: 0.5rem;
        letter-spacing: 1px;
    }

    .premium-text {
        font-size: 0.85rem;
        color: #cbd5e1;
        line-height: 1.5;
    }

    /* Other Sellers */
    .seller-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.85rem;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        margin-bottom: 0.5rem;
        transition: var(--transition);
    }

    .seller-card:hover {
        border-color: var(--primary);
        background: var(--bg-light);
    }

    .seller-name {
        font-size: 0.88rem;
        color: #0066cc;
        font-weight: 600;
        text-decoration: none;
    }

    .seller-price {
        font-weight: 700;
        color: var(--dark-blue);
    }

    .seller-go-btn {
        padding: 0.45rem 0.85rem;
        border: 1px solid var(--border-color);
        border-radius: 6px;
        background: white;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition);
    }

    .seller-go-btn:hover {
        border-color: var(--primary);
        color: var(--primary);
        background: var(--primary-light);
    }

    /* Tabs Component Styles */
    .tabs-section {
        background: white;
        border-radius: 12px;
        margin-top: 1.5rem;
        overflow: hidden;
        border: 1px solid var(--border-color);
        box-shadow: var(--card-shadow);
    }

    .tab-nav {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        border-bottom: 1px solid var(--border-color);
        background: var(--bg-light);
    }

    .tab-nav::-webkit-scrollbar {
        display: none;
    }

    .tab-btn {
        width: 100%;
        min-width: 0;
        padding: 1.1rem 1rem;
        background: none;
        border: none;
        border-bottom: 3px solid transparent;
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--text-muted);
        cursor: pointer;
        white-space: normal;
        text-align: center;
        transition: var(--transition);
    }

    .tab-btn:hover {
        color: var(--primary);
        background: rgba(255, 96, 0, 0.02);
    }

    .tab-btn.active {
        color: var(--primary);
        border-bottom-color: var(--primary);
        background: white;
    }

    .tab-content {
        padding: 2rem;
    }

    .tab-pane {
        display: none;
        animation: fadeIn 0.3s ease-in-out;
    }

    .tab-pane.active {
        display: block;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(4px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Specs Tab Design */
    .specs-header {
        font-size: 1.2rem;
        font-weight: 700;
        margin-bottom: 1.25rem;
        padding-bottom: 0.75rem;
        border-bottom: 2px solid var(--primary);
        display: inline-block;
        color: var(--dark-blue);
    }

    .specs-table {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0 1.5rem;
    }

    .spec-row {
        display: flex;
        justify-content: space-between;
        padding: 0.85rem 1rem;
        border-bottom: 1px solid var(--border-color);
    }

    .spec-row:nth-child(even) {
        background: var(--bg-light);
    }

    .spec-label {
        color: var(--text-muted);
        font-size: 0.88rem;
    }

    .spec-value {
        color: var(--text-main);
        font-size: 0.88rem;
        font-weight: 600;
        text-align: right;
    }

    /* Info Icons Grid */
    .info-icons {
        display: flex;
        gap: 1.5rem;
        padding: 1.25rem;
        background: var(--bg-light);
        border-radius: 12px;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        border: 1px solid var(--border-color);
    }

    .info-icon-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 0.5rem;
        flex: 1;
        min-width: 100px;
    }

    .info-icon-item i {
        font-size: 1.6rem;
        color: var(--primary);
    }

    .info-icon-item span {
        font-size: 0.78rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .info-icon-item strong {
        font-size: 0.9rem;
        color: var(--dark-blue);
        font-weight: 700;
    }

    /* Responsive Breakpoints */
    @@media (max-width: 1199px) {
        .product-main {
            padding: 1.5rem;
        }
    }

    @@media (max-width: 991px) {
        .product-info-section {
            padding-left: 0;
            margin-top: 2rem;
        }

        .sidebar-section {
            padding-left: 0;
            margin-top: 2rem;
        }

        .specs-table {
            grid-template-columns: 1fr;
            gap: 0;
        }

        .tab-nav {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 575px) {
        .product-main {
            padding: 1rem;
            margin-top: 1rem;
            border-radius: 8px;
        }

        .main-image-wrapper img {
            height: 280px;
        }

        .main-price {
            font-size: 1.75rem;
        }

        .tab-btn {
            padding: 0.85rem 1rem;
            font-size: 0.85rem;
        }

        .variant-grid {
            grid-template-columns: 1fr;
            gap: 0.85rem;
        }

        .stock-strip {
            align-items: flex-start;
            flex-direction: column;
        }

        .stock-strip-note {
            text-align: left;
        }

        .info-icons {
            gap: 1rem;
            padding: 1rem;
        }

        .action-buttons {
            gap: 0.5rem;
        }

        .action-btn {
            width: 52px;
            height: 52px;
            font-size: 1.15rem;
        }

        .cart-actions-row .btn-favorite {
            width: 52px;
            height: 52px;
        }

        .add-to-cart-btn {
            height: 52px;
            font-size: 1rem;
        }
    }

    /* Gallery Modal */
    .modal-backdrop.show {
        opacity: 0.58 !important;
        background: #111827;
    }

    .gallery-modal.fade .modal-dialog,
    .gallery-modal.show .modal-dialog {
        transform: none;
    }

    .gallery-modal .modal-dialog {
        max-width: min(1180px, calc(100vw - 4rem));
        height: auto;
        margin: 1.5rem auto;
    }

    .gallery-modal .modal-content {
        min-height: min(760px, calc(100vh - 5rem));
        background: #ffffff;
        border: none;
        border-radius: 8px;
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.28);
        overflow: hidden;
    }

    .gallery-modal .modal-body {
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f8fafc;
        position: relative;
    }

    .gallery-shell {
        width: min(1120px, calc(100vw - 5rem));
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding: 0.85rem;
    }

    .gallery-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .modal-image-container {
        width: 100%;
        min-height: min(680px, calc(100vh - 10rem));
        background: #fff;
        display: flex;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        overflow: hidden;
    }

    .modal-main-image {
        flex-grow: 1;
        min-height: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        position: relative;
        min-width: 0;
        background: #fff;
    }

    .modal-main-image img {
        width: auto;
        height: auto;
        max-width: min(680px, 100%);
        max-height: min(500px, 64vh);
        object-fit: contain;
    }

    .modal-main-image img.is-portrait {
        max-width: min(500px, 56%);
        max-height: min(620px, 70vh);
    }

    .modal-main-image img.is-landscape {
        max-width: min(720px, 76%);
        max-height: min(460px, 56vh);
    }

    .modal-thumbnails {
        width: 164px;
        overflow-y: auto;
        display: grid;
        grid-template-columns: 1fr;
        align-content: start;
        gap: 10px;
        padding: 0.85rem;
        border-left: 1px solid #e5e7eb;
        background: #f8fafc;
    }

    .modal-thumbnails::-webkit-scrollbar {
        width: 4px;
    }

    .modal-thumbnails::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 2px;
    }

    .modal-thumb-item {
        width: 100%;
        aspect-ratio: 1 / 1;
        position: relative;
        border: 1px solid #d9dee7;
        border-radius: 8px;
        cursor: pointer;
        overflow: hidden;
        transition: border-color 0.12s ease, box-shadow 0.12s ease;
        background: white;
    }

    .modal-thumb-item img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        padding: 6px;
    }

    .modal-thumb-item:hover,
    .modal-thumb-item.active {
        border-color: var(--primary);
        box-shadow: 0 0 0 1px var(--primary);
    }

    .modal-close-btn {
        width: 42px;
        height: 42px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #f5f6f8;
        border: none;
        border-radius: 50%;
        color: #4b5563;
        font-size: 1.25rem;
        cursor: pointer;
        transition: background-color 0.12s ease, color 0.12s ease;
    }

    .modal-close-btn:hover {
        background: #eceff3;
        color: #111827;
    }

    @@media (max-width: 768px) {
        .gallery-modal .modal-dialog {
            max-width: calc(100vw - 1rem);
            margin: 0.5rem auto;
        }

        .gallery-shell {
            width: calc(100vw - 1rem);
            padding: 0.5rem;
        }

        .modal-image-container {
            flex-direction: column;
            min-height: calc(100vh - 9rem);
        }

        .modal-main-image {
            min-height: 0;
            padding: 1rem;
        }

        .modal-thumbnails {
            width: 100%;
            display: flex;
            flex-direction: row;
            gap: 10px;
            padding: 16px;
            border-left: 0;
            border-top: 1px solid #e5e7eb;
            overflow-x: auto;
            overflow-y: hidden;
        }

        .modal-thumb-item {
            width: 78px;
            min-width: 78px;
        }
    }
</style>

<!-- Breadcrumb -->
<div class="breadcrumb-section">
    <div class="container">
        <a asp-controller="Home" asp-action="Index">Ana Sayfa</a>
        <span class="separator">&gt;</span>
        @if (!string.IsNullOrEmpty(Model.CategoryName))
        {
            <a asp-controller="Product" asp-action="Index" asp-route-categoryId="@Model.CategoryId">@Model.CategoryName</a>
            <span class="separator">&gt;</span>
        }
        <span class="text-muted">@Model.Name</span>
    </div>
</div>

<div class="product-page">
    <div class="container">
        <div class="product-main">
            <div class="row">
                <!-- Image Gallery -->
                <div class="col-lg-4">
                    <div class="image-gallery">
                        <div class="main-image-wrapper">
                            @if (displayImageUrls.Count > 1)
                            {
                                <button class="image-nav-btn prev" onclick="prevImage()">
                                    <i class="fas fa-chevron-left"></i>
                                </button>
                                <button class="image-nav-btn next" onclick="nextImage()">
                                    <i class="fas fa-chevron-right"></i>
                                </button>
                            }
                            <img src="@Model.FirstImageUrl" alt="@Model.Name" id="mainImage"
                                onclick="openGalleryModal()" title="B&uuml;y&uuml;tmek i&ccedil;in t&#305;klay&#305;n"
                                onerror="this.onerror=null;this.src='@GameGaraj.WebUI.Models.Products.ProductViewModel.DefaultImageUrl';">
                        </div>

                        @if (displayImageUrls.Count > 1)
                        {
                            <div class="thumbnail-row">
                                @for (int i = 0; i < displayImageUrls.Count; i++)
                                {
                                    <div class="thumbnail-item @(i == 0 ? "active" : "")"
                                        onclick="selectImage(@i, '@displayImageUrls[i]')">
                                        <img src="@displayImageUrls[i]" alt="@Model.Name - @(i + 1)"
                                             onerror="this.onerror=null;this.src='@GameGaraj.WebUI.Models.Products.ProductViewModel.DefaultImageUrl';">
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Product Info -->
                <div class="col-lg-5">
                    <div class="product-info-section">
                        <!-- Brand -->
                        @if (!string.IsNullOrWhiteSpace(Model.Brand))
                        {
                            <a asp-controller="Product" asp-action="Index" asp-route-brand="@Model.Brand" class="product-brand">@Model.Brand</a>
                        }

                        <!-- Title -->
                        <h1 class="product-title">@Model.Name</h1>

                        <!-- Rating -->
                        @if (reviewSummary.TotalCount == 0)
                        {
                            <div class="product-rating">
                                <span class="text-muted small">Henüz değerlendirilmemiş</span>
                            </div>
                        }
                        else
                        {
                            <div class="product-rating">
                                <span class="stars">
                                    @for (var i = 1; i <= 5; i++)
                                    {
                                        <i class="@(i <= Math.Round(reviewSummary.AverageRating) ? "fas" : "far") fa-star"></i>
                                    }
                                </span>
                                <span>@reviewSummary.AverageRating.ToString("0.0")</span>
                                <a href="#reviews" class="rating-count">@reviewSummary.TotalCount Değerlendirme</a>
                            </div>
                        }


                        <!-- Price -->
                        <div class="price-section">
                            @if (matchingCampaign != null)
                            {
                                <div class="product-card-campaign" title="@matchingCampaign.Name">
                                    @matchingCampaign.Name
                                </div>
                            }
                            <div class="main-price" style="display: flex; flex-direction: column;">
                                @if (matchingCampaign != null && ((matchingCampaign.DiscountRate.HasValue && matchingCampaign.DiscountRate.Value > 0) || (matchingCampaign.FixedDiscount.HasValue && matchingCampaign.FixedDiscount.Value > 0)))
                                {
                                    decimal discountedPrice = Model.Price;
                                    if (matchingCampaign.DiscountRate.HasValue && matchingCampaign.DiscountRate.Value > 0)
                                    {
                                        var discountRate = matchingCampaign.DiscountRate.Value;
                                        discountedPrice = Model.Price - (Model.Price * (discountRate / 100m));
                                    }
                                    else if (matchingCampaign.FixedDiscount.HasValue && matchingCampaign.FixedDiscount.Value > 0)
                                    {
                                        discountedPrice = Model.Price - matchingCampaign.FixedDiscount.Value;
                                        if (discountedPrice < 0) discountedPrice = 0;
                                    }
                                    <div style="font-size: 1.1rem; color: #999; text-decoration: line-through; margin-bottom: -5px; font-weight: 600;">
                                        @Model.Price.ToString("N2") <span class="currency" style="font-size: 0.9rem;">TL</span>
                                    </div>
                                    <div class="text-success">
                                        @discountedPrice.ToString("N2") <span class="currency text-success">TL</span>
                                    </div>
                                }
                                else
                                {
                                    <div>
                                        @Model.Price.ToString("N2") <span class="currency">TL</span>
                                    </div>
                                }
                            </div>
                            <div class="installment-info">
                                <i class="far fa-credit-card"></i>
                                <span>Pe&#351;in Fiyat&#305;na</span>
                                <span class="installment-badge">9 x @((Model.Price / 9).ToString("N2")) TL</span>
                            </div>
                        </div>

                        @if (Model.AvailableStock > 0 || (Model.AvailableStock == 0 && Model.Stock > 0))
                        {
                            <div class="stock-strip">
                                <span>
                                    <i class="fas fa-check-circle"></i>
                                    Stokta (@(Model.AvailableStock > 0 ? Model.AvailableStock : Model.Stock) adet)
                                </span>
                                <span class="stock-strip-note">
                                    15 saat 34 dk i&ccedil;inde sipari&#351; ver, bug&uuml;n kargoda
                                </span>
                            </div>
                        }
                        else
                        {
                            <div class="stock-strip out-of-stock">
                                <span>
                                    <i class="fas fa-times-circle"></i>
                                    Stokta yok
                                </span>
                            </div>
                        }

                        <!-- Variants (if specs exist) -->
                        @if (Model.Specs.Any())
                        {
                            <div class="variant-section">
                                @{
                                    var displayedSpecs = Model.Specs.Take(2).ToList();
                                }
                                <div class="variant-grid">
                                    @foreach (var spec in displayedSpecs)
                                    {
                                        <div class="variant-group">
                                            <span class="variant-label">@spec.Key:</span>
                                            <span class="variant-value">@spec.Value</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <!-- Add to Cart -->
                        <div class="cart-section">
                            <div class="cart-actions-row">
                                @if (Model.AvailableStock > 0 || (Model.AvailableStock == 0 && Model.Stock > 0))
                                {
                                    <form asp-controller="Basket" asp-action="AddItem" method="post" id="addToCartForm"
                                        class="js-add-to-cart-form">
                                        <input type="hidden" name="productId" value="@Model.Id" />
                                        <input type="hidden" name="quantity" value="1" id="quantityInput" />
                                        <button type="submit" class="add-to-cart-btn @(Model.IsInBasket ? "in-cart" : "")"
                                            @(Model.IsInBasket ? "disabled" : "")>
                                            <i class="fas @(Model.IsInBasket ? "fa-check" : "fa-cart-plus")"></i>
                                            <span>@(Model.IsInBasket ? "Sepete Eklendi" : "Sepete Ekle")</span>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <button class="add-to-cart-btn" disabled>
                                        <i class="fas fa-ban"></i>
                                        Stokta Yok
                                    </button>
                                }

                                <div class="action-buttons">
                                    <button type="button" class="action-btn" aria-label="Kaydet" title="Kaydet">
                                        <i class="far fa-bookmark"></i>
                                    </button>
                                    <button type="button" class="action-btn btn-favorite @(Model.IsFavorite ? "active" : "")"
                                        data-product-id="@Model.Id" aria-label="Favorilere Ekle" title="Favorilere Ekle">
                                        <i class="@(Model.IsFavorite ? "fas" : "far") fa-heart"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Right Sidebar -->
                <div class="col-lg-3">
                    <div class="sidebar-section">
                        <!-- Campaigns -->
                        <div class="sidebar-card">
                            <div class="sidebar-title">
                                <i class="fas fa-tags campaign-icon"></i>
                                Kampanyalar
                            </div>
                            <div class="campaign-item">
                                <i class="fas fa-check-circle campaign-icon"></i>
                                <span>150 TL &uuml;zeri kargo bedava</span>
                            </div>
                            <div class="campaign-item">
                                <i class="fas fa-check-circle campaign-icon"></i>
                                <span>Kredi kart&#305;na 9 taksit</span>
                            </div>
                        </div>

                        <div class="sidebar-card">
                            <div class="sidebar-title">
                                <i class="fas fa-truck campaign-icon"></i>
                                Teslimat Se&ccedil;enekleri
                            </div>
                            <div class="delivery-section">
                                <div class="delivery-option">
                                    <i class="fas fa-truck delivery-icon"></i>
                                    <div class="delivery-text">
                                        <strong>&Uuml;cretsiz Kargo</strong> ile yar&#305;n kap&#305;n&#305;zda!
                                    </div>
                                </div>
                                <div class="delivery-option">
                                    <i class="fas fa-store delivery-icon"></i>
                                    <div class="delivery-text">
                                        <strong>Ma&#287;azadan Teslim</strong> - Bug&uuml;n teslim al
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabs Section -->
        <div class="tabs-section">
            <!-- Tab Navigation -->
            <div class="tab-nav">
                <button class="tab-btn active" onclick="openTab(event, 'description')">&Uuml;r&uuml;n A&ccedil;&#305;klamas&#305;</button>
                <button class="tab-btn" onclick="openTab(event, 'specs')">Teknik &Ouml;zellikler</button>
                <button class="tab-btn" onclick="openTab(event, 'reviews')">De&#287;erlendirmeler <span
                        style="background: #ff6000; color: white; padding: 0.1rem 0.4rem; border-radius: 10px; font-size: 0.7rem; margin-left: 0.25rem;">@reviewSummary.TotalCount</span></button>
                <button class="tab-btn" onclick="openTab(event, 'qa')">Soru & Cevap</button>
            </div>

            <!-- Tab Content -->
            <div class="tab-content">
                <!-- Description Tab -->
                <div id="description" class="tab-pane active">
                    <h2 class="specs-header">&Uuml;r&uuml;n A&ccedil;&#305;klamas&#305;</h2>
                    <p style="font-size: 0.95rem; line-height: 1.8; color: #333;">
                        <strong>@Model.Name</strong>
                    </p>
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <p style="font-size: 0.95rem; line-height: 1.8; color: #666;">
                            @Model.Description
                        </p>
                    }
                </div>

                <!-- Specs Tab -->
                <div id="specs" class="tab-pane">
                    <h2 class="specs-header">&Uuml;r&uuml;n &Ouml;zellikleri</h2>

                    <!-- Info Icons -->
                    @if (Model.Specs.Any())
                    {
                        <div class="info-icons">
                            @foreach (var spec in Model.Specs.Take(5))
                            {
                                <div class="info-icon-item">
                                    <i class="fas fa-microchip"></i>
                                    <span>@spec.Key</span>
                                    <strong>@spec.Value</strong>
                                </div>
                            }
                        </div>

                        <div class="specs-table">
                            @foreach (var spec in Model.Specs)
                            {
                                <div class="spec-row">
                                    <span class="spec-label">@spec.Key</span>
                                    <span class="spec-value">@spec.Value</span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">Bu &uuml;r&uuml;n i&ccedil;in teknik &ouml;zellik bilgisi bulunmamaktad&#305;r.</p>
                    }
                </div>

                <!-- Reviews Tab -->
                <div id="reviews" class="tab-pane">
                    <h2 class="specs-header">De&#287;erlendirmeler</h2>
                    <div class="row g-4">
                        <div class="col-lg-4">
                            <div class="border rounded-3 p-3 bg-light">
                                <div class="d-flex align-items-baseline gap-2">
                                    <strong style="font-size: 2rem; color: var(--dark-blue);">@reviewSummary.AverageRating.ToString("0.0")</strong>
                                    <span class="stars">
                                        @for (var i = 1; i <= 5; i++)
                                        {
                                            <i class="@(i <= Math.Round(reviewSummary.AverageRating) ? "fas" : "far") fa-star"></i>
                                        }
                                    </span>
                                </div>
                                <div class="text-muted small">@reviewSummary.TotalCount de&#287;erlendirme</div>
                            </div>

                            <div class="border rounded-3 p-3 mt-3">
                                @if (User.Identity?.IsAuthenticated != true)
                                {
                                    <p class="text-muted mb-2">Yorum yapmak i&ccedil;in giri&#351; yapmal&#305;s&#305;n&#305;z.</p>
                                    <a asp-controller="Auth" asp-action="SignIn" class="btn btn-outline-primary btn-sm">Giri&#351; Yap</a>
                                }
                                else if (userReview != null)
                                {
                                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                                        <div class="fw-bold">Yorumunuz</div>
                                        <span class="badge @ReviewStatusClass(userReview.Status)">@ReviewStatusText(userReview.Status)</span>
                                    </div>
                                    @if (userReview.Status == 2)
                                    {
                                        <div class="alert alert-danger py-2 px-3 small mb-3">
                                            <div class="fw-bold mb-1"><i class="fas fa-circle-info me-1"></i>Yorumunuz reddedildi</div>
                                            <div>Gerekce: @(string.IsNullOrWhiteSpace(userReview.AdminNote) ? "Gerekce belirtilmedi." : userReview.AdminNote)</div>
                                        </div>
                                    }
                                    else if (userReview.Status == 0)
                                    {
                                        <div class="alert alert-warning py-2 px-3 small mb-3">
                                            <i class="fas fa-clock me-1"></i>Yorumunuz inceleme bekliyor.
                                        </div>
                                    }
                                    <form asp-controller="Product" asp-action="UpdateReview" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="ReviewId" value="@userReview.Id" />
                                        <input type="hidden" name="productId" value="@Model.Id" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString#reviews" />
                                        <select name="Rating" class="form-select mb-2">
                                            @for (var i = 5; i >= 1; i--)
                                            {
                                                if (userReview.Rating == i)
                                                {
                                                    <option value="@i" selected>@i y&#305;ld&#305;z</option>
                                                }
                                                else
                                                {
                                                    <option value="@i">@i y&#305;ld&#305;z</option>
                                                }
                                            }
                                        </select>
                                        <textarea name="Comment" class="form-control mb-2" rows="4" maxlength="1000">@userReview.Comment</textarea>
                                        <button type="submit" class="btn btn-primary btn-sm">G&uuml;ncelle</button>
                                    </form>
                                    <form asp-controller="Product" asp-action="DeleteReview" method="post" class="mt-2" onsubmit="return confirm('Yorumunuzu silmek istiyor musunuz?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="reviewId" value="@userReview.Id" />
                                        <input type="hidden" name="productId" value="@Model.Id" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString#reviews" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm">Yorumu Sil</button>
                                    </form>
                                }
                                else if (canReview?.CanReview == true)
                                {
                                    <div class="fw-bold mb-2">De&#287;erlendirme Yaz</div>
                                    <form asp-controller="Product" asp-action="CreateReview" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="ProductId" value="@Model.Id" />
                                        <input type="hidden" name="ProductName" value="@Model.Name" />
                                        <input type="hidden" name="ProductImageUrl" value="@Model.FirstImageUrl" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString#reviews" />
                                        <select name="Rating" class="form-select mb-2" required>
                                            <option value="">Puan se&ccedil;in</option>
                                            <option value="5">5 y&#305;ld&#305;z</option>
                                            <option value="4">4 y&#305;ld&#305;z</option>
                                            <option value="3">3 y&#305;ld&#305;z</option>
                                            <option value="2">2 y&#305;ld&#305;z</option>
                                            <option value="1">1 y&#305;ld&#305;z</option>
                                        </select>
                                        <textarea name="Comment" class="form-control mb-2" rows="4" minlength="10" maxlength="1000" placeholder="Deneyiminizi yaz&#305;n" required></textarea>
                                        <button type="submit" class="btn btn-primary btn-sm">Yorumu G&ouml;nder</button>
                                    </form>
                                }
                                else
                                {
                                    <p class="text-muted mb-0">@(canReview?.Reason ?? "Bu &uuml;r&uuml;n i&ccedil;in yorum yazamazs&#305;n&#305;z.")</p>
                                }
                            </div>
                        </div>

                        <div class="col-lg-8">
                            @if (reviewSummary.Reviews.Any())
                            {
                                foreach (var review in reviewSummary.Reviews)
                                {
                                    <div class="border-bottom py-3">
                                        <div class="d-flex justify-content-between gap-3 flex-wrap">
                                            <div>
                                                <strong>@review.UserName</strong>
                                                <div class="stars small">
                                                    @for (var i = 1; i <= 5; i++)
                                                    {
                                                        <i class="@(i <= review.Rating ? "fas" : "far") fa-star"></i>
                                                    }
                                                </div>
                                            </div>
                                            <small class="text-muted">@review.CreatedAt.ToString("dd.MM.yyyy")</small>
                                        </div>
                                        <p class="mb-0 mt-2">@review.Comment</p>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-center py-5">
                                    <i class="far fa-comment-dots fa-3x text-muted mb-3"></i>
                                    <p class="text-muted">Hen&uuml;z de&#287;erlendirme yap&#305;lmam&#305;&#351;.</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Q&A Tab -->
                <div id="qa" class="tab-pane">
                    <h2 class="specs-header">Soru & Cevap</h2>
                    <div class="text-center py-5">
                        <i class="far fa-question-circle fa-3x text-muted mb-3"></i>
                        <p class="text-muted">Hen&uuml;z soru sorulmam&#305;&#351;.</p>
                        <button class="btn btn-outline-primary">Soru Sor</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Fullscreen Image Gallery Modal -->
<div class="modal fade gallery-modal" id="imageGalleryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body"
                onclick="if(event.target === this) { const m = bootstrap.Modal.getInstance(document.getElementById('imageGalleryModal')); if(m) m.hide(); }">
                <div class="gallery-shell">
                    <div class="gallery-header">
                        <div class="modal-title-bar" title="B&uuml;y&uuml;tmek i&ccedil;in t&#305;klay&#305;n">
                            @Model.Name
                        </div>
                        <button type="button" class="modal-close-btn" data-bs-dismiss="modal" aria-label="Close">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>

                    <div class="modal-image-container" onclick="event.stopPropagation();">
                        <div class="modal-main-image">
                            @if (displayImageUrls.Count > 1)
                            {
                                <button type="button" class="image-nav-btn prev" onclick="prevModalImage()">
                                    <i class="fas fa-chevron-left"></i>
                                </button>
                                <button type="button" class="image-nav-btn next" onclick="nextModalImage()">
                                    <i class="fas fa-chevron-right"></i>
                                </button>
                            }
                            <img src="@Model.FirstImageUrl" id="modalMainImage" alt="@Model.Name"
                                 onerror="this.onerror=null;this.src='@GameGaraj.WebUI.Models.Products.ProductViewModel.DefaultImageUrl';">
                        </div>

                        @if (displayImageUrls.Count > 1)
                        {
                            <div class="modal-thumbnails">
                                @for (int i = 0; i < displayImageUrls.Count; i++)
                                {
                                    <div class="modal-thumb-item @(i == 0 ? "active" : "")"
                                        onclick="selectModalImage(@i, '@displayImageUrls[i]')">
                                        <img src="@displayImageUrls[i]" alt="Thumbnail @(i + 1)"
                                             onerror="this.onerror=null;this.src='@GameGaraj.WebUI.Models.Products.ProductViewModel.DefaultImageUrl';">
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentImageIndex = 0;
        const images = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(displayImageUrls));

        function applyGalleryImageOrientation(imgElement) {
            if (!imgElement) return;

            const isPortrait = imgElement.naturalHeight > imgElement.naturalWidth * 1.08;
            imgElement.classList.remove('is-portrait', 'is-landscape');
            imgElement.classList.add(isPortrait ? 'is-portrait' : 'is-landscape');
        }

        function selectImage(index, src) {
            currentImageIndex = index;
            document.getElementById('mainImage').src = src;

            document.querySelectorAll('.thumbnail-item').forEach((item, i) => {
                item.classList.toggle('active', i === index);
            });
        }

        function prevImage() {
            if (images.length === 0) return;
            currentImageIndex = (currentImageIndex - 1 + images.length) % images.length;
            selectImage(currentImageIndex, images[currentImageIndex]);
        }

        function nextImage() {
            if (images.length === 0) return;
            currentImageIndex = (currentImageIndex + 1) % images.length;
            selectImage(currentImageIndex, images[currentImageIndex]);
        }

        // Tab functionality
        function openTab(evt, tabName) {
            document.querySelectorAll('.tab-pane').forEach(pane => {
                pane.classList.remove('active');
            });
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('active');
            });

            document.getElementById(tabName).classList.add('active');
            evt.currentTarget.classList.add('active');
        }

        // Share functionality
        function shareProduct() {
            if (navigator.share) {
                navigator.share({
                    title: '@Model.Name',
                    url: window.location.href
                });
            } else {
                navigator.clipboard.writeText(window.location.href);
                alert('Link kopyaland\\u0131!');
            }
        }
        // Modal Gallery functionality
        let modal;
        document.addEventListener("DOMContentLoaded", function () {
            // Initialize Bootstrap modal instance
            let modalEl = document.getElementById('imageGalleryModal');
            const modalMainImage = document.getElementById('modalMainImage');
            if (modalEl) {
                modal = new bootstrap.Modal(modalEl);

                // When modal is hidden, sync the main page image to the last viewed modal image
                modalEl.addEventListener('hidden.bs.modal', function () {
                    selectImage(currentImageIndex, images[currentImageIndex]);
                });
            }

            if (modalMainImage) {
                if (modalMainImage.complete) {
                    applyGalleryImageOrientation(modalMainImage);
                } else {
                    modalMainImage.addEventListener('load', function () {
                        applyGalleryImageOrientation(modalMainImage);
                    });
                }
            }
        });

        function openGalleryModal() {
            if (modal) {
                // Sync modal with current index before opening
                selectModalImage(currentImageIndex, images[currentImageIndex]);
                modal.show();
            }
        }

        function selectModalImage(index, src) {
            currentImageIndex = index;
            const modalMainImage = document.getElementById('modalMainImage');
            modalMainImage.src = src;

            document.querySelectorAll('.modal-thumb-item').forEach((item, i) => {
                item.classList.toggle('active', i === index);
            });

            if (modalMainImage.complete) {
                applyGalleryImageOrientation(modalMainImage);
            } else {
                modalMainImage.onload = function () {
                    applyGalleryImageOrientation(modalMainImage);
                };
            }
        }

        function prevModalImage() {
            if (images.length === 0) return;
            currentImageIndex = (currentImageIndex - 1 + images.length) % images.length;
            selectModalImage(currentImageIndex, images[currentImageIndex]);
        }

        function nextModalImage() {
            if (images.length === 0) return;
            currentImageIndex = (currentImageIndex + 1) % images.length;
            selectModalImage(currentImageIndex, images[currentImageIndex]);
        }

        // Keyboard arrow navigation
        document.addEventListener('keydown', function (e) {
            if (images && images.length > 1) {
                if (e.key === 'ArrowLeft') {
                    const modalEl = document.getElementById('imageGalleryModal');
                    if (modalEl && modalEl.classList.contains('show')) {
                        prevModalImage();
                    } else {
                        prevImage();
                    }
                } else if (e.key === 'ArrowRight') {
                    const modalEl = document.getElementById('imageGalleryModal');
                    if (modalEl && modalEl.classList.contains('show')) {
                        nextModalImage();
                    } else {
                        nextImage();
                    }
                }
            }
        });
    </script>
}
