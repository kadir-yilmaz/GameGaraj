@model GameGaraj.WebUI.Areas.Admin.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2><i class="fas fa-tachometer-alt me-2"></i>Dashboard</h2>
            <p class="text-muted">GameGaraj yönetim paneline hoş geldiniz</p>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 metric-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="text-muted small">Ürün</div>
                            <div class="fs-3 fw-bold">@Model.ProductCount</div>
                        </div>
                        <span class="metric-icon text-success"><i class="fas fa-box"></i></span>
                    </div>
                    <div class="small text-muted mt-2">@Model.FeaturedProductCount vitrin ürünü</div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 metric-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="text-muted small">Kategori</div>
                            <div class="fs-3 fw-bold">@Model.CategoryCount</div>
                        </div>
                        <span class="metric-icon text-warning"><i class="fas fa-th-list"></i></span>
                    </div>
                    <div class="small text-muted mt-2">Alt kategoriler dahil</div>
                </div>
            </div>
        </div>

        @if (User.IsInRole("admin"))
        {
            <div class="col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100 metric-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <div class="text-muted small">Sipariş</div>
                                <div class="fs-3 fw-bold">@Model.OrderCount</div>
                            </div>
                            <span class="metric-icon text-primary"><i class="fas fa-shopping-cart"></i></span>
                        </div>
                        <div class="small text-muted mt-2">@Model.TotalRevenue.ToString("C2") toplam ciro</div>
                    </div>
                </div>
            </div>
        }

        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 metric-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="text-muted small">Düşük Stok</div>
                            <div class="fs-3 fw-bold">@Model.LowStockProductCount</div>
                        </div>
                        <span class="metric-icon text-danger"><i class="fas fa-exclamation-triangle"></i></span>
                    </div>
                    <div class="small text-muted mt-2">5 veya daha az kullanılabilir stok</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @if (User.IsInRole("admin"))
        {
            <div class="col-md-6 col-lg-3">
                <div class="card border-0 shadow-sm h-100 action-card">
                    <div class="card-body text-center">
                        <div class="mb-3">
                            <i class="fas fa-shopping-cart fa-3x text-primary"></i>
                        </div>
                        <h5 class="card-title">Sipariş Yönetimi</h5>
                        <p class="card-text text-muted">Siparişleri görüntüle ve yönet</p>
                        <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="btn btn-primary">
                            <i class="fas fa-arrow-right me-1"></i> Git
                        </a>
                    </div>
                </div>
            </div>
        }

        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 action-card">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <i class="fas fa-box fa-3x text-success"></i>
                    </div>
                    <h5 class="card-title">Ürün Yönetimi</h5>
                    <p class="card-text text-muted">Ürünleri ekle, düzenle, sil</p>
                    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-success">
                        <i class="fas fa-arrow-right me-1"></i> Git
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 action-card">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <i class="fas fa-th-list fa-3x text-warning"></i>
                    </div>
                    <h5 class="card-title">Kategori Yönetimi</h5>
                    <p class="card-text text-muted">Kategorileri düzenle</p>
                    <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="btn btn-warning">
                        <i class="fas fa-arrow-right me-1"></i> Git
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 action-card">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <i class="fas fa-globe fa-3x text-info"></i>
                    </div>
                    <h5 class="card-title">Siteyi Görüntüle</h5>
                    <p class="card-text text-muted">Ana siteye git</p>
                    <a asp-area="" asp-controller="Home" asp-action="Index" target="_blank" class="btn btn-info">
                        <i class="fas fa-external-link-alt me-1"></i> Aç
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .action-card,
    .metric-card {
        border-radius: 8px;
    }

    .action-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .action-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12) !important;
    }

    .action-card .fa-3x {
        transition: transform 0.2s;
    }

    .action-card:hover .fa-3x {
        transform: scale(1.08);
    }

    .metric-icon {
        width: 44px;
        height: 44px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        background: #f8f9fa;
        font-size: 1.35rem;
    }
</style>
