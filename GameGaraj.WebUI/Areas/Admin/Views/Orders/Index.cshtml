@model List<GameGaraj.WebUI.Models.Orders.OrderViewModel>
@{
    ViewData["Title"] = "Sipariş Yönetimi";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1"><i class="fas fa-shopping-cart me-2 text-primary"></i>Sipariş Yönetimi</h2>
            <p class="text-muted mb-0">Tüm siparişleri görüntüleyin ve yönetin</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary" onclick="filterOrders('all')">
                <i class="fas fa-list me-1"></i> Tümü (@Model.Count)
            </button>
            <button class="btn btn-outline-warning" onclick="filterOrders('pending')">
                <i class="fas fa-clock me-1"></i> Beklemede (@Model.Count(x => x.Status == 0))
            </button>
            <button class="btn btn-outline-info" onclick="filterOrders('processing')">
                <i class="fas fa-cog me-1"></i> Hazırlanıyor (@Model.Count(x => x.Status == 3))
            </button>
            <button class="btn btn-outline-primary" onclick="filterOrders('shipped')">
                <i class="fas fa-truck me-1"></i> Kargoda (@Model.Count(x => x.Status == 4))
            </button>
        </div>
    </div>

    <!-- Orders Grid -->
    <div class="row g-3" id="ordersContainer">
        @if (Model != null && Model.Any())
        {
            foreach (var order in Model)
            {
                var statusClass = order.Status switch
                {
                    0 => "warning",
                    1 => "success",
                    2 => "danger",
                    3 => "primary",
                    4 => "info",
                    5 => "success",
                    _ => "secondary"
                };

                var statusText = order.Status switch
                {
                    0 => "Beklemede",
                    1 => "Tamamlandı",
                    2 => "Başarısız",
                    3 => "Hazırlanıyor",
                    4 => "Kargoda",
                    5 => "Teslim Edildi",
                    _ => "Bilinmiyor"
                };

                var statusIcon = order.Status switch
                {
                    0 => "fa-clock",
                    1 => "fa-check-circle",
                    2 => "fa-times-circle",
                    3 => "fa-cog fa-spin",
                    4 => "fa-truck",
                    5 => "fa-box-open",
                    _ => "fa-question"
                };

                <div class="col-12 order-card" data-status="@order.Status">
                    <div class="card shadow-sm border-0 h-100 hover-card">
                        <div class="card-body">
                            <div class="row align-items-center">
                                <!-- Sipariş Bilgileri -->
                                <div class="col-md-2">
                                    <div class="text-center">
                                        <h5 class="mb-1 text-primary">#@order.Id</h5>
                                        <small class="text-muted">
                                            @order.CreatedDate.ToString("dd.MM.yyyy")<br/>
                                            @order.CreatedDate.ToString("HH:mm")
                                        </small>
                                    </div>
                                </div>

                                <!-- Müşteri Bilgileri -->
                                <div class="col-md-2">
                                    @if (order.Address != null && !string.IsNullOrEmpty(order.Address.FirstName))
                                    {
                                        <div>
                                            <i class="fas fa-user text-muted me-1"></i>
                                            <strong>@order.Address.FirstName @order.Address.LastName</strong>
                                        </div>
                                        <small class="text-muted">
                                            <i class="fas fa-phone me-1"></i>@order.Address.PhoneNumber
                                        </small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </div>

                                <!-- Ürünler -->
                                <div class="col-md-3">
                                    <div class="product-list">
                                        @foreach (var item in order.OrderItems.Take(2))
                                        {
                                            <div class="mb-1">
                                                <small class="text-truncate d-block">
                                                    <i class="fas fa-box text-muted me-1"></i>@item.ProductName
                                                </small>
                                            </div>
                                        }
                                        @if (order.OrderItems.Count > 2)
                                        {
                                            <small class="text-muted">+@(order.OrderItems.Count - 2) ürün daha</small>
                                        }
                                    </div>
                                </div>

                                <!-- Toplam -->
                                <div class="col-md-2 text-center">
                                    <h4 class="mb-0 text-success">
                                        ₺@order.OrderItems.Sum(x => x.Price).ToString("N2")
                                    </h4>
                                    <small class="text-muted">Toplam</small>
                                </div>

                                <!-- Durum -->
                                <div class="col-md-2 text-center">
                                    <span class="badge bg-@statusClass fs-6 px-3 py-2">
                                        <i class="fas @statusIcon me-1"></i>@statusText
                                    </span>
                                </div>

                                <!-- İşlemler -->
                                <div class="col-md-1 text-end">
                                    <div class="d-flex flex-column gap-2">
                                        @if (order.Status == 1) // Completed - Ödeme tamamlandı
                                        {
                                            <button type="button" 
                                                    class="btn btn-primary btn-sm w-100" 
                                                    onclick="showPrepareConfirm(@order.Id)"
                                                    title="Hazırlanıyor">
                                                <i class="fas fa-cog me-1"></i> Hazırla
                                            </button>
                                        }
                                        @if (order.Status == 3) // Processing - Hazırlanıyor
                                        {
                                            <button type="button" 
                                                    class="btn btn-info btn-sm w-100" 
                                                    onclick="showShipConfirm(@order.Id)"
                                                    title="Kargoya Ver">
                                                <i class="fas fa-truck me-1"></i> Kargola
                                            </button>
                                        }
                                        @if (order.Status == 4) // Shipped - Kargoda
                                        {
                                            <form asp-action="UpdateStatus" method="post">
                                                <input type="hidden" name="orderId" value="@order.Id" />
                                                <input type="hidden" name="status" value="5" />
                                                <button type="submit" class="btn btn-success btn-sm w-100" title="Teslim Edildi">
                                                    <i class="fas fa-box-open me-1"></i> Teslim
                                                </button>
                                            </form>
                                        }
                                        <button type="button" 
                                                class="btn btn-outline-secondary btn-sm w-100" 
                                                onclick="showOrderDetail(@order.Id)"
                                                title="Detaylar">
                                            <i class="fas fa-eye me-1"></i> Detay
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Kargolama Modal -->
                <div class="modal fade" id="shipModal@(order.Id)" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header bg-info text-white">
                                <h5 class="modal-title">
                                    <i class="fas fa-truck me-2"></i>Kargoya Ver - Sipariş #@order.Id
                                </h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                            </div>
                            <form asp-action="Ship" method="post">
                                <div class="modal-body">
                                    <input type="hidden" name="orderId" value="@order.Id" />
                                    
                                    <div class="alert alert-info">
                                        <i class="fas fa-info-circle me-2"></i>
                                        Bu siparişi kargoya vermek üzeresiniz. Müşteriye bilgilendirme e-postası gönderilecektir.
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label"><strong>Kargo Firması</strong></label>
                                        <select name="cargoCompany" class="form-select" required>
                                            <option value="">Seçiniz...</option>
                                            <option value="Yurtiçi Kargo">Yurtiçi Kargo</option>
                                            <option value="Aras Kargo">Aras Kargo</option>
                                            <option value="MNG Kargo">MNG Kargo</option>
                                            <option value="PTT Kargo">PTT Kargo</option>
                                            <option value="Sürat Kargo">Sürat Kargo</option>
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label"><strong>Kargo Takip No</strong></label>
                                        <input type="text" name="trackingNumber" class="form-control" 
                                               placeholder="Örn: 1234567890" required />
                                    </div>

                                    <div class="card bg-light">
                                        <div class="card-body">
                                            <h6 class="mb-2">Teslimat Adresi:</h6>
                                            @if (order.Address != null)
                                            {
                                                <p class="mb-1"><strong>@order.Address.FirstName @order.Address.LastName</strong></p>
                                                <p class="mb-1">@order.Address.PhoneNumber</p>
                                                <p class="mb-1">@order.Address.AddressDetail</p>
                                                <p class="mb-0">@order.Address.District / @order.Address.Province</p>
                                            }
                                        </div>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                        <i class="fas fa-times me-1"></i> İptal
                                    </button>
                                    <button type="submit" class="btn btn-info">
                                        <i class="fas fa-truck me-1"></i> Kargoya Ver
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Detay Modal -->
                <div class="modal fade" id="detailModal@(order.Id)" tabindex="-1">
                    <div class="modal-dialog modal-lg">
                        <div class="modal-content">
                            <div class="modal-header bg-primary text-white">
                                <h5 class="modal-title">
                                    <i class="fas fa-file-invoice me-2"></i>Sipariş #@order.Id Detayları
                                </h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <div class="row mb-4">
                                    <div class="col-md-6">
                                        <div class="card bg-light">
                                            <div class="card-body">
                                                <h6 class="mb-3"><i class="fas fa-user me-2"></i>Müşteri Bilgileri</h6>
                                                @if (order.Address != null)
                                                {
                                                    <p class="mb-1"><strong>Ad Soyad:</strong> @order.Address.FirstName @order.Address.LastName</p>
                                                    <p class="mb-1"><strong>Telefon:</strong> @order.Address.PhoneNumber</p>
                                                    <p class="mb-0"><strong>Email:</strong> @order.Address.Email</p>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="card bg-light">
                                            <div class="card-body">
                                                <h6 class="mb-3"><i class="fas fa-map-marker-alt me-2"></i>Teslimat Adresi</h6>
                                                @if (order.Address != null)
                                                {
                                                    <p class="mb-1">@order.Address.AddressDetail</p>
                                                    <p class="mb-1">@order.Address.Neighborhood</p>
                                                    <p class="mb-0">@order.Address.District / @order.Address.Province - @order.Address.PostalCode</p>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <h6 class="mb-3"><i class="fas fa-box me-2"></i>Sipariş Ürünleri</h6>
                                <div class="table-responsive">
                                    <table class="table table-hover">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Ürün Adı</th>
                                                <th class="text-end">Fiyat</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in order.OrderItems)
                                            {
                                                <tr>
                                                    <td>@item.ProductName</td>
                                                    <td class="text-end">₺@item.Price.ToString("N2")</td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot class="table-light">
                                            <tr>
                                                <th>TOPLAM</th>
                                                <th class="text-end text-success">₺@order.OrderItems.Sum(x => x.Price).ToString("N2")</th>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-body text-center py-5">
                        <i class="fas fa-inbox fa-4x text-muted mb-3"></i>
                        <h5 class="text-muted">Henüz sipariş bulunmamaktadır</h5>
                        <p class="text-muted">Yeni siparişler burada görünecektir.</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Toast Notification (Sol Alt) -->
<div class="position-fixed bottom-0 start-0 p-3" style="z-index: 1050;">
    <div id="orderToast" class="toast align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">
                <i class="fas fa-check-circle me-2"></i>
                <span id="toastMessage"></span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

<!-- Hazırla Onay Modal -->
<div class="modal fade" id="prepareConfirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="fas fa-cog me-2"></i>Siparişi Hazırla
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="text-center mb-3">
                    <i class="fas fa-box-open fa-3x text-primary mb-3"></i>
                    <h6>Bu siparişi hazırlamaya başlamak istediğinize emin misiniz?</h6>
                </div>
                <div class="alert alert-info mb-0">
                    <i class="fas fa-info-circle me-2"></i>
                    <small>Sipariş durumu "Hazırlanıyor" olarak güncellenecek ve müşteriye bilgilendirme e-postası gönderilecektir.</small>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i> İptal
                </button>
                <form id="prepareForm" asp-action="UpdateStatus" method="post" style="display: inline;">
                    <input type="hidden" name="orderId" id="prepareOrderId" />
                    <input type="hidden" name="status" value="3" />
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-cog me-1"></i> Hazırlamaya Başla
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Kargola Onay Modal -->
<div class="modal fade" id="shipConfirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title">
                    <i class="fas fa-truck me-2"></i>Kargoya Ver
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="text-center mb-3">
                    <i class="fas fa-shipping-fast fa-3x text-info mb-3"></i>
                    <h6>Bu siparişi kargoya vermek istediğinize emin misiniz?</h6>
                </div>
                <div class="alert alert-info mb-0">
                    <i class="fas fa-envelope me-2"></i>
                    <small>Kargo bilgileri kaydedilecek ve müşteriye kargo takip numarası ile birlikte bilgilendirme e-postası gönderilecektir.</small>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i> İptal
                </button>
                <button type="button" class="btn btn-info" id="confirmShipBtn">
                    <i class="fas fa-truck me-1"></i> Kargoya Ver
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-card {
        transition: all 0.3s ease;
    }

    .hover-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.15) !important;
    }

    .product-list {
        max-height: 60px;
        overflow: hidden;
    }

    .order-card {
        transition: opacity 0.3s ease;
    }

    .order-card.hidden {
        display: none;
    }
</style>

<script>
    let currentShipOrderId = null;

    // Toast göster
    function showToast(message, type = 'success') {
        const toast = document.getElementById('orderToast');
        const toastBody = toast.querySelector('.toast-body');
        const toastMessage = document.getElementById('toastMessage');
        
        // Renk ayarla
        toast.classList.remove('bg-success', 'bg-danger', 'bg-info');
        if (type === 'success') {
            toast.classList.add('bg-success', 'text-white');
            toastBody.innerHTML = '<i class="fas fa-check-circle me-2"></i><span>' + message + '</span>';
        } else if (type === 'error') {
            toast.classList.add('bg-danger', 'text-white');
            toastBody.innerHTML = '<i class="fas fa-exclamation-circle me-2"></i><span>' + message + '</span>';
        } else {
            toast.classList.add('bg-info', 'text-white');
            toastBody.innerHTML = '<i class="fas fa-info-circle me-2"></i><span>' + message + '</span>';
        }
        
        const bsToast = new bootstrap.Toast(toast, { delay: 4000 });
        bsToast.show();
    }

    // Hazırla onay popup
    function showPrepareConfirm(orderId) {
        document.getElementById('prepareOrderId').value = orderId;
        const modal = new bootstrap.Modal(document.getElementById('prepareConfirmModal'));
        modal.show();
    }

    // Kargola onay popup
    function showShipConfirm(orderId) {
        currentShipOrderId = orderId;
        const modal = new bootstrap.Modal(document.getElementById('shipConfirmModal'));
        modal.show();
    }

    // Kargola modal göster
    function showShipModal(orderId) {
        currentShipOrderId = orderId;
        const shipModal = new bootstrap.Modal(document.getElementById('shipModal' + orderId));
        shipModal.show();
    }

    // Kargola onay
    document.getElementById('confirmShipBtn')?.addEventListener('click', function() {
        if (currentShipOrderId) {
            const confirmModal = document.getElementById('shipConfirmModal');
            
            // Onay modalını kapat
            bootstrap.Modal.getInstance(confirmModal).hide();
            
            // Kargo modalını göster
            setTimeout(() => {
                showShipModal(currentShipOrderId);
            }, 300);
        }
    });

    function showOrderDetail(orderId) {
        const modal = new bootstrap.Modal(document.getElementById('detailModal' + orderId));
        modal.show();
    }

    function filterOrders(status) {
        const cards = document.querySelectorAll('.order-card');
        
        cards.forEach(card => {
            const orderStatus = card.getAttribute('data-status');
            
            if (status === 'all') {
                card.classList.remove('hidden');
            } else if (status === 'pending' && orderStatus === '0') {
                card.classList.remove('hidden');
            } else if (status === 'processing' && orderStatus === '3') {
                card.classList.remove('hidden');
            } else if (status === 'shipped' && orderStatus === '4') {
                card.classList.remove('hidden');
            } else {
                card.classList.add('hidden');
            }
        });
    }

    // Sayfa yüklendiğinde TempData'dan mesaj göster
    document.addEventListener('DOMContentLoaded', function() {
        @if (TempData["Success"] != null)
        {
            <text>
            showToast('@TempData["Success"]', 'success');
            </text>
        }
        @if (TempData["Error"] != null)
        {
            <text>
            showToast('@TempData["Error"]', 'error');
            </text>
        }
    });
</script>
