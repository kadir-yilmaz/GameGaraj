@model GameGaraj.WebUI.Areas.Admin.Models.OrderAdminIndexViewModel
@{
    ViewData["Title"] = "Siparis Yonetimi";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";

    var orders = Model.Results.Items;
    var currentUrl = Context.Request.Path + Context.Request.QueryString;
    var totalRevenue = orders.Sum(order => order.TotalPaidAmount > 0
        ? order.TotalPaidAmount
        : order.OrderItems.Sum(item => item.Price * item.Quantity));
    var pendingCount = orders.Count(order => order.Status == 0 || order.Status == 1);
    var shippingCount = orders.Count(order => order.Status == 4);
    var deliveredCount = orders.Count(order => order.Status == 5);

    static (string Text, string Theme, string Icon) GetStatusMeta(int status) => status switch
    {
        0 => ("Beklemede", "warning", "fa-clock"),
        1 => ("Tamamlandi", "success", "fa-check-circle"),
        2 => ("Basarisiz", "danger", "fa-times-circle"),
        3 => ("Hazirlaniyor", "primary", "fa-cog"),
        4 => ("Kargoda", "info", "fa-truck"),
        5 => ("Teslim edildi", "success", "fa-box-open"),
        _ => ("Bilinmiyor", "secondary", "fa-question-circle")
    };
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-4">
        <div>
            <h2 class="mb-1"><i class="fas fa-shopping-cart me-2 text-primary"></i>Siparis Yonetimi</h2>
            <p class="text-muted mb-0">Toplam <strong>@Model.Results.TotalCount</strong> siparis, sayfa <strong>@Model.Results.Page</strong> / <strong>@Math.Max(Model.Results.TotalPages, 1)</strong></p>
        </div>
        <div class="admin-toolbar-note">
            Son guncel filtrelerle calisiyorsunuz.
        </div>
    </div>

    <div class="admin-stat-grid mb-4">
        <section class="admin-stat-card">
            <div class="admin-stat-label">Bu sayfadaki ciro</div>
            <div class="admin-stat-value">@totalRevenue.ToString("C2")</div>
            <div class="admin-stat-meta">@orders.Count siparis goruntuleniyor</div>
        </section>
        <section class="admin-stat-card">
            <div class="admin-stat-label">Aksiyon bekleyen</div>
            <div class="admin-stat-value">@pendingCount</div>
            <div class="admin-stat-meta">Beklemede veya tamamlandi</div>
        </section>
        <section class="admin-stat-card">
            <div class="admin-stat-label">Kargoda</div>
            <div class="admin-stat-value">@shippingCount</div>
            <div class="admin-stat-meta">Takip sureci devam eden</div>
        </section>
        <section class="admin-stat-card">
            <div class="admin-stat-label">Teslim edildi</div>
            <div class="admin-stat-value">@deliveredCount</div>
            <div class="admin-stat-meta">Bu sayfadaki tamamlananlar</div>
        </section>
    </div>

    <form method="get" class="admin-filter-panel mb-4">
        <div class="row g-3 align-items-end">
            <div class="col-xl-4 col-lg-6">
                <label class="form-label">Ara</label>
                <input asp-for="Query" class="form-control" placeholder="Siparis no, musteri, e-posta, telefon" />
            </div>
            <div class="col-xl-3 col-lg-6">
                <label class="form-label">Durum</label>
                <select asp-for="Status" asp-items="Model.StatusOptions" class="form-select"></select>
            </div>
            <div class="col-xl-2 col-md-4">
                <label class="form-label">Baslangic</label>
                <input asp-for="DateFrom" type="date" class="form-control" />
            </div>
            <div class="col-xl-2 col-md-4">
                <label class="form-label">Bitis</label>
                <input asp-for="DateTo" type="date" class="form-control" />
            </div>
            <div class="col-xl-1 col-md-4">
                <label class="form-label">Boyut</label>
                <select asp-for="PageSize" class="form-select">
                    <option value="12">12</option>
                    <option value="24">24</option>
                    <option value="36">36</option>
                    <option value="48">48</option>
                </select>
            </div>
            <div class="col-12 d-flex justify-content-between align-items-center gap-2 flex-wrap">
                <div class="filter-hint">
                    Tarih araligi bitis gununu de kapsar.
                </div>
                <div class="d-flex gap-2">
                    <a asp-action="Index" class="btn btn-light border">Temizle</a>
                    <button type="submit" class="btn btn-dark">
                        <i class="fas fa-filter me-2"></i>Filtrele
                    </button>
                </div>
            </div>
        </div>
        <input type="hidden" name="Page" value="1" />
    </form>

    <div class="order-grid">
        @if (orders.Any())
        {
            foreach (var order in orders)
            {
                var status = GetStatusMeta(order.Status);
                var orderTotal = order.TotalPaidAmount > 0
                    ? order.TotalPaidAmount
                    : order.OrderItems.Sum(item => item.Price * item.Quantity);
                var customerName = string.IsNullOrWhiteSpace(order.Address?.FirstName)
                    ? "-"
                    : $"{order.Address.FirstName} {order.Address.LastName}";

                <article class="order-card">
                    <div class="order-card-top">
                        <div>
                            <div class="order-number">#@order.Id</div>
                            <div class="order-date">@order.CreatedDate.ToString("dd.MM.yyyy HH:mm")</div>
                        </div>
                        <span class="badge bg-@status.Theme-subtle text-@status.Theme-emphasis order-status-badge">
                            <i class="fas @status.Icon me-1"></i>@status.Text
                        </span>
                    </div>

                    <div class="order-card-body">
                        <div class="order-meta">
                            <div class="order-meta-label">Musteri</div>
                            <div class="order-meta-value">@customerName</div>
                            <div class="order-meta-sub text-truncate">@order.Address?.Email</div>
                        </div>

                        <div class="order-meta">
                            <div class="order-meta-label">Telefon</div>
                            <div class="order-meta-value">@(!string.IsNullOrWhiteSpace(order.Address?.PhoneNumber) ? order.Address.PhoneNumber : "-")</div>
                            <div class="order-meta-sub">@order.OrderItems.Count urun satiri</div>
                        </div>

                        <div class="order-meta text-end">
                            <div class="order-meta-label">Tutar</div>
                            <div class="order-meta-value text-success-emphasis">@orderTotal.ToString("C2")</div>
                            <div class="order-meta-sub">@order.OrderItems.Sum(item => item.Quantity) adet</div>
                        </div>
                    </div>

                    <div class="order-items-preview">
                        @foreach (var item in order.OrderItems.Take(3))
                        {
                            <div class="order-item-line">
                                <span class="text-truncate">@item.ProductName</span>
                                <span class="text-muted">@((item.Price * item.Quantity).ToString("C2"))</span>
                            </div>
                        }
                        @if (order.OrderItems.Count > 3)
                        {
                            <div class="small text-muted mt-1">+@(order.OrderItems.Count - 3) urun daha</div>
                        }
                    </div>

                    <div class="order-card-actions">
                        @if (order.Status == 1)
                        {
                            <button type="button" class="btn btn-sm btn-primary" onclick="showPrepareConfirm(@order.Id)">
                                <i class="fas fa-cog me-1"></i>Hazirla
                            </button>
                        }
                        @if (order.Status == 3)
                        {
                            <button type="button" class="btn btn-sm btn-info text-white" onclick="showShipModal(@order.Id)">
                                <i class="fas fa-truck me-1"></i>Kargola
                            </button>
                        }
                        @if (order.Status == 4)
                        {
                            <button type="button" class="btn btn-sm btn-success" onclick="showDeliverConfirm(@order.Id)">
                                <i class="fas fa-box-open me-1"></i>Teslim et
                            </button>
                        }
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="showOrderDetail(@order.Id)">
                            <i class="fas fa-eye me-1"></i>Detay
                        </button>
                    </div>
                </article>

                <div class="modal fade" id="shipModal@(order.Id)" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header bg-info text-white">
                                <h5 class="modal-title"><i class="fas fa-truck me-2"></i>Kargoya ver - Siparis #@order.Id</h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                            </div>
                            <form asp-action="Ship" method="post">
                                <div class="modal-body">
                                    <input type="hidden" name="orderId" value="@order.Id" />
                                    <input type="hidden" name="returnUrl" value="@currentUrl" />

                                    <div class="mb-3">
                                        <label class="form-label"><strong>Kargo firmasi</strong></label>
                                        <select name="cargoCompany" class="form-select" required>
                                            <option value="">Seciniz...</option>
                                            <option value="Yurtici Kargo">Yurtici Kargo</option>
                                            <option value="Aras Kargo">Aras Kargo</option>
                                            <option value="MNG Kargo">MNG Kargo</option>
                                            <option value="PTT Kargo">PTT Kargo</option>
                                            <option value="Surat Kargo">Surat Kargo</option>
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label"><strong>Takip no</strong></label>
                                        <input type="text" name="trackingNumber" class="form-control" placeholder="Orn: 1234567890" required />
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Iptal</button>
                                    <button type="submit" class="btn btn-info text-white"><i class="fas fa-truck me-1"></i>Kargoya ver</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="detailModal@(order.Id)" tabindex="-1">
                    <div class="modal-dialog modal-lg modal-dialog-scrollable">
                        <div class="modal-content">
                            <div class="modal-header bg-primary text-white">
                                <h5 class="modal-title"><i class="fas fa-file-invoice me-2"></i>Siparis #@order.Id detaylari</h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <div class="row g-3 mb-4">
                                    <div class="col-md-6">
                                        <div class="detail-panel h-100">
                                            <h6 class="mb-3">Musteri bilgileri</h6>
                                            <div><strong>@customerName</strong></div>
                                            <div class="text-muted">@order.Address?.PhoneNumber</div>
                                            <div class="text-muted">@order.Address?.Email</div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="detail-panel h-100">
                                            <h6 class="mb-3">Teslimat adresi</h6>
                                            <div>@order.Address?.AddressDetail</div>
                                            <div class="text-muted">@order.Address?.Neighborhood</div>
                                            <div class="text-muted">@order.Address?.District / @order.Address?.Province @order.Address?.PostalCode</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="table-responsive">
                                    <table class="table table-sm align-middle">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Urun</th>
                                                <th class="text-center">Adet</th>
                                                <th class="text-end">Birim fiyat</th>
                                                <th class="text-end">Tutar</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in order.OrderItems)
                                            {
                                                <tr>
                                                    <td>@item.ProductName</td>
                                                    <td class="text-center">@item.Quantity</td>
                                                    <td class="text-end">@item.Price.ToString("C2")</td>
                                                    <td class="text-end">@((item.Price * item.Quantity).ToString("C2"))</td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot>
                                            <tr>
                                                <th colspan="3">Toplam</th>
                                                <th class="text-end text-success">@orderTotal.ToString("C2")</th>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-inbox fa-3x mb-3 text-muted"></i>
                <h5 class="mb-2">Sonuc bulunamadi</h5>
                <p class="text-muted mb-0">Filtreleri degistirip tekrar deneyin.</p>
            </div>
        }
    </div>

    @if (Model.Results.TotalPages > 1)
    {
        <nav class="mt-4" aria-label="Order pagination">
            <ul class="pagination justify-content-center flex-wrap gap-2">
                <li class="page-item @(Model.Results.HasPreviousPage ? string.Empty : "disabled")">
                    <a class="page-link" asp-action="Index"
                       asp-route-Query="@Model.Query"
                       asp-route-Status="@Model.Status"
                       asp-route-DateFrom="@(Model.DateFrom?.ToString("yyyy-MM-dd"))"
                       asp-route-DateTo="@(Model.DateTo?.ToString("yyyy-MM-dd"))"
                       asp-route-Page="@(Model.Results.Page - 1)"
                       asp-route-PageSize="@Model.PageSize">Onceki</a>
                </li>
                @for (var i = Math.Max(1, Model.Results.Page - 2); i <= Math.Min(Model.Results.TotalPages, Model.Results.Page + 2); i++)
                {
                    <li class="page-item @(i == Model.Results.Page ? "active" : string.Empty)">
                        <a class="page-link" asp-action="Index"
                           asp-route-Query="@Model.Query"
                           asp-route-Status="@Model.Status"
                           asp-route-DateFrom="@(Model.DateFrom?.ToString("yyyy-MM-dd"))"
                           asp-route-DateTo="@(Model.DateTo?.ToString("yyyy-MM-dd"))"
                           asp-route-Page="@i"
                           asp-route-PageSize="@Model.PageSize">@i</a>
                    </li>
                }
                <li class="page-item @(Model.Results.HasNextPage ? string.Empty : "disabled")">
                    <a class="page-link" asp-action="Index"
                       asp-route-Query="@Model.Query"
                       asp-route-Status="@Model.Status"
                       asp-route-DateFrom="@(Model.DateFrom?.ToString("yyyy-MM-dd"))"
                       asp-route-DateTo="@(Model.DateTo?.ToString("yyyy-MM-dd"))"
                       asp-route-Page="@(Model.Results.Page + 1)"
                       asp-route-PageSize="@Model.PageSize">Sonraki</a>
                </li>
            </ul>
        </nav>
    }
</div>

<div class="modal fade" id="prepareConfirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fas fa-cog me-2"></i>Siparisi hazirla</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Bu siparisi hazirlamaya baslamak istediginize emin misiniz?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Iptal</button>
                <form asp-action="UpdateStatus" method="post">
                    <input type="hidden" name="orderId" id="prepareOrderId" />
                    <input type="hidden" name="status" value="3" />
                    <input type="hidden" name="returnUrl" value="@currentUrl" />
                    <button type="submit" class="btn btn-primary">Hazirlamaya basla</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deliverConfirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="fas fa-box-open me-2"></i>Siparisi teslim et</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Bu siparisi teslim edildi olarak isaretlemek istediginize emin misiniz?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Iptal</button>
                <form asp-action="UpdateStatus" method="post">
                    <input type="hidden" name="orderId" id="deliverOrderId" />
                    <input type="hidden" name="status" value="5" />
                    <input type="hidden" name="returnUrl" value="@currentUrl" />
                    <button type="submit" class="btn btn-success">Teslim edildi</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="position-fixed bottom-0 start-0 p-3" style="z-index: 1050;">
    <div id="orderToast" class="toast align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body"></div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

<style>
    .admin-filter-panel,
    .admin-stat-card,
    .order-card,
    .detail-panel {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
    }

    .admin-filter-panel,
    .order-card,
    .detail-panel {
        padding: 1rem;
    }

    .admin-toolbar-note,
    .filter-hint {
        color: #64748b;
        font-size: 0.9rem;
    }

    .admin-stat-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
    }

    .admin-stat-card {
        padding: 1rem 1.1rem;
    }

    .admin-stat-label {
        font-size: 0.85rem;
        color: #64748b;
        margin-bottom: 0.35rem;
    }

    .admin-stat-value {
        font-size: 1.6rem;
        font-weight: 700;
        color: #111827;
        line-height: 1.1;
    }

    .admin-stat-meta {
        color: #64748b;
        font-size: 0.85rem;
        margin-top: 0.4rem;
    }

    .order-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 1rem;
    }

    .order-card-top,
    .order-card-body,
    .order-card-actions,
    .order-item-line {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
    }

    .order-card-top {
        margin-bottom: 1rem;
    }

    .order-card-body {
        align-items: stretch;
        margin-bottom: 1rem;
    }

    .order-meta {
        flex: 1;
        min-width: 0;
    }

    .order-number {
        font-size: 1.1rem;
        font-weight: 700;
        color: #111827;
    }

    .order-date,
    .order-meta-label,
    .order-meta-sub {
        font-size: 0.85rem;
        color: #6b7280;
    }

    .order-meta-value {
        font-weight: 600;
        color: #111827;
        line-height: 1.35;
    }

    .order-status-badge {
        padding: 0.55rem 0.8rem;
        border-radius: 999px;
    }

    .order-items-preview {
        padding-top: 0.85rem;
        border-top: 1px solid #f1f5f9;
        margin-bottom: 1rem;
    }

    .order-item-line + .order-item-line {
        margin-top: 0.4rem;
    }

    .order-card-actions {
        justify-content: flex-end;
        flex-wrap: wrap;
    }

    .empty-state {
        background: #fff;
        border: 1px dashed #d1d5db;
        border-radius: 8px;
        padding: 3rem 1.5rem;
        text-align: center;
    }

    .page-link {
        border-radius: 8px;
        border: 1px solid #d1d5db;
        color: #111827;
    }

    .page-item.active .page-link {
        background: #111827;
        border-color: #111827;
    }

    @@media (max-width: 1200px) {
        .admin-stat-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 768px) {
        .admin-stat-grid {
            grid-template-columns: 1fr;
        }

        .order-card-body {
            flex-direction: column;
            align-items: flex-start;
        }

        .order-meta.text-end {
            text-align: left !important;
        }
    }
</style>

@section Scripts {
    <script>
        function showToast(message, type = 'success') {
            const toast = document.getElementById('orderToast');
            const toastBody = toast.querySelector('.toast-body');

            toast.classList.remove('bg-success', 'bg-danger');
            toast.classList.add(type === 'success' ? 'bg-success' : 'bg-danger', 'text-white');
            toastBody.innerHTML = `<i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle'} me-2"></i><span>${message}</span>`;

            bootstrap.Toast.getOrCreateInstance(toast, { delay: 4000 }).show();
        }

        function showPrepareConfirm(orderId) {
            document.getElementById('prepareOrderId').value = orderId;
            bootstrap.Modal.getOrCreateInstance(document.getElementById('prepareConfirmModal')).show();
        }

        function showDeliverConfirm(orderId) {
            document.getElementById('deliverOrderId').value = orderId;
            bootstrap.Modal.getOrCreateInstance(document.getElementById('deliverConfirmModal')).show();
        }

        function showShipModal(orderId) {
            bootstrap.Modal.getOrCreateInstance(document.getElementById('shipModal' + orderId)).show();
        }

        function showOrderDetail(orderId) {
            bootstrap.Modal.getOrCreateInstance(document.getElementById('detailModal' + orderId)).show();
        }

        document.addEventListener('DOMContentLoaded', function () {
            @if (TempData["Success"] != null)
            {
                <text>showToast('@TempData["Success"]', 'success');</text>
            }
            @if (TempData["Error"] != null)
            {
                <text>showToast('@TempData["Error"]', 'error');</text>
            }
        });
    </script>
}
