@model GameGaraj.WebUI.Models.Products.CategoryCreateInput
@{
    ViewData["Title"] = "Kategori Düzenle";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2">Kategoriyi Düzenle</h1>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-action="Index">Kategoriler</a></li>
        <li class="breadcrumb-item active" aria-current="page">Düzenle</li>
      </ol>
    </nav>
</div>

<style>
    .attribute-card {
        transition: box-shadow 0.2s ease, transform 0.2s ease;
    }

    .attribute-card:hover {
        box-shadow: 0 0.5rem 1.5rem rgba(15, 23, 42, 0.08);
    }

    .attr-chip,
    .edit-option-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        border-radius: 999px;
        background: #e8f5ff;
        color: #075985;
        border: 1px solid #bae6fd;
        padding: 0.35rem 0.65rem;
        font-size: 0.8rem;
        font-weight: 700;
        line-height: 1;
    }

    .edit-option-chip button {
        border: 0;
        background: transparent;
        color: #075985;
        padding: 0;
        line-height: 1;
    }

    .edit-options-editor {
        border: 1px solid #dbeafe;
        background: #f8fbff;
        border-radius: 8px;
        padding: 0.85rem;
    }
</style>

<form asp-action="Edit" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="row g-4">
        <!-- Genel Bilgiler Card -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title mb-0"><i class="fas fa-edit me-2 text-primary"></i>Kategori Bilgileri</h5>
                </div>
                <div class="card-body p-4">
                    <div class="mb-4">
                        <label asp-for="Name" class="form-label fw-bold">Kategori Adı</label>
                        <input asp-for="Name" class="form-control" placeholder="Örn: Ekran Kartı" required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-0">
                        <label asp-for="ParentId" class="form-label fw-bold">Üst Kategori</label>
                        <select asp-for="ParentId" class="form-select" asp-items="ViewBag.Categories">
                            <option value="">-- Ana Kategori (ROOT) --</option>
                        </select>
                        <div class="form-text mt-2 small text-muted">Alt kategori eklemek için ana kategoriyi seçin.</div>
                    </div>
                    <div class="mt-4 form-check form-switch">
                        <input asp-for="IsShowOnHome" class="form-check-input" type="checkbox" role="switch" id="isShowOnHomeSwitch">
                        <label asp-for="IsShowOnHome" class="form-check-label fw-bold" for="isShowOnHomeSwitch">Ana Sayfada Göster</label>
                        <div class="form-text small text-muted">Bu kategori ana sayfada her satırda 5 adet olacak şekilde listelensin mi?</div>
                    </div>
                </div>
            </div>

            <!-- Existing Attributes -->
            @if (ViewBag.ExistingAttributes != null && ((List<GameGaraj.WebUI.Models.Products.CategoryAttributeViewModel>)ViewBag.ExistingAttributes).Any())
            {
                    <div class="card border-0 shadow-sm mt-4">
                        <div class="card-header bg-white py-3">
                            <h5 class="card-title mb-0"><i class="fas fa-list me-2 text-secondary"></i>Mevcut Özellikler</h5>
                        </div>
                        <div class="card-body p-0">
                        @foreach (var attr in (List<GameGaraj.WebUI.Models.Products.CategoryAttributeViewModel>)ViewBag.ExistingAttributes)
                        {
                                    <div class="border-bottom p-3 existing-attr-row attribute-card" data-attr-id="@attr.Id">
                                        <!-- Display Mode -->
                                        <div class="attr-display d-flex justify-content-between align-items-center">
                                            <div>
                                                <div class="fw-bold">@attr.DisplayName</div>
                                                <small class="text-muted">Tip: @attr.Type | Kod: @attr.Name</small>
                                        @if (attr.Options != null && attr.Options.Any())
                                        {
                                                        <div class="mt-2 d-flex flex-wrap gap-2">
                                                @foreach (var opt in attr.Options)
                                                {
                                                                    <span class="attr-chip">@opt</span>
                                                }
                                                        </div>
                                        }
                                            </div>
                                            <div class="btn-group btn-group-sm">
                                                <button type="button" class="btn btn-outline-primary btn-edit-existing" title="Düzenle">
                                                    <i class="fas fa-pen"></i>
                                                </button>
                                                <button type="button" class="btn btn-outline-danger btn-delete-existing" 
                                                        data-category-id="@Context.Request.RouteValues["id"]" 
                                                        data-attr-id="@attr.Id"
                                                        data-attr-name="@attr.DisplayName"
                                                        title="Sil">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                        <!-- Edit Mode (hidden by default) -->
                                        <div class="attr-edit-form" style="display:none;">
                                            <div class="row g-2 align-items-end">
                                                <div class="col-md-3">
                                                    <label class="small text-muted mb-1 d-block">Kod Adı</label>
                                                    <input type="text" class="form-control form-control-sm edit-name" value="@attr.Name" />
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="small text-muted mb-1 d-block">Görünen Ad</label>
                                                    <input type="text" class="form-control form-control-sm edit-displayname" value="@attr.DisplayName" />
                                                </div>
                                                <div class="col-md-2">
                                                    <label class="small text-muted mb-1 d-block">Tip</label>
                                                    <select class="form-select form-select-sm edit-type">
                                                        <!option value="Text" @(attr.Type == "Text" ? "selected" : "")>Metin</!option>
                                                        <!option value="Number" @(attr.Type == "Number" ? "selected" : "")>Sayı</!option>
                                                        <!option value="Dropdown" @(attr.Type == "Dropdown" ? "selected" : "")>Dropdown</!option>
                                                    </select>
                                                </div>
                                                <div class="col-md-4 d-flex gap-1">
                                                    <button type="button" class="btn btn-sm btn-success btn-save-edit flex-fill"
                                                            data-category-id="@Context.Request.RouteValues["id"]"
                                                            data-attr-id="@attr.Id">
                                                        <i class="fas fa-check me-1"></i>Kaydet
                                                    </button>
                                                    <button type="button" class="btn btn-sm btn-secondary btn-cancel-edit">
                                                        <i class="fas fa-times"></i>
                                                    </button>
                                                </div>
                                            </div>
                                            <div class="mt-3 edit-options-editor @(attr.Type == "Dropdown" ? "" : "d-none")">
                                                <div class="d-flex justify-content-between align-items-center mb-2">
                                                    <label class="small fw-bold text-primary mb-0">
                                                        <i class="fas fa-tags me-1"></i>Seçenekler
                                                    </label>
                                                    <span class="small text-muted">Enter ile ekleyin</span>
                                                </div>
                                                <div class="edit-option-list d-flex flex-wrap gap-2 mb-2">
                                                    @if (attr.Options != null)
                                                    {
                                                        @foreach (var opt in attr.Options)
                                                        {
                                                            <span class="edit-option-chip" data-option="@opt">
                                                                @opt
                                                                <button type="button" class="btn-remove-edit-option" aria-label="@opt seçeneğini sil">
                                                                    <i class="fas fa-times"></i>
                                                                </button>
                                                            </span>
                                                        }
                                                    }
                                                </div>
                                                <div class="input-group input-group-sm">
                                                    <input type="text" class="form-control edit-option-input" placeholder="Örn: 12GB">
                                                    <button type="button" class="btn btn-outline-primary btn-add-edit-option">
                                                        <i class="fas fa-plus me-1"></i>Ekle
                                                    </button>
                                                </div>
                                                <input type="hidden" class="edit-options" value="@(attr.Options != null ? string.Join(", ", attr.Options) : "")" />
                                            </div>
                                        </div>
                                    </div>
                        }
                        </div>
                    </div>
            }
        </div>

        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0"><i class="fas fa-plus-circle me-2 text-success"></i>Yeni Özellik Ekle</h5>
                    <button type="button" class="btn btn-sm btn-outline-success rounded-pill px-3" id="btnAddAttribute">
                        <i class="fas fa-plus me-1"></i> Özellik Ekle
                    </button>
                </div>
                <div class="card-body p-4">
                    <div id="attributesContainer" class="mb-3">
                        <!-- Dynamic inputs will be added here -->
                    </div>
                    <div class="bg-light p-3 rounded border border-dashed text-center" id="emptyAttributesHint">
                        <p class="mb-0 text-muted small">Bu kategoriye yeni özellikler eklemek için butona tıklayın.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5 mb-5 pt-4 border-top">
        <button class="btn btn-primary px-5 py-2 fw-bold" type="submit">
            <i class="fas fa-save me-2"></i>Değişiklikleri Kaydet
        </button>
        <a asp-action="Index" class="btn btn-light px-4 py-2 text-muted ms-2">İptal</a>
    </div>
</form>

@section Scripts {
        <script>
            $(document).ready(function() {
                let attributeIndex = 0;

                function toggleHint() {
                    if ($('.attribute-row').length > 0) {
                        $('#emptyAttributesHint').hide();
                    } else {
                        $('#emptyAttributesHint').show();
                    }
                }

                $('#btnAddAttribute').click(function() {
                    const html = `
                        <div class="card mb-3 border attribute-row bg-light shadow-sm animate__animated animate__fadeIn" data-index="${attributeIndex}">
                            <div class="card-body p-3">
                                <div class="row g-2 align-items-center">
                                    <div class="col-md-3">
                                        <label class="small text-muted mb-1 d-block font-monospace">Kod Adı (ID)</label>
                                        <input type="text" name="attributes[${attributeIndex}].Name" class="form-control form-control-sm" placeholder="örn: frequency" required>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="small text-muted mb-1 d-block font-monospace">Görünen Ad</label>
                                        <input type="text" name="attributes[${attributeIndex}].DisplayName" class="form-control form-control-sm" placeholder="örn: Frekans" required>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="small text-muted mb-1 d-block font-monospace">Tip</label>
                                        <select name="attributes[${attributeIndex}].Type" class="form-select form-select-sm attr-type-select">
                                            <option value="Text">Metin (String)</option>
                                            <option value="Number">Sayı (Number)</option>
                                            <option value="Dropdown">Seçenekli (Dropdown)</option>
                                        </select>
                                    </div>
                                    <div class="col-md-2 d-flex align-self-end">
                                         <button type="button" class="btn btn-outline-danger btn-sm w-100 btn-remove-attr">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </div>
                                <div class="options-container mt-3 p-3 bg-white rounded border border-info" style="display:none;">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <label class="small fw-bold text-info"><i class="fas fa-list-ul me-1"></i> Dropdown Seçenekleri</label>
                                        <button type="button" class="btn btn-xxs btn-info text-white rounded-pill btn-add-option">
                                            <i class="fas fa-plus small"></i>
                                        </button>
                                    </div>
                                    <div class="options-list row g-2"></div>
                                </div>
                            </div>
                        </div>
                    `;
                    $('#attributesContainer').append(html);
                    attributeIndex++;
                    toggleHint();
                });

                $(document).on('change', '.attr-type-select', function() {
                    const container = $(this).closest('.card-body').find('.options-container');
                    if ($(this).val() === 'Dropdown') {
                        container.slideDown();
                        if (container.find('.option-item').length === 0) {
                            $(this).closest('.card-body').find('.btn-add-option').click();
                        }
                    } else {
                        container.slideUp();
                    }
                });

                $(document).on('click', '.btn-add-option', function() {
                    const row = $(this).closest('.attribute-row');
                    const attrIdx = row.data('index');
                    const list = row.find('.options-list');
                    const optIdx = list.find('.option-item').length;

                    const html = `
                        <div class="col-md-6 option-item animate__animated animate__fadeIn">
                            <div class="input-group input-group-sm">
                                <input type="text" name="attributes[${attrIdx}].Options[${optIdx}]" class="form-control" placeholder="Seçenek..." required>
                                <button class="btn btn-outline-danger btn-remove-option" type="button"><i class="fas fa-times"></i></button>
                            </div>
                        </div>
                    `;
                    list.append(html);
                });

                $(document).on('click', '.btn-remove-option', function() {
                    $(this).closest('.option-item').remove();
                    reindexNewOptions($(this).closest('.attribute-row'));
                });

                function reindexNewOptions(row) {
                    const attrIdx = row.data('index');
                    row.find('.option-item input').each(function(index) {
                        $(this).attr('name', `attributes[${attrIdx}].Options[${index}]`);
                    });
                }

                $(document).on('keydown', '.options-list .option-item input', function(e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        const row = $(this).closest('.attribute-row');
                        if ($(this).val().trim()) {
                            row.find('.btn-add-option').click();
                            row.find('.option-item input').last().trigger('focus');
                        }
                    }
                });

                $('form[asp-action="Edit"], form').on('submit', function() {
                    $('.attribute-row').each(function() {
                        const row = $(this);
                        const seen = new Set();
                        row.find('.option-item').each(function() {
                            const input = $(this).find('input');
                            const value = (input.val() || '').trim();
                            const key = value.toLocaleLowerCase('tr-TR');
                            if (!value || seen.has(key)) {
                                $(this).remove();
                            } else {
                                input.val(value);
                                seen.add(key);
                            }
                        });
                        reindexNewOptions(row);
                    });
                });

                $(document).on('click', '.btn-remove-attr', function() {
                $(this).closest('.attribute-row').remove();
                toggleHint();
            });

            // === EXISTING ATTRIBUTE HANDLERS ===

            // Edit button — toggle display/edit mode
            $(document).on('click', '.btn-edit-existing', function() {
                const row = $(this).closest('.existing-attr-row');
                row.find('.attr-display').hide();
                row.find('.attr-edit-form').slideDown();
            });

            // Cancel edit
            $(document).on('click', '.btn-cancel-edit', function() {
                const row = $(this).closest('.existing-attr-row');
                row.find('.attr-edit-form').slideUp();
                row.find('.attr-display').show();
            });

            function normalizeOption(value) {
                return (value || '').trim();
            }

            function getEditOptions(row) {
                return row.find('.edit-option-chip').map(function() {
                    return normalizeOption($(this).data('option') || $(this).find('.edit-option-text').text() || $(this).contents().first().text());
                }).get().filter(Boolean);
            }

            function syncEditOptions(row) {
                row.find('.edit-options').val(getEditOptions(row).join(', '));
            }

            function addEditOption(row, value) {
                const option = normalizeOption(value);
                if (!option) return;

                const exists = getEditOptions(row).some(function(existing) {
                    return existing.toLocaleLowerCase('tr-TR') === option.toLocaleLowerCase('tr-TR');
                });
                if (exists) {
                    row.find('.edit-option-input').val('').focus();
                    return;
                }

                const chip = $(`
                    <span class="edit-option-chip" data-option="">
                        <span class="edit-option-text"></span>
                        <button type="button" class="btn-remove-edit-option" aria-label="Seçeneği sil">
                            <i class="fas fa-times"></i>
                        </button>
                    </span>
                `);
                chip.attr('data-option', option);
                chip.find('.edit-option-text').text(option);
                row.find('.edit-option-list').append(chip);
                row.find('.edit-option-input').val('').focus();
                syncEditOptions(row);
            }

            $(document).on('change', '.existing-attr-row .edit-type', function() {
                const row = $(this).closest('.existing-attr-row');
                const editor = row.find('.edit-options-editor');
                if ($(this).val() === 'Dropdown') {
                    editor.removeClass('d-none').hide().slideDown(150);
                    row.find('.edit-option-input').trigger('focus');
                } else {
                    editor.slideUp(150, function() {
                        editor.addClass('d-none');
                    });
                }
            });

            $(document).on('click', '.btn-add-edit-option', function() {
                const row = $(this).closest('.existing-attr-row');
                addEditOption(row, row.find('.edit-option-input').val());
            });

            $(document).on('keydown', '.edit-option-input', function(e) {
                if (e.key === 'Enter' || e.key === ',') {
                    e.preventDefault();
                    const row = $(this).closest('.existing-attr-row');
                    addEditOption(row, $(this).val());
                }
            });

            $(document).on('click', '.btn-remove-edit-option', function() {
                const row = $(this).closest('.existing-attr-row');
                $(this).closest('.edit-option-chip').remove();
                syncEditOptions(row);
            });

            // Save edit — submit via hidden form
            $(document).on('click', '.btn-save-edit', function() {
                const row = $(this).closest('.existing-attr-row');
                const categoryId = $(this).data('category-id');
                const attrId = $(this).data('attr-id');
                const name = row.find('.edit-name').val();
                const displayName = row.find('.edit-displayname').val();
                const type = row.find('.edit-type').val();
                syncEditOptions(row);
                const options = getEditOptions(row);

                // Build form and submit
                const form = $('<form>', {
                    method: 'POST',
                    action: `@Url.Action("UpdateAttribute", "Category", new { Area = "Admin" })`
                });

                form.append($('<input>', { type: 'hidden', name: 'categoryId', value: categoryId }));
                form.append($('<input>', { type: 'hidden', name: 'attributeId', value: attrId }));
                form.append($('<input>', { type: 'hidden', name: 'Name', value: name }));
                form.append($('<input>', { type: 'hidden', name: 'DisplayName', value: displayName }));
                form.append($('<input>', { type: 'hidden', name: 'Type', value: type }));

                // Add options if dropdown
                if (type === 'Dropdown' && options.length > 0) {
                    options.forEach((opt, idx) => {
                        form.append($('<input>', { type: 'hidden', name: `Options[${idx}]`, value: opt }));
                    });
                }

                // Add AntiForgeryToken
                const token = $('form input[name="__RequestVerificationToken"]').val();
                if (token) {
                    form.append($('<input>', { type: 'hidden', name: '__RequestVerificationToken', value: token }));
                }

                $('body').append(form);
                form.submit();
            });

            // Delete existing attribute
            $(document).on('click', '.btn-delete-existing', function() {
                const attrName = $(this).data('attr-name');
                const categoryId = $(this).data('category-id');
                const attrId = $(this).data('attr-id');

                if (!confirm(`"${attrName}" özelliğini silmek istediğinize emin misiniz?\n\nBu özellik, bu kategori ve alt kategorilerdeki ürünlerin teknik özelliklerinden de kaldırılacak.`)) {
                    return;
                }

                const form = $('<form>', {
                    method: 'POST',
                    action: `@Url.Action("DeleteAttribute", "Category", new { Area = "Admin" })`
                });

                form.append($('<input>', { type: 'hidden', name: 'categoryId', value: categoryId }));
                form.append($('<input>', { type: 'hidden', name: 'attributeId', value: attrId }));

                const token = $('form input[name="__RequestVerificationToken"]').val();
                if (token) {
                    form.append($('<input>', { type: 'hidden', name: '__RequestVerificationToken', value: token }));
                }

                $('body').append(form);
                form.submit();
            });

            toggleHint();
        });
    </script>
}
