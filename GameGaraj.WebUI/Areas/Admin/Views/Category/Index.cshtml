@model List<GameGaraj.WebUI.Models.Products.CategoryViewModel>
@{
    ViewData["Title"] = "Kategoriler";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Kategoriler</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Create" class="btn btn-sm btn-outline-primary">
            <i class="fas fa-plus"></i> Yeni Kategori
        </a>
    </div>
</div>

<style>
    .tree-table .folder-icon { width: 20px; text-align: center; }
    .tree-table .chevron-toggle { 
        cursor: pointer; 
        transition: transform 0.2s; 
        width: 20px;
        display: inline-block;
        text-align: center;
    }
    .tree-table .collapsed .chevron-toggle { transform: rotate(-90deg); }
    
    /* Tree Lines */
    .tree-row { position: relative; }
    .tree-line {
        position: absolute;
        left: 2.5rem;
        top: 0;
        bottom: 0;
        width: 1px;
        background-color: #dee2e6;
    }
    .tree-node {
        position: relative;
        display: flex;
        align-items: center;
    }
    .tree-node::before {
        content: "";
        position: absolute;
        left: -1.2rem;
        top: 50%;
        width: 1rem;
        height: 1px;
        background-color: #dee2e6;
    }
    
    .table-hover tbody tr:hover {
        background-color: rgba(0,123,255,0.03);
    }
    
    .category-level-0 { background-color: #f8f9fa; }
    .category-level-0:hover { background-color: #f1f3f5; }
</style>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table tree-table align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 border-0" style="width: 50%">Kategori Hiyerarşisi</th>
                        <th class="py-3 border-0 text-center" style="width: 25%">Ana Sayfada Göster</th>
                        <th class="py-3 border-0 text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody id="categoryTreeBody">
                    @foreach (var item in Model)
                    {
                        @await Html.PartialAsync("_CategoryRow", (item, 0, ""))
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).on('click', '.chevron-toggle', function() {
            const row = $(this).closest('tr');
            const id = row.data('id');
            const isCollapsed = row.hasClass('collapsed');
            
            if (isCollapsed) {
                row.removeClass('collapsed');
                $(`tr[data-parent-id="${id}"]`).fadeIn(100);
            } else {
                row.addClass('collapsed');
                collapseRecursive(id);
            }
        });

        function collapseRecursive(parentId) {
            const children = $(`tr[data-parent-id="${parentId}"]`);
            children.each(function() {
                const childId = $(this).data('id');
                $(this).hide().addClass('collapsed');
                collapseRecursive(childId);
            });
        }

        $(document).on('change', '.toggle-show-home', function () {
            const id = $(this).data('id');
            const isChecked = $(this).is(':checked');

            $.ajax({
                url: '@Url.Action("ToggleShowOnHome", "Category", new { area = "Admin" })',
                type: 'POST',
                data: { id: id },
                success: function (res) {
                    if (res.success) {
                        // Toast or alert could be shown here
                    } else {
                        alert(res.message);
                        // revert
                        $(`input[data-id="${id}"]`).prop('checked', !isChecked);
                    }
                },
                error: function () {
                    alert('Bir hata oluştu.');
                    $(`input[data-id="${id}"]`).prop('checked', !isChecked);
                }
            });
        });

        $(document).on('click', '.delete-category-btn', function () {
            if (!confirm('Bu kategoriyi silmek istediğinize emin misiniz? Altındaki ürünler Kategorisiz alanına taşınacaktır.')) {
                return;
            }

            const btn = $(this);
            const id = btn.data('id');
            const row = btn.closest('tr');

            // Disable button to prevent double-clicks
            btn.prop('disabled', true);

            $.ajax({
                url: '@Url.Action("Delete", "Category", new { area = "Admin" })',
                type: 'POST',
                data: { id: id },
                success: function (res) {
                    if (res.success) {
                        // Remove the row visually
                        row.fadeOut(300, function() {
                            $(this).remove();
                        });
                        // Remove children recursively
                        $(`tr[data-parent-id="${id}"]`).fadeOut(300, function() {
                             $(this).remove();
                        });
                        // Optional toast could go here
                    } else {
                        alert(res.message);
                        btn.prop('disabled', false);
                    }
                },
                error: function () {
                    alert('Kategori silinirken bir sunucu hatası oluştu.');
                    btn.prop('disabled', false);
                }
            });
        });
    </script>
}
