@model List<GameGaraj.WebUI.Models.Products.ProductViewModel>
@{
    ViewData["Title"] = "Ürünler";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Ürünler</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Create" class="btn btn-sm btn-outline-primary">
            <i class="fas fa-plus"></i> Yeni Ürün
        </a>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th>Resim</th>
                <th>Ad</th>
                <th>Fiyat</th>
                <th>Stok</th>
                <th>Kategori</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <img src="@item.FirstImageUrl" alt="@item.Name" width="50" class="img-thumbnail" />
                    </td>
                    <td>@item.Name</td>
                    <td>@item.Price.ToString("C2")</td>
                    <td>@item.Stock</td>
                    <td>@item.CategoryName</td>
                    <td class="d-flex gap-1">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">
                            <i class="fas fa-pen me-1"></i>Düzenle
                        </a>
                        <form asp-action="Delete" method="post"
                            onsubmit="return confirm('Bu ürünü silmek istediğinize emin misiniz?');">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="fas fa-trash me-1"></i>Sil
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
