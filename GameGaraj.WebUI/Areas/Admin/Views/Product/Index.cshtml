@model List<GameGaraj.WebUI.Models.Products.ProductViewModel>
@{
    ViewData["Title"] = "Ürünler";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Ürünler</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-area="Admin" asp-controller="Product" asp-action="Create" class="btn btn-sm btn-outline-primary">
            <i class="fas fa-plus"></i> Yeni Ürün
        </a>
    </div>
</div>

<div class="table-responsive">
    <form id="antiForgeryForm" class="d-none">
        @Html.AntiForgeryToken()
    </form>

    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th style="width: 120px;">Resim</th>
                <th>Ürün Bilgisi</th>
                <th style="width: 150px;">Fiyat</th>
                <th style="width: 100px;">Stok</th>
                <th style="width: 130px;">Showcase</th>
                <th style="width: 150px;">Kategori</th>
                <th style="width: 200px;">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <div class="product-img-container">
                            <img src="@item.FirstImageUrl" alt="@item.Name" class="product-list-img" />
                        </div>
                    </td>
                    <td>
                        <div class="fw-bold">@item.Name</div>
                        <small class="text-muted d-block text-truncate" style="max-width: 300px;">@item.Id</small>
                    </td>
                    <td class="fw-bold text-primary">@item.Price.ToString("C2")</td>
                    <td>
                        <span class="badge @(item.Stock > 0 ? "bg-success" : "bg-danger")">
                            @item.Stock
                        </span>
                    </td>
                    <td>
                        <div class="form-check form-switch m-0">
                            <input class="form-check-input js-featured-switch"
                                   type="checkbox"
                                   role="switch"
                                   title="Showcase"
                                   data-product-id="@item.Id"
                                   @(item.IsFeatured ? "checked" : "") />
                        </div>
                    </td>
                    <td>@item.CategoryName</td>
                    <td>
                        <div class="btn-group">
                            <a asp-area="Admin" asp-controller="Product" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-edit"></i> Düzenle
                            </a>
                            <form asp-area="Admin" asp-controller="Product" asp-action="Delete" method="post" class="d-inline"
                                  onsubmit="return confirm('Bu ürünü silmek istediğinize emin misiniz?');">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    .product-img-container {
        width: 100px;
        height: 100px;
        overflow: hidden;
        border-radius: 8px;
        border: 1px solid #dee2e6;
        background-color: #f8f9fa;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .product-list-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .table.align-middle td {
        padding-top: 1rem;
        padding-bottom: 1rem;
    }

    .js-featured-switch {
        cursor: pointer;
    }
</style>

@section Scripts {
    <script>
        $(document).on('change', '.js-featured-switch', function () {
            const checkbox = $(this);
            const previousValue = !checkbox.prop('checked');
            const token = $('#antiForgeryForm input[name="__RequestVerificationToken"]').val();

            checkbox.prop('disabled', true);

            $.ajax({
                url: '@Url.Action("ToggleFeatured", "Product", new { area = "Admin" })',
                method: 'POST',
                headers: {
                    'RequestVerificationToken': token
                },
                data: {
                    id: checkbox.data('product-id'),
                    isFeatured: checkbox.prop('checked')
                }
            }).done(function (response) {
                if (!response || !response.success) {
                    checkbox.prop('checked', previousValue);
                    alert('Showcase durumu güncellenemedi.');
                }
            }).fail(function () {
                checkbox.prop('checked', previousValue);
                alert('Showcase durumu güncellenirken hata oluştu.');
            }).always(function () {
                checkbox.prop('disabled', false);
            });
        });
    </script>
}
