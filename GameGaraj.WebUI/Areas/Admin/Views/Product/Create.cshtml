@model GameGaraj.WebUI.Models.Products.ProductCreateInput
@{
    ViewData["Title"] = "Yeni Ürün";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Yeni Ürün Ekle</h1>
</div>

<form asp-area="Admin" asp-controller="Product" asp-action="Create" method="post" enctype="multipart/form-data" id="createProductForm">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>
    <input type="hidden" asp-for="CoverImageKey" id="coverImageKey" />
    <div class="row">
        <div class="col-md-8">
            <div class="row">
                <div class="col-md-8 mb-3">
                    <label asp-for="Name" class="form-label">Ürün Adı</label>
                    <input asp-for="Name" class="form-control" required />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Brand" class="form-label">Marka</label>
                    <input asp-for="Brand" class="form-control js-brand-input" list="brandSuggestions" placeholder="Örn: ASUS" autocomplete="off" />
                    <datalist id="brandSuggestions"></datalist>
                    <div class="form-text">Listede yoksa elle yazabilirsiniz.</div>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label">Kategori</label>
                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories" id="categoryIdSelect">
                    <option value="">-- Kategori Seçiniz --</option>
                </select>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Price" class="form-label">Fiyat</label>
                    <input asp-for="Price" type="number" step="0.01" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Stock" class="form-label">Stok</label>
                    <input asp-for="Stock" type="number" class="form-control" required />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Açıklama</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="Photos" class="form-label">Ürün Fotoğrafları (En fazla 5 adet, Max 5MB)</label>
                <input type="file" name="Photos" id="newPhotosInput" class="form-control" multiple
                    accept="image/jpeg, image/png, image/webp" />
                <div class="form-text">Mevcut limitler PhotoStock servisi tarafından belirlenmektedir. Sadece jpg, png,
                    webp.</div>

                <div class="mt-3">
                    <label class="form-label fw-bold d-none" id="newPhotosPreviewLabel">Yeni Yüklenecek Fotoğrafların
                        Önizlemesi</label>
                    <div class="row g-2" id="newPhotosPreviewContainer">
                        <!-- Preview images will be generated here by JS -->
                    </div>
                </div>
            </div>

            <div class="mb-3 form-check form-switch">
                <input asp-for="IsFeatured" class="form-check-input" type="checkbox" id="isFeaturedSwitch">
                <label class="form-check-label fw-bold" for="isFeaturedSwitch">Öne Çıkan Ürün (Showcase)</label>
                <div class="form-text">Bu ürünü ana sayfadaki vitrinde gösterir.</div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Teknik Özellikler</h5>
                </div>
                <div class="card-body" id="dynamicSpecsContainer">
                    <p class="text-muted small">Kategori seçildiğinde özellikler burada görünecektir.</p>
                </div>
            </div>

        </div>
    </div>

    <hr class="my-4">

    <button class="btn btn-primary btn-lg" type="submit">Kaydet</button>
    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-secondary btn-lg">İptal</a>
</form>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <style>
        .photo-preview-card {
            width: 110px;
            height: 110px;
            position: relative;
            border: 2px dashed #dee2e6;
            border-radius: 8px;
            overflow: hidden;
            cursor: grab;
            transition: all 0.2s ease;
        }
        .photo-preview-card:hover {
            border-color: #0d6efd;
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }
        .photo-preview-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .photo-preview-card .delete-btn {
            position: absolute;
            top: 4px;
            right: 4px;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: rgba(220, 53, 69, 0.9);
            color: white;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            cursor: pointer;
            transition: background 0.2s;
            z-index: 10;
        }
        .photo-preview-card .delete-btn:hover {
            background: rgba(186, 35, 50, 1);
        }
        .photo-preview-card .vitrin-badge {
            position: absolute;
            bottom: 4px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 10px;
            padding: 2px 6px;
            border-radius: 4px;
            background: #198754;
            color: white;
            font-weight: bold;
            pointer-events: none;
            z-index: 10;
        }
        .photo-preview-card .drag-handle {
            position: absolute;
            top: 4px;
            left: 4px;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: rgba(0, 0, 0, 0.5);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            cursor: grab;
            z-index: 10;
        }
    </style>
    <script>
        $(document).ready(function () {
            $.getJSON('/data/brands.json', function (brands) {
                var dataList = $('#brandSuggestions');
                dataList.empty();
                (brands || [])
                    .filter(function (brand) { return typeof brand === 'string' && brand.trim().length > 0; })
                    .sort(function (a, b) { return a.localeCompare(b, 'tr', { sensitivity: 'base' }); })
                    .forEach(function (brand) {
                        dataList.append($('<option>').attr('value', brand));
                    });
            });

            $('#categoryIdSelect').change(function () {
                var categoryId = $(this).val();
                var container = $('#dynamicSpecsContainer');

                if (!categoryId) {
                    container.html('<p class="text-muted small">Kategori seçildiğinde özellikler burada görünecektir.</p>');
                    return;
                }

                container.html('<div class="d-flex justify-content-center"><div class="spinner-border text-primary" role="status"></div></div>');

                $.get('/Admin/Product/GetCategoryAttributes?id=' + categoryId, function (data) {
                    container.empty();

                    if (!data || data.length === 0) {
                        container.html('<div class="alert alert-info py-2">Bu kategori için tanımlı özellik yok.</div>');
                        return;
                    }

                    $.each(data, function (index, item) {
                        let html = '';

                        if (item.type === 'Dropdown' && item.options && item.options.length > 0) {
                            let optionsHtml = '';
                            $.each(item.options, function (i, opt) {
                                optionsHtml += `<option value="${opt}">${opt}</option>`;
                            });

                            html = `
                                        <div class="mb-3">
                                            <label class="form-label font-monospace small fw-bold text-primary">${item.displayName}</label>
                                            <select name="Specs[${item.name}]" class="form-select border-primary shadow-sm bg-light">
                                                <option value="">Seçiniz...</option>
                                                ${optionsHtml}
                                            </select>
                                        </div>
                                    `;
                        } else {
                            let inputType = item.type === 'Number' ? 'number' : 'text';
                            html = `
                                        <div class="mb-3">
                                            <label class="form-label">${item.displayName}</label>
                                            <input type="${inputType}" name="Specs[${item.name}]" class="form-control" placeholder="${item.displayName} giriniz" />
                                        </div>
                                    `;
                        }
                        container.append(html);
                    });
                }).fail(function () {
                    container.html('<div class="alert alert-danger">Özellikler yüklenirken hata oluştu.</div>');
                });
            });

            // Reordering logic
            var selectedPhotoFiles = [];
            var previewContainer = document.getElementById('newPhotosPreviewContainer');

            // Initialize Sortable
            var sortable = new Sortable(previewContainer, {
                animation: 150,
                handle: '.photo-preview-card',
                onEnd: function () {
                    reorderFilesList();
                    updateCoverBadges();
                }
            });

            function updateCoverBadges() {
                $('.photo-preview-card').each(function (index) {
                    var badge = $(this).find('.vitrin-badge');
                    if (index === 0) {
                        badge.removeClass('d-none');
                    } else {
                        badge.addClass('d-none');
                    }
                });
            }

            function reorderFilesList() {
                var newOrderedList = [];
                $('.photo-preview-card').each(function () {
                    var fileId = $(this).data('file-id');
                    var item = selectedPhotoFiles.find(x => x.id === fileId);
                    if (item) {
                        newOrderedList.push(item);
                    }
                });
                selectedPhotoFiles = newOrderedList;
            }

            function renderCreatePhotoPreviews() {
                var previewContainerJq = $('#newPhotosPreviewContainer');
                var previewLabel = $('#newPhotosPreviewLabel');
                previewContainerJq.empty();

                if (selectedPhotoFiles.length === 0) {
                    previewLabel.addClass('d-none');
                    return;
                }

                previewLabel.removeClass('d-none');

                selectedPhotoFiles.forEach((item, index) => {
                    var file = item.file;
                    if (!file.type.startsWith('image/')) return;

                    var reader = new FileReader();
                    reader.onload = function(e) {
                        var html = `
                            <div class="col-auto photo-preview-card" data-file-id="${item.id}">
                                <div class="grab-handle"><i class="fas fa-arrows-alt"></i></div>
                                <img src="${e.target.result}" alt="Preview">
                                <span class="vitrin-badge ${index === 0 ? '' : 'd-none'}">Vitrin</span>
                                <button type="button" class="delete-btn btn-remove-preview" data-file-id="${item.id}" title="Sil">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                        `;
                        previewContainerJq.append(html);
                    }
                    reader.readAsDataURL(file);
                });
            }

            // Remove preview handler
            $(document).on('click', '.btn-remove-preview', function (e) {
                e.stopPropagation();
                var fileId = $(this).data('file-id');
                selectedPhotoFiles = selectedPhotoFiles.filter(x => x.id !== fileId);
                $(`.photo-preview-card[data-file-id="${fileId}"]`).remove();
                updateCoverBadges();
                reorderFilesList();
                if (selectedPhotoFiles.length === 0) {
                    $('#newPhotosPreviewLabel').addClass('d-none');
                    $('#newPhotosInput').val('');
                }
            });

            // New Photo Preview Logic
            $('#newPhotosInput').on('change', function() {
                if (this.files && this.files.length > 0) {
                    if (this.files.length > 5) {
                        alert('Bir ürüne en fazla 5 fotoğraf yükleyebilirsiniz.');
                        $(this).val('');
                        selectedPhotoFiles = [];
                        $('#newPhotosPreviewContainer').empty();
                        $('#newPhotosPreviewLabel').addClass('d-none');
                        return;
                    }

                    selectedPhotoFiles = Array.from(this.files).map((file, i) => {
                        return {
                            id: 'file_' + Date.now() + '_' + i,
                            file: file
                        };
                    });
                    renderCreatePhotoPreviews();
                } else {
                    selectedPhotoFiles = [];
                    $('#newPhotosPreviewContainer').empty();
                    $('#newPhotosPreviewLabel').addClass('d-none');
                }
            });

            // On Form Submit, bind sorted files to the input element
            $('#createProductForm').on('submit', function (e) {
                if (selectedPhotoFiles.length > 0) {
                    var dataTransfer = new DataTransfer();
                    selectedPhotoFiles.forEach(function (item) {
                        dataTransfer.items.add(item.file);
                    });
                    document.getElementById('newPhotosInput').files = dataTransfer.files;
                }
            });
        });
    </script>
}
