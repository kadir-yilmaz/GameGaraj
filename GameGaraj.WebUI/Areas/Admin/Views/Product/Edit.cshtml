@model GameGaraj.WebUI.Models.Products.ProductUpdateInput
@{
    ViewData["Title"] = "Urun Duzenle";
    var serializedSpecs = System.Text.Json.JsonSerializer.Serialize(Model.Specs ?? new Dictionary<string, string>());
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Urun Duzenle</h1>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Product" asp-action="Index">Urunler</a></li>
            <li class="breadcrumb-item active" aria-current="page">Duzenle</li>
        </ol>
    </nav>
</div>

<form asp-area="Admin" asp-controller="Product" asp-action="Edit" method="post" id="editProductForm" enctype="multipart/form-data">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="CoverImageKey" id="coverImageKey" />



    <div class="row">
        <div class="col-md-8">
            <div class="row">
                <div class="col-md-8 mb-3">
                    <label asp-for="Name" class="form-label">Urun Adi</label>
                    <input asp-for="Name" class="form-control" required />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Brand" class="form-label">Marka</label>
                    <input asp-for="Brand" class="form-control js-brand-input" list="brandSuggestions" placeholder="Orn: ASUS" autocomplete="off" />
                    <datalist id="brandSuggestions"></datalist>
                    <div class="form-text">Listede yoksa elle yazabilirsiniz.</div>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label">Kategori</label>
                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories" id="categoryIdSelect">
                    <option value="">-- Kategori Seciniz --</option>
                </select>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Price" class="form-label">Fiyat</label>
                    <input asp-for="Price" type="number" step="0.01" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Stock" class="form-label">Stok</label>
                    <input asp-for="Stock" type="number" class="form-control" required />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Aciklama</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Urun Fotograflari (Surukleyip Siralayabilirsiniz)</label>
                <div class="row g-2 mb-2" id="photosContainer">
                    @if (Model.ImageUrls != null)
                    {
                        for (int i = 0; i < Model.ImageUrls.Count; i++)
                        {
                            <div class="col-auto photo-preview-card" data-type="existing" data-value="@Model.ImageUrls[i]">
                                <div class="grab-handle"><i class="fas fa-arrows-alt"></i></div>
                                <img src="@Model.ImageUrls[i]" alt="Product Image"
                                     onerror="this.onerror=null;this.src='@GameGaraj.WebUI.Models.Products.ProductViewModel.DefaultImageUrl';" />
                                <span class="vitrin-badge @(i == 0 ? "" : "d-none")">Vitrin</span>
                                <button type="button" class="delete-btn btn-remove-existing" title="Sil">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                        }
                    }
                </div>
                <div class="form-text text-warning mt-1" id="photoLimitText">
                    Su an <span id="currentPhotoCount">@(Model.ImageUrls?.Count ?? 0)</span> adet fotograf var.
                    Maksimum 5 fotograf limitine ulasmak icin <span id="remainingPhotoCount">@(5 - (Model.ImageUrls?.Count ?? 0))</span> adet daha yukleyebilirsiniz.
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Photos" class="form-label">Yeni Fotograf Ekle (Max 5MB)</label>
                <input type="file" name="Photos" id="newPhotosInput" class="form-control" multiple accept="image/jpeg, image/png, image/webp" />
                <div class="form-text">Sadece jpg, png ve webp dosyalari desteklenir.</div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3 form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" id="isActiveSwitch">
                        <label class="form-check-label fw-bold" for="isActiveSwitch">Aktif</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3 form-check form-switch">
                        <input asp-for="IsFeatured" class="form-check-input" type="checkbox" id="isFeaturedSwitch">
                        <label class="form-check-label fw-bold" for="isFeaturedSwitch">One Cikan Urun (Showcase)</label>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Teknik Ozellikler</h5>
                </div>
                <div class="card-body" id="dynamicSpecsContainer">
                    @if (Model.Specs != null && Model.Specs.Any())
                    {
                        @foreach (var spec in Model.Specs)
                        {
                            <div class="mb-3">
                                <label class="form-label font-monospace small fw-bold text-primary">@spec.Key</label>
                                <input type="text" name="Specs[@spec.Key]" class="form-control" value="@spec.Value" />
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted small">Bu urune ait teknik ozellik yok.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <hr class="my-4">

    <button class="btn btn-primary btn-lg" type="submit">
        <i class="fas fa-save me-2"></i>Guncelle
    </button>
    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-secondary btn-lg">Iptal</a>
</form>



@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <style>
        .photo-preview-card {
            width: 110px;
            height: 110px;
            position: relative;
            border: 2px dashed #dee2e6;
            border-radius: 8px;
            overflow: hidden;
            cursor: grab;
            transition: all 0.2s ease;
        }
        .photo-preview-card:hover {
            border-color: #0d6efd;
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }
        .photo-preview-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .photo-preview-card .delete-btn {
            position: absolute;
            top: 4px;
            right: 4px;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: rgba(220, 53, 69, 0.9);
            color: white;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            cursor: pointer;
            transition: background 0.2s;
            z-index: 10;
        }
        .photo-preview-card .delete-btn:hover {
            background: rgba(186, 35, 50, 1);
        }
        .photo-preview-card .vitrin-badge {
            position: absolute;
            bottom: 4px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 10px;
            padding: 2px 6px;
            border-radius: 4px;
            background: #198754;
            color: white;
            font-weight: bold;
            pointer-events: none;
            z-index: 10;
        }
        .photo-preview-card .drag-handle {
            position: absolute;
            top: 4px;
            left: 4px;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: rgba(0, 0, 0, 0.5);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            cursor: grab;
            z-index: 10;
        }
    </style>
    <script>
        $(document).ready(function () {
            const existingSpecs = @Html.Raw(serializedSpecs);

            function escapeHtml(value) {
                return $('<div>').text(value ?? '').html();
            }

            function renderDynamicSpecs(categoryId) {
                var container = $('#dynamicSpecsContainer');

                if (!categoryId) {
                    container.html('<p class="text-muted small">Kategori secildiginde ozellikler burada gorunecektir.</p>');
                    return;
                }

                container.html('<div class="d-flex justify-content-center"><div class="spinner-border text-primary" role="status"></div></div>');

                $.get('/Admin/Product/GetCategoryAttributes?id=' + categoryId, function (data) {
                    container.empty();

                    if (!data || data.length === 0) {
                        container.html('<div class="alert alert-info py-2">Bu kategori icin tanimli ozellik yok.</div>');
                        return;
                    }

                    $.each(data, function (index, item) {
                        const currentValue = existingSpecs[item.name] || '';
                        let html = '';

                        if (item.type === 'Dropdown' && item.options && item.options.length > 0) {
                            let optionsHtml = '';

                            $.each(item.options, function (i, opt) {
                                const selected = currentValue === opt ? 'selected' : '';
                                optionsHtml += `<option value="${escapeHtml(opt)}" ${selected}>${escapeHtml(opt)}</option>`;
                            });

                            html = `
                                <div class="mb-3">
                                    <label class="form-label font-monospace small fw-bold text-primary">${escapeHtml(item.displayName)}</label>
                                    <select name="Specs[${item.name}]" class="form-select border-primary shadow-sm bg-light">
                                        <option value="">Seciniz...</option>
                                        ${optionsHtml}
                                    </select>
                                </div>
                            `;
                        } else {
                            let inputType = item.type === 'Number' ? 'number' : 'text';
                            html = `
                                <div class="mb-3">
                                    <label class="form-label">${escapeHtml(item.displayName)}</label>
                                    <input type="${inputType}" name="Specs[${item.name}]" class="form-control" placeholder="${escapeHtml(item.displayName)} giriniz" value="${escapeHtml(currentValue)}" />
                                </div>
                            `;
                        }

                        container.append(html);
                    });
                }).fail(function () {
                    container.html('<div class="alert alert-danger">Ozellikler yuklenirken hata olustu.</div>');
                });
            }

            $('#categoryIdSelect').change(function () {
                renderDynamicSpecs($(this).val());
            });

            renderDynamicSpecs($('#categoryIdSelect').val());

            // Image management variables
            var selectedPhotoFiles = [];
            var photosContainer = document.getElementById('photosContainer');

            // Initialize Sortable
            var sortable = new Sortable(photosContainer, {
                animation: 150,
                handle: '.photo-preview-card',
                onEnd: function () {
                    updatePhotoCounts();
                }
            });

            function updatePhotoCounts() {
                var count = $('.photo-preview-card').length;
                $('#currentPhotoCount').text(count);
                $('#remainingPhotoCount').text(5 - count);

                $('.photo-preview-card').each(function (index) {
                    var badge = $(this).find('.vitrin-badge');
                    if (index === 0) {
                        badge.removeClass('d-none');
                    } else {
                        badge.addClass('d-none');
                    }
                });
            }

            // Remove existing photo
            $(document).on('click', '.btn-remove-existing', function () {
                $(this).closest('.photo-preview-card').remove();
                updatePhotoCounts();
            });

            // Remove new photo
            $(document).on('click', '.btn-remove-new', function () {
                var fileId = $(this).data('file-id');
                selectedPhotoFiles = selectedPhotoFiles.filter(x => x.id !== fileId);
                $(`.photo-preview-card[data-value="${fileId}"]`).remove();
                updatePhotoCounts();
                if (selectedPhotoFiles.length === 0) {
                    $('#newPhotosInput').val('');
                }
            });

            function renderNewPhotoPreviews() {
                selectedPhotoFiles.forEach((item, index) => {
                    // Check if already in container
                    if ($(`.photo-preview-card[data-value="${item.id}"]`).length > 0) return;

                    var file = item.file;
                    if (!file.type.startsWith('image/')) return;

                    var reader = new FileReader();
                    reader.onload = function(e) {
                        var html = `
                            <div class="col-auto photo-preview-card" data-type="new" data-value="${item.id}">
                                <div class="grab-handle"><i class="fas fa-arrows-alt"></i></div>
                                <img src="${e.target.result}" alt="Preview">
                                <span class="vitrin-badge d-none">Vitrin</span>
                                <button type="button" class="delete-btn btn-remove-new" data-file-id="${item.id}" title="Sil">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                        `;
                        $('#photosContainer').append(html);
                        updatePhotoCounts();
                    }
                    reader.readAsDataURL(file);
                });
            }

            // New Photos Change
            $('#newPhotosInput').on('change', function () {
                if (this.files && this.files.length > 0) {
                    var currentCount = $('.photo-preview-card').length;
                    var spaceLeft = 5 - currentCount;

                    if (this.files.length > spaceLeft) {
                        alert('Maksimum 5 fotoğraf sınırını aşıyorsunuz. En fazla ' + spaceLeft + ' adet yeni fotoğraf ekleyebilirsiniz.');
                        $(this).val('');
                        return;
                    }

                    var newFilesMapped = Array.from(this.files).map((file, i) => {
                        return {
                            id: 'file_' + Date.now() + '_' + i,
                            file: file
                        };
                    });

                    selectedPhotoFiles = selectedPhotoFiles.concat(newFilesMapped);
                    renderNewPhotoPreviews();
                }
            });

            // Form Submit Re-ordering
            $('#editProductForm').on('submit', function (e) {
                var dataTransfer = new DataTransfer();
                var imageOrderIndex = 0;

                // Remove any previously appended image order hidden inputs
                $('.dynamic-image-order-input').remove();

                $('.photo-preview-card').each(function () {
                    var type = $(this).data('type');
                    var val = $(this).data('value');

                    if (type === 'existing') {
                        $('<input>').attr({
                            type: 'hidden',
                            name: 'ImageOrder[' + imageOrderIndex + ']',
                            value: 'existing:' + val,
                            class: 'dynamic-image-order-input'
                        }).appendTo('#editProductForm');
                        imageOrderIndex++;
                    } else if (type === 'new') {
                        var fileItem = selectedPhotoFiles.find(x => x.id === val);
                        if (fileItem) {
                            dataTransfer.items.add(fileItem.file);

                            $('<input>').attr({
                                type: 'hidden',
                                name: 'ImageOrder[' + imageOrderIndex + ']',
                                value: 'new:' + fileItem.file.name,
                                class: 'dynamic-image-order-input'
                            }).appendTo('#editProductForm');
                            imageOrderIndex++;
                        }
                    }
                });

                // Assign the sorted files list to the actual file input
                if (dataTransfer.files.length > 0) {
                    document.getElementById('newPhotosInput').files = dataTransfer.files;
                }
            });
        });
    </script>
}
