@model GameGaraj.WebUI.Models.Products.ProductUpdateInput
@{
    ViewData["Title"] = "Ürün Düzenle";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Ürün Düzenle</h1>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-action="Index">Ürünler</a></li>
            <li class="breadcrumb-item active" aria-current="page">Düzenle</li>
        </ol>
    </nav>
</div>

<form asp-action="Edit" method="post" id="editProductForm" enctype="multipart/form-data">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>
    <input type="hidden" asp-for="Id" />
    <!-- Hidden inputs for existing ImageUrls will be appended here by JS or Razor -->
    @if (Model.ImageUrls != null)
    {
        for (int i = 0; i < Model.ImageUrls.Count; i++)
        {
            <input type="hidden" name="ImageUrls" value="@Model.ImageUrls[i]" class="existing-image-input" data-index="@i" />
        }
    }

    <div class="row">
        <div class="col-md-8">
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Ürün Adı</label>
                <input asp-for="Name" class="form-control" required />
            </div>

            <div class="mb-3">
                <label asp-for="Brand" class="form-label">Marka</label>
                <input asp-for="Brand" class="form-control" placeholder="Örn: AMD, MSI, ASUS" />
            </div>

            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label">Kategori</label>
                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories" id="categoryIdSelect">
                    <option value="">-- Kategori Seçiniz --</option>
                </select>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Price" class="form-label">Fiyat</label>
                    <input asp-for="Price" type="number" step="0.01" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Stock" class="form-label">Stok</label>
                    <input asp-for="Stock" type="number" class="form-control" required />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Açıklama</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            </div>

            <!-- Existing Photos Management -->
            <div class="mb-3">
                <label class="form-label fw-bold">Mevcut Fotoğraflar</label>
                @if (Model.ImageUrls != null && Model.ImageUrls.Any())
                {
                    <div class="row g-2" id="existingPhotosContainer">
                        @for (int i = 0; i < Model.ImageUrls.Count; i++)
                        {
                            <div class="col-auto position-relative photo-item" data-index="@i">
                                <img src="@Model.ImageUrls[i]" alt="Product Image" class="img-thumbnail"
                                    style="height: 100px; width: 100px; object-fit: cover;" />
                                <button type="button"
                                    class="btn btn-danger btn-sm position-absolute top-0 end-0 m-1 rounded-circle btn-remove-photo"
                                    data-index="@i" title="Fotoğrafı Sil">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                        }
                    </div>
                    <div class="form-text text-warning mt-1" id="photoLimitText">
                        Şu an <span id="currentPhotoCount">@Model.ImageUrls.Count</span> adet fotoğraf var.
                        Maksimum (5) fotoğrafa ulaşmak için <span id="remainingPhotoCount">@(5 -
                        Model.ImageUrls.Count)</span> adet daha yükleyebilirsiniz.
                    </div>
                }
                else
                {
                    <div class="alert alert-secondary py-2">Bu ürüne ait henüz fotoğraf yok.</div>
                }
            </div>

            <!-- New Photos Upload -->
            <div class="mb-3">
                <label asp-for="Photos" class="form-label">Yeni Fotoğraf Ekle (Max 5MB)</label>
                <input type="file" name="Photos" id="newPhotosInput" class="form-control" multiple
                    accept="image/jpeg, image/png, image/webp" />
                <div class="form-text">Mevcut limitler PhotoStock servisi tarafından belirlenmektedir. Sadece jpg, png,
                    webp.</div>
                
                <div class="mt-3">
                    <label class="form-label fw-bold d-none" id="newPhotosPreviewLabel">Yeni Yüklenecek Fotoğrafların Önizlemesi</label>
                    <div class="row g-2" id="newPhotosPreviewContainer">
                        <!-- Preview images will be generated here by JS -->
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3 form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" id="isActiveSwitch">
                        <label class="form-check-label fw-bold" for="isActiveSwitch">Aktif</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3 form-check form-switch">
                        <input asp-for="IsFeatured" class="form-check-input" type="checkbox" id="isFeaturedSwitch">
                        <label class="form-check-label fw-bold" for="isFeaturedSwitch">Öne Çıkan Ürün (Showcase)</label>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Teknik Özellikler</h5>
                </div>
                <div class="card-body" id="dynamicSpecsContainer">
                    @if (Model.Specs != null && Model.Specs.Any())
                    {
                        @foreach (var spec in Model.Specs)
                        {
                            <div class="mb-3">
                                <label class="form-label font-monospace small fw-bold text-primary">@spec.Key</label>
                                <input type="text" name="Specs[@spec.Key]" class="form-control" value="@spec.Value" />
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted small">Bu ürüne ait teknik özellik yok.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <hr class="my-4">

    <button class="btn btn-primary btn-lg" type="submit">
        <i class="fas fa-save me-2"></i>Güncelle
    </button>
    <a asp-action="Index" class="btn btn-secondary btn-lg">İptal</a>
</form>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#categoryIdSelect').change(function () {
                var categoryId = $(this).val();
                var container = $('#dynamicSpecsContainer');

                if (!categoryId) {
                    container.html('<p class="text-muted small">Kategori seçildiğinde özellikler burada görünecektir.</p>');
                    return;
                }

                container.html('<div class="d-flex justify-content-center"><div class="spinner-border text-primary" role="status"></div></div>');

                $.get('/Admin/Product/GetCategoryAttributes?id=' + categoryId, function (data) {
                    container.empty();

                    if (!data || data.length === 0) {
                        container.html('<div class="alert alert-info py-2">Bu kategori için tanımlı özellik yok.</div>');
                        return;
                    }

                    $.each(data, function (index, item) {
                        let html = '';

                        if (item.type === 'Dropdown' && item.options && item.options.length > 0) {
                            let optionsHtml = '';
                            $.each(item.options, function (i, opt) {
                                optionsHtml += `<option value="${opt}">${opt}</option>`;
                            });

                            html = `
                                    <div class="mb-3">
                                        <label class="form-label font-monospace small fw-bold text-primary">${item.displayName}</label>
                                        <select name="Specs[${item.name}]" class="form-select border-primary shadow-sm bg-light">
                                            <option value="">Seçiniz...</option>
                                            ${optionsHtml}
                                        </select>
                                    </div>
                                `;
                        } else {
                            let inputType = item.type === 'Number' ? 'number' : 'text';
                            html = `
                                    <div class="mb-3">
                                        <label class="form-label">${item.displayName}</label>
                                        <input type="${inputType}" name="Specs[${item.name}]" class="form-control" placeholder="${item.displayName} giriniz" />
                                    </div>
                                `;
                        }
                        container.append(html);
                    });
                }).fail(function () {
                    container.html('<div class="alert alert-danger">Özellikler yüklenirken hata oluştu.</div>');
                });
            });

            // Photo Removal Logic
            $('.btn-remove-photo').click(function () {
                var index = $(this).data('index');

                // Remove the photo UI item
                $(`.photo-item[data-index="${index}"]`).remove();

                // Remove the hidden input so it's not sent to the server
                $(`.existing-image-input[data-index="${index}"]`).remove();

                // Update counts
                var currentCount = $('.existing-image-input').length;
                $('#currentPhotoCount').text(currentCount);
                $('#remainingPhotoCount').text(5 - currentCount);

                if (currentCount === 0) {
                    $('#existingPhotosContainer').parent().append('<div class="alert alert-secondary py-2">Tüm mevcut fotoğrafları sildiniz. Yeni fotoğraf ekleyebilirsiniz.</div>');
                    $('#photoLimitText').hide();
                }
            });

            // New Photo Preview Logic
            $('#newPhotosInput').on('change', function() {
                var previewContainer = $('#newPhotosPreviewContainer');
                var previewLabel = $('#newPhotosPreviewLabel');
                previewContainer.empty();
                
                if (this.files && this.files.length > 0) {
                    var remainingSlots = 5 - $('.existing-image-input').length;
                    
                    if (this.files.length > remainingSlots) {
                        alert('Maksimum 5 fotoğraf limitine ulaştınız. En fazla ' + remainingSlots + ' yeni fotoğraf yükleyebilirsiniz.');
                        $(this).val('');
                        previewLabel.addClass('d-none');
                        return;
                    }

                    previewLabel.removeClass('d-none');
                    
                    Array.from(this.files).forEach(file => {
                        if (file.type.startsWith('image/')) {
                            var reader = new FileReader();
                            reader.onload = function(e) {
                                var html = `
                                    <div class="col-auto">
                                        <img src="${e.target.result}" class="img-thumbnail" style="height: 100px; width: 100px; object-fit: cover;" alt="Preview">
                                    </div>
                                `;
                                previewContainer.append(html);
                            }
                            reader.readAsDataURL(file);
                        }
                    });
                } else {
                    previewLabel.addClass('d-none');
                }
            });
        });
    </script>
}
