@model GameGaraj.WebUI.Models.Products.ProductUpdateInput
@{
    ViewData["Title"] = "Urun Duzenle";
    var serializedSpecs = System.Text.Json.JsonSerializer.Serialize(Model.Specs ?? new Dictionary<string, string>());
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Urun Duzenle</h1>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Product" asp-action="Index">Urunler</a></li>
            <li class="breadcrumb-item active" aria-current="page">Duzenle</li>
        </ol>
    </nav>
</div>

<form asp-area="Admin" asp-controller="Product" asp-action="Edit" method="post" id="editProductForm" enctype="multipart/form-data">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="CoverImageKey" id="coverImageKey" />

    @if (Model.ImageUrls != null)
    {
        for (int i = 0; i < Model.ImageUrls.Count; i++)
        {
            <input type="hidden" name="ImageUrls" value="@Model.ImageUrls[i]" class="existing-image-input" data-index="@i" />
        }
    }

    <div class="row">
        <div class="col-md-8">
            <div class="row">
                <div class="col-md-8 mb-3">
                    <label asp-for="Name" class="form-label">Urun Adi</label>
                    <input asp-for="Name" class="form-control" required />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Brand" class="form-label">Marka</label>
                    <input asp-for="Brand" class="form-control js-brand-input" list="brandSuggestions" placeholder="Orn: ASUS" autocomplete="off" />
                    <datalist id="brandSuggestions"></datalist>
                    <div class="form-text">Listede yoksa elle yazabilirsiniz.</div>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label">Kategori</label>
                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories" id="categoryIdSelect">
                    <option value="">-- Kategori Seciniz --</option>
                </select>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Price" class="form-label">Fiyat</label>
                    <input asp-for="Price" type="number" step="0.01" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Stock" class="form-label">Stok</label>
                    <input asp-for="Stock" type="number" class="form-control" required />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Aciklama</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Mevcut Fotograflar</label>
                @if (Model.ImageUrls != null && Model.ImageUrls.Any())
                {
                    <div class="row g-2" id="existingPhotosContainer">
                        @for (int i = 0; i < Model.ImageUrls.Count; i++)
                        {
                            <div class="col-auto position-relative photo-item" data-index="@i" data-image-url="@Model.ImageUrls[i]">
                                <img src="@Model.ImageUrls[i]" alt="Product Image" class="img-thumbnail"
                                     style="height: 100px; width: 100px; object-fit: cover;"
                                     onerror="this.onerror=null;this.src='@GameGaraj.WebUI.Models.Products.ProductViewModel.DefaultImageUrl';" />
                                <span class="badge bg-primary position-absolute top-0 start-0 m-1 cover-badge @(i == 0 ? "" : "d-none")">Vitrin</span>
                                <button type="button"
                                        class="btn btn-danger btn-sm position-absolute top-0 end-0 m-1 rounded-circle btn-remove-photo"
                                        data-index="@i" title="Fotografi Sil">
                                    <i class="fas fa-times"></i>
                                </button>
                                <button type="button"
                                        class="btn btn-light btn-sm position-absolute bottom-0 start-50 translate-middle-x mb-1 btn-set-cover"
                                        title="Vitrin gorseli yap">
                                    <i class="fas fa-star me-1"></i>Vitrin
                                </button>
                            </div>
                        }
                    </div>
                    <div class="form-text text-warning mt-1" id="photoLimitText">
                        Su an <span id="currentPhotoCount">@Model.ImageUrls.Count</span> adet fotograf var.
                        Maksimum 5 fotograf limitine ulasmak icin <span id="remainingPhotoCount">@(5 - Model.ImageUrls.Count)</span> adet daha yukleyebilirsiniz.
                    </div>
                }
                else
                {
                    <div class="alert alert-secondary py-2">Bu urune ait henuz fotograf yok.</div>
                }
            </div>

            <div class="mb-3">
                <label asp-for="Photos" class="form-label">Yeni Fotograf Ekle (Max 5MB)</label>
                <input type="file" name="Photos" id="newPhotosInput" class="form-control" multiple accept="image/jpeg, image/png, image/webp" />
                <div class="form-text">Sadece jpg, png ve webp dosyalari desteklenir.</div>

                <div class="mt-3">
                    <label class="form-label fw-bold d-none" id="newPhotosPreviewLabel">Yeni Yuklenecek Fotograflarin Onizlemesi</label>
                    <div class="row g-2" id="newPhotosPreviewContainer"></div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3 form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" id="isActiveSwitch">
                        <label class="form-check-label fw-bold" for="isActiveSwitch">Aktif</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3 form-check form-switch">
                        <input asp-for="IsFeatured" class="form-check-input" type="checkbox" id="isFeaturedSwitch">
                        <label class="form-check-label fw-bold" for="isFeaturedSwitch">One Cikan Urun (Showcase)</label>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Teknik Ozellikler</h5>
                </div>
                <div class="card-body" id="dynamicSpecsContainer">
                    @if (Model.Specs != null && Model.Specs.Any())
                    {
                        @foreach (var spec in Model.Specs)
                        {
                            <div class="mb-3">
                                <label class="form-label font-monospace small fw-bold text-primary">@spec.Key</label>
                                <input type="text" name="Specs[@spec.Key]" class="form-control" value="@spec.Value" />
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted small">Bu urune ait teknik ozellik yok.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <hr class="my-4">

    <button class="btn btn-primary btn-lg" type="submit">
        <i class="fas fa-save me-2"></i>Guncelle
    </button>
    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-secondary btn-lg">Iptal</a>
</form>

@section Scripts {
    <script>
        $(document).ready(function () {
            const existingSpecs = @Html.Raw(serializedSpecs);

            $.getJSON('/data/brands.json', function (brands) {
                var dataList = $('#brandSuggestions');
                dataList.empty();
                (brands || [])
                    .filter(function (brand) { return typeof brand === 'string' && brand.trim().length > 0; })
                    .sort(function (a, b) { return a.localeCompare(b, 'tr', { sensitivity: 'base' }); })
                    .forEach(function (brand) {
                        dataList.append($('<option>').attr('value', brand));
                    });
            });

            function escapeHtml(value) {
                return $('<div>').text(value ?? '').html();
            }

            function renderDynamicSpecs(categoryId) {
                var container = $('#dynamicSpecsContainer');

                if (!categoryId) {
                    container.html('<p class="text-muted small">Kategori secildiginde ozellikler burada gorunecektir.</p>');
                    return;
                }

                container.html('<div class="d-flex justify-content-center"><div class="spinner-border text-primary" role="status"></div></div>');

                $.get('/Admin/Product/GetCategoryAttributes?id=' + categoryId, function (data) {
                    container.empty();

                    if (!data || data.length === 0) {
                        container.html('<div class="alert alert-info py-2">Bu kategori icin tanimli ozellik yok.</div>');
                        return;
                    }

                    $.each(data, function (index, item) {
                        const currentValue = existingSpecs[item.name] || '';
                        let html = '';

                        if (item.type === 'Dropdown' && item.options && item.options.length > 0) {
                            let optionsHtml = '';

                            $.each(item.options, function (i, opt) {
                                const selected = currentValue === opt ? 'selected' : '';
                                optionsHtml += `<option value="${escapeHtml(opt)}" ${selected}>${escapeHtml(opt)}</option>`;
                            });

                            html = `
                                <div class="mb-3">
                                    <label class="form-label font-monospace small fw-bold text-primary">${escapeHtml(item.displayName)}</label>
                                    <select name="Specs[${item.name}]" class="form-select border-primary shadow-sm bg-light">
                                        <option value="">Seciniz...</option>
                                        ${optionsHtml}
                                    </select>
                                </div>
                            `;
                        } else {
                            let inputType = item.type === 'Number' ? 'number' : 'text';
                            html = `
                                <div class="mb-3">
                                    <label class="form-label">${escapeHtml(item.displayName)}</label>
                                    <input type="${inputType}" name="Specs[${item.name}]" class="form-control" placeholder="${escapeHtml(item.displayName)} giriniz" value="${escapeHtml(currentValue)}" />
                                </div>
                            `;
                        }

                        container.append(html);
                    });
                }).fail(function () {
                    container.html('<div class="alert alert-danger">Ozellikler yuklenirken hata olustu.</div>');
                });
            }

            $('#categoryIdSelect').change(function () {
                renderDynamicSpecs($(this).val());
            });

            renderDynamicSpecs($('#categoryIdSelect').val());

            function rebuildExistingImageInputs() {
                $('.existing-image-input').remove();

                $('.photo-item').each(function (index) {
                    var imageUrl = $(this).data('image-url');
                    $('<input>', {
                        type: 'hidden',
                        name: 'ImageUrls',
                        value: imageUrl,
                        class: 'existing-image-input',
                        'data-index': index
                    }).appendTo('#editProductForm');

                    $(this).attr('data-index', index);
                    $(this).find('.btn-remove-photo').attr('data-index', index);
                });

                var currentCount = $('.photo-item').length;
                $('#currentPhotoCount').text(currentCount);
                $('#remainingPhotoCount').text(5 - currentCount);
                $('.cover-badge').addClass('d-none');
                $('.photo-item:first .cover-badge').removeClass('d-none');

                var firstImageUrl = $('.photo-item:first').data('image-url') || '';
                if (firstImageUrl) {
                    $('#coverImageKey').val('existing:' + firstImageUrl);
                }
            }

            rebuildExistingImageInputs();

            $(document).on('click', '.btn-set-cover', function () {
                var item = $(this).closest('.photo-item');
                $('#existingPhotosContainer').prepend(item);
                rebuildExistingImageInputs();
            });

            $('.btn-remove-photo').click(function () {
                var index = $(this).data('index');

                $(`.photo-item[data-index="${index}"]`).remove();
                $(`.existing-image-input[data-index="${index}"]`).remove();
                rebuildExistingImageInputs();

                var currentCount = $('.existing-image-input').length;
                $('#currentPhotoCount').text(currentCount);
                $('#remainingPhotoCount').text(5 - currentCount);

                if (currentCount === 0) {
                    $('#existingPhotosContainer').parent().append('<div class="alert alert-secondary py-2">Tum mevcut fotograflari sildiniz. Yeni fotograf ekleyebilirsiniz.</div>');
                    $('#photoLimitText').hide();
                }
            });

            var selectedNewPhotoFiles = [];

            function setNewCoverPhoto(index) {
                if (index < 0 || index >= selectedNewPhotoFiles.length) return;

                $('#coverImageKey').val('new:' + index);
                $('.photo-item .cover-badge').addClass('d-none');
                renderNewPhotoPreviews();
            }

            function renderNewPhotoPreviews() {
                var previewContainer = $('#newPhotosPreviewContainer');
                var previewLabel = $('#newPhotosPreviewLabel');
                previewContainer.empty();

                if (selectedNewPhotoFiles.length === 0) {
                    previewLabel.addClass('d-none');
                    return;
                }

                previewLabel.removeClass('d-none');

                selectedNewPhotoFiles.forEach((file, index) => {
                    if (!file.type.startsWith('image/')) return;

                    var reader = new FileReader();
                    reader.onload = function (e) {
                        var isCover = $('#coverImageKey').val() === 'new:' + index;
                        var html = `
                            <div class="col-auto position-relative">
                                <img src="${e.target.result}" class="img-thumbnail" style="height: 100px; width: 100px; object-fit: cover;" alt="Preview">
                                <span class="badge bg-primary position-absolute top-0 start-0 m-1 cover-badge ${isCover ? '' : 'd-none'}">Vitrin</span>
                                <button type="button" class="btn btn-light btn-sm position-absolute bottom-0 start-50 translate-middle-x mb-1 btn-new-set-cover" data-index="${index}" title="Vitrin gorseli yap">
                                    <i class="fas fa-star me-1"></i>Vitrin
                                </button>
                            </div>
                        `;
                        previewContainer.append(html);
                    };
                    reader.readAsDataURL(file);
                });
            }

            $(document).on('click', '.btn-new-set-cover', function () {
                setNewCoverPhoto(parseInt($(this).data('index'), 10));
            });

            $('#newPhotosInput').on('change', function () {
                var previewContainer = $('#newPhotosPreviewContainer');
                var previewLabel = $('#newPhotosPreviewLabel');
                previewContainer.empty();

                if (this.files && this.files.length > 0) {
                    var remainingSlots = 5 - $('.existing-image-input').length;

                    if (this.files.length > remainingSlots) {
                        alert('Maksimum 5 fotograf limitine ulastiniz. En fazla ' + remainingSlots + ' yeni fotograf yukleyebilirsiniz.');
                        $(this).val('');
                        selectedNewPhotoFiles = [];
                        $('#coverImageKey').val($('.photo-item:first').data('image-url') ? 'existing:' + $('.photo-item:first').data('image-url') : '');
                        previewLabel.addClass('d-none');
                        return;
                    }

                    selectedNewPhotoFiles = Array.from(this.files);
                    renderNewPhotoPreviews();
                } else {
                    selectedNewPhotoFiles = [];
                    $('#coverImageKey').val($('.photo-item:first').data('image-url') ? 'existing:' + $('.photo-item:first').data('image-url') : '');
                    previewLabel.addClass('d-none');
                }
            });
        });
    </script>
}
