@model List<GameGaraj.WebUI.Models.Campaigns.CampaignRuleViewModel>
@{
    ViewData["Title"] = "İndirim Kuralları";
    var categoryMap = ViewBag.CategoryMap as Dictionary<string, string> ?? new Dictionary<string, string>();
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="fas fa-percentage me-2 text-danger"></i>İndirim Kuralları</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Create" class="btn btn-sm btn-outline-primary">
            <i class="fas fa-plus"></i> Yeni Kural
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="fas fa-tags fa-3x text-muted mb-3"></i>
        <p class="text-muted">Henüz indirim kuralı oluşturulmamış.</p>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i>İlk Kuralı Oluştur
        </a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-sm align-middle">
            <thead>
                <tr>
                    <th>Ad</th>
                    <th>Kural Türü</th>
                    <th>Uygulama Alanı</th>
                    <th>Parametreler</th>
                    <th>Tarih Aralığı</th>
                    <th>Durum</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var rule in Model)
                {
                    <tr>
                        <td>
                            <strong>@rule.Name</strong>
                            @if (!string.IsNullOrEmpty(rule.Description))
                            {
                                <br /><small class="text-muted">@rule.Description</small>
                            }
                        </td>
                        <td>
                            @switch (rule.RuleType)
                            {
                                case "TotalAmount":
                                    <span class="badge bg-primary"><i class="fas fa-money-bill-wave me-1"></i>Toplam Tutar</span>
                                    break;
                                case "BuyXGetYFree":
                                    <span class="badge bg-success"><i class="fas fa-gift me-1"></i>X Al Y Bedava</span>
                                    break;
                                case "CheapestItemDiscount":
                                    <span class="badge bg-warning text-dark"><i class="fas fa-tag me-1"></i>En Ucuz İndirim</span>
                                    break;
                                case "BrandDiscount":
                                    <span class="badge bg-info text-dark"><i class="fas fa-trademark me-1"></i>Marka İndirimi</span>
                                    break;
                                default:
                                    <span class="badge bg-secondary">@rule.RuleType</span>
                                    break;
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(rule.ProductId))
                            {
                                <span class="text-success"><i class="fas fa-box me-1"></i>Ürün: @rule.ProductName</span>
                            }
                            else if (!string.IsNullOrEmpty(rule.BrandName))
                            {
                                <span class="text-secondary"><i class="fas fa-copyright me-1"></i>Marka: @rule.BrandName</span>
                                @if (!string.IsNullOrEmpty(rule.CategoryId) && categoryMap.ContainsKey(rule.CategoryId))
                                {
                                    <small class="text-muted d-block">(Kategori: @categoryMap[rule.CategoryId])</small>
                                }
                            }
                            else if (!string.IsNullOrEmpty(rule.CategoryId) && categoryMap.ContainsKey(rule.CategoryId))
                            {
                                <span class="text-info"><i class="fas fa-folder me-1"></i>Kategori: @categoryMap[rule.CategoryId]</span>
                            }
                            else
                            {
                                <span class="text-muted"><i class="fas fa-globe me-1"></i>Tüm Sepet</span>
                            }
                        </td>
                        <td>
                            @if (rule.MinAmount.HasValue)
                            {
                                <span class="badge bg-light text-dark">Min Sepet: @rule.MinAmount.Value.ToString("N0") ₺</span>
                            }
                            @if (rule.DiscountRate.HasValue)
                            {
                                <span class="badge bg-light text-success">%@rule.DiscountRate İndirim</span>
                            }
                            @if (rule.FixedDiscount.HasValue)
                            {
                                <span class="badge bg-light text-success">@rule.FixedDiscount.Value.ToString("N0") ₺ İndirim</span>
                            }
                            @if (rule.MinQuantity.HasValue)
                            {
                                <span class="badge bg-light text-dark">@rule.MinQuantity Adet</span>
                            }
                            @if (rule.FreeQuantity.HasValue)
                            {
                                <span class="badge bg-light text-dark">@rule.FreeQuantity Bedava</span>
                            }
                        </td>
                        <td>
                            @if (rule.StartDate.HasValue || rule.EndDate.HasValue)
                            {
                                <small class="text-muted">
                                    @(rule.StartDate?.ToString("dd.MM.yyyy") ?? "Başlangıç Yok") - 
                                    @(rule.EndDate?.ToString("dd.MM.yyyy") ?? "Süresiz")
                                </small>
                            }
                            else
                            {
                                <span class="text-muted small">Her Zaman</span>
                            }
                        </td>
                        <td>
                            @if (rule.IsActive)
                            {
                                <span class="badge bg-success">Aktif</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Pasif</span>
                            }
                        </td>
                        <td style="width: 180px;">
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@rule.Id" class="btn btn-sm btn-outline-secondary flex-grow-1">
                                    <i class="fas fa-pen me-1"></i>Düzenle
                                </a>
                                <form asp-action="Delete" method="post" class="m-0"
                                    onsubmit="return confirm('Bu indirim kuralını silmek istediğinize emin misiniz?');">
                                    <input type="hidden" name="id" value="@rule.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
