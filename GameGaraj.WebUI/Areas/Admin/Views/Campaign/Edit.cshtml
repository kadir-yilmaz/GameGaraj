@model GameGaraj.WebUI.Models.Campaigns.CampaignRuleUpdateInput
@{
    ViewData["Title"] = "İndirim Kuralı Düzenle";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="fas fa-edit me-2 text-warning"></i>İndirim Kuralı Düzenle</h1>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i>Geri Dön
    </a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="DiscountRate" id="modelDiscountRate" />
                    <input type="hidden" asp-for="MinQuantity" id="modelMinQuantity" />
                    <input type="hidden" asp-for="FreeQuantity" id="modelFreeQuantity" />
                    <input type="hidden" asp-for="MinAmount" id="modelMinAmount" />
                    <input type="hidden" asp-for="FixedDiscount" id="modelFixedDiscount" />
                    
                    @* Temel Bilgiler *@
                    <div class="row mb-3">
                        <div class="col-md-12">
                            <label class="form-label fw-semibold">Kural Adı <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Açıklama <span class="text-muted small">(isteğe bağlı)</span></label>
                        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Kural Türü <span class="text-danger">*</span></label>
                            <select asp-for="RuleType" asp-items="ViewBag.RuleTypes" class="form-select" id="ruleTypeSelect" required>
                                <option value="">-- Seçiniz --</option>
                            </select>
                        </div>
                        <div class="col-md-6" id="targetTypeCol" style="display:none;">
                            <label class="form-label fw-semibold">Uygulama Kapsamı</label>
                            <select class="form-select" id="targetTypeSelect">
                                <option value="category" selected="@(Model.CategoryId != null)">Kategori Bazlı</option>
                                <option value="product" selected="@(Model.ProductId != null)">Ürün Bazlı</option>
                                <option value="brand" selected="@(Model.BrandName != null)">Marka Bazlı</option>
                            </select>
                        </div>
                    </div>

                    @* Kategori seçimi *@
                    <div class="mb-3" id="categoryField" style="display:none;">
                        <label class="form-label fw-semibold">Kategori Seçiniz</label>
                        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                            <option value="">-- Kategori Seçiniz --</option>
                        </select>
                    </div>

                    @* Marka seçimi *@
                    <div class="mb-3" id="brandField" style="display:none;">
                        <label class="form-label fw-semibold">Marka Adı</label>
                        <input asp-for="BrandName" class="form-control" list="brandsDatalist" />
                        <datalist id="brandsDatalist"></datalist>
                    </div>

                    @* Ürün arama (AJAX) *@
                    <div class="mb-3" id="productField" style="display:none;">
                        <label class="form-label fw-semibold">Ürün Seçiniz</label>
                        <div class="position-relative">
                            <input type="text" id="productSearchInput" class="form-control"
                                   placeholder="Ürün adı yazın (min 2 karakter)..." autocomplete="off" />
                            <div id="productSuggestions"
                                 class="list-group position-absolute w-100 shadow-sm"
                                 style="display:none; z-index:1000; max-height:280px; overflow-y:auto; top:100%;"></div>
                        </div>
                        <input type="hidden" asp-for="ProductId" id="productIdHidden" />
                        <div id="selectedProductBadge" class="mt-2" style="display:none;">
                            <span class="badge bg-primary fs-6 fw-normal" id="selectedProductText">@ViewBag.SelectedProductName</span>
                            <button type="button" class="btn btn-sm btn-link text-danger p-0 ms-1" id="clearProductBtn">
                                <i class="fas fa-times-circle"></i>
                            </button>
                        </div>
                    </div>

                    @* Tarih ve Görsel Ayarları *@
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Başlangıç Tarihi</label>
                            <input asp-for="StartDate" type="date" class="form-control" value="@(Model.StartDate?.ToString("yyyy-MM-dd"))" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Bitiş Tarihi</label>
                            <input asp-for="EndDate" type="date" class="form-control" value="@(Model.EndDate?.ToString("yyyy-MM-dd"))" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Görsel URL</label>
                        <input asp-for="ImageUrl" class="form-control" />
                    </div>

                    @* Dinamik Parametreler *@
                    <div id="totalAmountFields" class="rule-fields" style="display:none;">
                        <div class="card bg-light mb-3">
                            <div class="card-body">
                                <h6 class="card-title text-primary"><i class="fas fa-money-bill-wave me-1"></i>Toplam Tutar Parametreleri</h6>
                                <div class="row">
                                    <div class="col-md-4">
                                        <label class="form-label">Minimum Tutar (₺)</label>
                                        <input id="input_MinAmount_TotalAmount" type="number" step="0.01" class="form-control" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Yüzdelik İndirim (%)</label>
                                        <input id="input_DiscountRate_TotalAmount" type="number" step="0.01" class="form-control" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Sabit İndirim (₺)</label>
                                        <input id="input_FixedDiscount_TotalAmount" type="number" step="0.01" class="form-control" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="buyXGetYFields" class="rule-fields" style="display:none;">
                        <div class="card bg-light mb-3">
                            <div class="card-body">
                                <h6 class="card-title text-success"><i class="fas fa-gift me-1"></i>X Al Y Bedava Parametreleri</h6>
                                <div class="row">
                                    <div class="col-md-6">
                                        <label class="form-label">Satın Alınacak Adet (X)</label>
                                        <input id="input_MinQuantity_BuyX" type="number" class="form-control" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Bedava Adet (Y)</label>
                                        <input id="input_FreeQuantity_BuyX" type="number" class="form-control" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="cheapestItemFields" class="rule-fields" style="display:none;">
                        <div class="card bg-light mb-3">
                            <div class="card-body">
                                <h6 class="card-title text-warning"><i class="fas fa-tag me-1"></i>En Ucuz Ürüne İndirim Parametreleri</h6>
                                <div class="row">
                                    <div class="col-md-6">
                                        <label class="form-label">Minimum Ürün Adedi</label>
                                        <input id="input_MinQuantity_Cheapest" type="number" class="form-control" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">İndirim Oranı (%)</label>
                                        <input id="input_DiscountRate_Cheapest" type="number" step="0.01" class="form-control" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="brandDiscountFields" class="rule-fields" style="display:none;">
                        <div class="card bg-light mb-3">
                            <div class="card-body">
                                <h6 class="card-title text-info"><i class="fas fa-tags me-1"></i>Seçili Ürün / Marka / Kategori Parametreleri</h6>
                                <p class="text-muted small mb-2">Belirtilen ürün, marka ve/veya kategori kapsamındaki tüm ürünlere yüzde indirim uygulanır.</p>
                                <div class="row">
                                    <div class="col-md-6">
                                        <label class="form-label">İndirim Oranı (%)</label>
                                        <input id="input_DiscountRate_Brand" type="number" step="0.01" class="form-control" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Minimum Tutar (₺ - Opsiyonel)</label>
                                        <input id="input_MinAmount_Brand" type="number" step="0.01" class="form-control" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                            <label class="form-check-label fw-semibold" asp-for="IsActive">Aktif</label>
                        </div>
                    </div>

                    <hr />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i>Değişiklikleri Kaydet
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    const ruleSelect = document.getElementById('ruleTypeSelect');
    const targetTypeSelect = document.getElementById('targetTypeSelect');
    const targetTypeCol = document.getElementById('targetTypeCol');
    const categoryField = document.getElementById('categoryField');
    const brandField = document.getElementById('brandField');
    const productField = document.getElementById('productField');

    // ─── Visibility ───────────────────────────────────────────
    function toggleFields() {
        const ruleVal = ruleSelect.value;
        const targetVal = targetTypeSelect.value;

        // Kural tipi parametre bölümleri
        document.querySelectorAll('.rule-fields').forEach(el => el.style.display = 'none');
        if (ruleVal === 'TotalAmount')         document.getElementById('totalAmountFields').style.display = 'block';
        else if (ruleVal === 'BuyXGetYFree')   document.getElementById('buyXGetYFields').style.display = 'block';
        else if (ruleVal === 'CheapestItemDiscount') document.getElementById('cheapestItemFields').style.display = 'block';
        else if (ruleVal === 'BrandDiscount')  document.getElementById('brandDiscountFields').style.display = 'block';

        // TotalAmount hariç kapsam seçimi var
        const needsTarget = (ruleVal === 'BuyXGetYFree' || ruleVal === 'CheapestItemDiscount' || ruleVal === 'BrandDiscount');
        targetTypeCol.style.display = needsTarget ? 'block' : 'none';
        
        categoryField.style.display = (needsTarget && targetVal === 'category') ? 'block' : 'none';
        productField.style.display  = (needsTarget && targetVal === 'product')  ? 'block' : 'none';
        brandField.style.display    = (needsTarget && targetVal === 'brand')    ? 'block' : 'none';
    }

    ruleSelect.addEventListener('change', toggleFields);
    targetTypeSelect.addEventListener('change', toggleFields);
    toggleFields();

    // ─── Ürün AJAX Arama ─────────────────────────────────────
    const searchInput   = document.getElementById('productSearchInput');
    const suggestions   = document.getElementById('productSuggestions');
    const hiddenInput   = document.getElementById('productIdHidden');
    const badge         = document.getElementById('selectedProductBadge');
    const badgeText     = document.getElementById('selectedProductText');
    const clearBtn      = document.getElementById('clearProductBtn');

    if (hiddenInput.value) {
        badge.style.display = 'block';
    }

    let searchTimeout;

    searchInput.addEventListener('input', function () {
        clearTimeout(searchTimeout);
        const q = this.value.trim();
        if (q.length < 2) { suggestions.style.display = 'none'; return; }

        searchTimeout = setTimeout(() => {
            fetch(`/Admin/Campaign/SearchProducts?q=${encodeURIComponent(q)}`)
                .then(r => r.json())
                .then(data => {
                    suggestions.innerHTML = '';
                    if (!data.length) {
                        suggestions.innerHTML = '<div class="list-group-item text-muted">Ürün bulunamadı</div>';
                    } else {
                        data.forEach(p => {
                            const item = document.createElement('button');
                            item.type = 'button';
                            item.className = 'list-group-item list-group-item-action d-flex justify-content-between align-items-center';
                            item.innerHTML = `<span>${p.name}</span><small class="text-muted">${p.price}</small>`;
                            item.addEventListener('click', () => selectProduct(p.id, p.name));
                            suggestions.appendChild(item);
                        });
                    }
                    suggestions.style.display = 'block';
                })
                .catch(() => { suggestions.style.display = 'none'; });
        }, 300);
    });

    function selectProduct(id, name) {
        hiddenInput.value = id;
        badgeText.textContent = name;
        badge.style.display = 'block';
        searchInput.value = '';
        suggestions.style.display = 'none';
    }

    function clearProduct() {
        hiddenInput.value = '';
        badgeText.textContent = '';
        badge.style.display = 'none';
        searchInput.value = '';
        suggestions.style.display = 'none';
    }

    clearBtn.addEventListener('click', clearProduct);

    document.addEventListener('click', function (e) {
        if (!searchInput.contains(e.target) && !suggestions.contains(e.target)) {
            suggestions.style.display = 'none';
        }
    });

        // Load brands data for datalist suggestions
        const brandsDatalist = document.getElementById('brandsDatalist');
        if (brandsDatalist) {
            fetch('/data/brands.json')
                .then(res => res.json())
                .then(brands => {
                    brands.sort().forEach(brand => {
                        const opt = document.createElement('option');
                        opt.value = brand;
                        brandsDatalist.appendChild(opt);
                    });
                })
                .catch(err => console.error('Markalar yüklenemedi:', err));
        }

        // Pre-fill panel inputs on page load based on model values
        const ruleVal = ruleSelect.value;
        const modelDiscountRate = document.getElementById('modelDiscountRate').value;
        const modelMinQuantity = document.getElementById('modelMinQuantity').value;
        const modelFreeQuantity = document.getElementById('modelFreeQuantity').value;
        const modelMinAmount = document.getElementById('modelMinAmount').value.replace(',', '.');
        const modelFixedDiscount = document.getElementById('modelFixedDiscount').value.replace(',', '.');

        if (ruleVal === 'TotalAmount') {
            document.getElementById('input_MinAmount_TotalAmount').value = modelMinAmount;
            document.getElementById('input_DiscountRate_TotalAmount').value = modelDiscountRate;
            document.getElementById('input_FixedDiscount_TotalAmount').value = modelFixedDiscount;
        } 
        else if (ruleVal === 'BuyXGetYFree') {
            document.getElementById('input_MinQuantity_BuyX').value = modelMinQuantity;
            document.getElementById('input_FreeQuantity_BuyX').value = modelFreeQuantity;
        } 
        else if (ruleVal === 'CheapestItemDiscount') {
            document.getElementById('input_MinQuantity_Cheapest').value = modelMinQuantity;
            document.getElementById('input_DiscountRate_Cheapest').value = modelDiscountRate;
        } 
        else if (ruleVal === 'BrandDiscount') {
            document.getElementById('input_DiscountRate_Brand').value = modelDiscountRate;
            document.getElementById('input_MinAmount_Brand').value = modelMinAmount;
        }

        // Copy panel inputs to model hidden inputs on submit
        const form = document.querySelector('form');
        if (form) {
            form.addEventListener('submit', function (e) {
                // Reset hidden inputs first
                document.getElementById('modelDiscountRate').value = '';
                document.getElementById('modelMinQuantity').value = '';
                document.getElementById('modelFreeQuantity').value = '';
                document.getElementById('modelMinAmount').value = '';
                document.getElementById('modelFixedDiscount').value = '';

                const currentRuleVal = ruleSelect.value;
                if (currentRuleVal === 'TotalAmount') {
                    document.getElementById('modelMinAmount').value = document.getElementById('input_MinAmount_TotalAmount').value;
                    document.getElementById('modelDiscountRate').value = document.getElementById('input_DiscountRate_TotalAmount').value;
                    document.getElementById('modelFixedDiscount').value = document.getElementById('input_FixedDiscount_TotalAmount').value;
                } 
                else if (currentRuleVal === 'BuyXGetYFree') {
                    document.getElementById('modelMinQuantity').value = document.getElementById('input_MinQuantity_BuyX').value;
                    document.getElementById('modelFreeQuantity').value = document.getElementById('input_FreeQuantity_BuyX').value;
                } 
                else if (currentRuleVal === 'CheapestItemDiscount') {
                    document.getElementById('modelMinQuantity').value = document.getElementById('input_MinQuantity_Cheapest').value;
                    document.getElementById('modelDiscountRate').value = document.getElementById('input_DiscountRate_Cheapest').value;
                } 
                else if (currentRuleVal === 'BrandDiscount') {
                    document.getElementById('modelDiscountRate').value = document.getElementById('input_DiscountRate_Brand').value;
                    document.getElementById('modelMinAmount').value = document.getElementById('input_MinAmount_Brand').value;
                }
            });
        }
    });
</script>
}
