@model List<GameGaraj.WebUI.Models.Campaigns.CouponViewModel>
@{
    ViewData["Title"] = "İndirim Kuponları";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h3 mb-0 text-gray-800">İndirim Kuponları</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Yeni Kupon Oluştur
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow mb-4 border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Kod</th>
                            <th>Kupon Türü</th>
                            <th>Değer</th>
                            <th>Min. Sepet</th>
                            <th>Kullanıcı</th>
                            <th>Durum</th>
                            <th>Son Kullanma</th>
                            <th class="text-end pe-4">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <span class="badge bg-secondary p-2">@item.Code</span>
                                    </td>
                                    <td>@item.DiscountTypeDisplayName</td>
                                    <td>
                                        @if (item.DiscountType == "Percentage")
                                        {
                                            <span class="fw-bold text-success">%@item.DiscountRate</span>
                                            @if (item.MaxDiscountAmount > 0)
                                            {
                                                <small class="text-muted d-block">(Max @item.MaxDiscountAmount TL)</small>
                                            }
                                        }
                                        else if (item.DiscountType == "FixedAmount")
                                        {
                                            <span class="fw-bold text-success">@item.Amount TL</span>
                                        }
                                        else if (item.DiscountType == "FreeShipping")
                                        {
                                            <span class="fw-bold text-info">Kargo Bedava</span>
                                        }
                                    </td>
                                    <td>@(item.MinPurchaseAmount > 0 ? $"{item.MinPurchaseAmount} TL" : "Yok")</td>
                                    <td>
                                        <span class="text-muted small">@(string.IsNullOrEmpty(item.UserId) ? "Tüm Kullanıcılar" : $"Özel ({item.UserId})")</span>
                                    </td>
                                    <td>
                                        @if (item.IsUsed)
                                        {
                                            <span class="badge bg-danger">Kullanıldı</span>
                                            @if (item.UsedDate.HasValue)
                                            {
                                                <small class="text-muted d-block">@item.UsedDate.Value.ToString("dd.MM.yyyy HH:mm")</small>
                                            }
                                        }
                                        else if (item.ExpiryDate.HasValue && item.ExpiryDate.Value < DateTime.Now)
                                        {
                                            <span class="badge bg-warning text-dark">Süresi Doldu</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Aktif</span>
                                        }
                                    </td>
                                    <td>
                                        @if(item.ExpiryDate.HasValue)
                                        {
                                            <span class="@(item.ExpiryDate.Value < DateTime.Now ? "text-danger" : "")">
                                                @item.ExpiryDate.Value.ToString("dd.MM.yyyy")
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Süresiz</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bu kuponu silmek istediğinize emin misiniz?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Sil">
                                                <i class="fas fa-trash"></i> Sil
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-4 text-muted">
                                    <i class="fas fa-ticket-alt fa-3x mb-3 opacity-50"></i>
                                    <p class="mb-0">Henüz hiç indirim kuponu tanımlanmamış.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
